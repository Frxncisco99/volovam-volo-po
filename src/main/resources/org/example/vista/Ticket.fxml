<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
    Ticket.fxml — Vista previa del ticket de venta.
    Controlador: org.example.controlador.TicketController

    Paleta de colores consistente con Ventas.fxml:
      Café oscuro sidebar : #3D1F0D
      Café botones        : #6B4226
      Café texto          : #7A5535
      Dorado              : #D4A843
      Fondo claro         : #F5EFE6
-->
<VBox xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controlador.TicketController"
      prefWidth="480" prefHeight="640"
      spacing="0"
      style="-fx-background-color: #F5EFE6;">

    <!-- ── TOPBAR ─────────────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color: #3D1F0D; -fx-padding: 16 20;">
        <VBox spacing="2">
            <Label style="-fx-text-fill: #D4A843; -fx-font-size: 18px; -fx-font-weight: bold;"
                   text="Volovan Volo"/>
            <Label style="-fx-text-fill: #C8A97E; -fx-font-size: 10px;"
                   text="Sistema de Punto de Venta"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblNumeroVenta"
               style="-fx-text-fill: #D4A843; -fx-font-size: 13px; -fx-font-weight: bold;"
               text="Venta # --"/>
    </HBox>

    <!-- ── RESUMEN DE DATOS ───────────────────────────────────────────────── -->
    <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 16 20;">

        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #6B4226;"
               text="Resumen de la venta"/>
        <Separator/>

        <!-- Fila: Fecha / Cajero -->
        <HBox spacing="16">
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="FECHA"/>
                <Label fx:id="lblFecha"
                       style="-fx-text-fill: #3D1F0D; -fx-font-size: 13px; -fx-font-weight: bold;"
                       text="--/--/---- --:--"/>
            </VBox>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="CAJERO"/>
                <Label fx:id="lblCajero"
                       style="-fx-text-fill: #3D1F0D; -fx-font-size: 13px; -fx-font-weight: bold;"
                       text="--"/>
            </VBox>
        </HBox>

        <!-- Fila: Total / Recibido / Cambio -->
        <HBox spacing="8" style="-fx-padding: 8 0 0 0;">
            <!-- Total -->
            <VBox spacing="2" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #F5EFE6; -fx-background-radius: 8; -fx-padding: 10 12;">
                <Label style="-fx-text-fill: #7A5535; -fx-font-size: 9px; -fx-font-weight: bold;"
                       text="TOTAL"/>
                <Label fx:id="lblTotal"
                       style="-fx-text-fill: #6B4226; -fx-font-size: 20px; -fx-font-weight: bold;"
                       text="0.00"/>
            </VBox>
            <!-- Recibido -->
            <VBox spacing="2" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #F5EFE6; -fx-background-radius: 8; -fx-padding: 10 12;">
                <Label style="-fx-text-fill: #7A5535; -fx-font-size: 9px; -fx-font-weight: bold;"
                       text="RECIBIDO"/>
                <Label fx:id="lblRecibido"
                       style="-fx-text-fill: #3D1F0D; -fx-font-size: 20px; -fx-font-weight: bold;"
                       text="0.00"/>
            </VBox>
            <!-- Cambio -->
            <VBox spacing="2" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #E8F5E9; -fx-background-radius: 8; -fx-padding: 10 12;">
                <Label style="-fx-text-fill: #2E7D32; -fx-font-size: 9px; -fx-font-weight: bold;"
                       text="CAMBIO"/>
                <Label fx:id="lblCambio"
                       style="-fx-text-fill: #2E7D32; -fx-font-size: 20px; -fx-font-weight: bold;"
                       text="0.00"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- ── VISTA PREVIA DEL TICKET ────────────────────────────────────────── -->
    <VBox spacing="6" style="-fx-padding: 14 20;" VBox.vgrow="ALWAYS">
        <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B4226;"
               text="Vista previa del ticket"/>
        <TextArea fx:id="txtVistaPrevia"
                  VBox.vgrow="ALWAYS"
                  wrapText="false"
                  style="-fx-font-family: 'Courier New', monospace;
                         -fx-font-size: 11px;
                         -fx-background-color: white;
                         -fx-border-color: #D4A843;
                         -fx-border-radius: 6;
                         -fx-background-radius: 6;
                         -fx-text-fill: #3D1F0D;"/>
    </VBox>

    <!-- ── BOTONES DE ACCIÓN ──────────────────────────────────────────────── -->
    <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 14 20;">
        <Separator/>
        <HBox spacing="10">
            <!-- Imprimir (primario) -->
            <Button prefHeight="42" HBox.hgrow="ALWAYS"
                    onAction="#handleImprimir"
                    style="-fx-background-color: #6B4226;
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;"
                    text="Imprimir ticket"
                    graphicTextGap="8">
                <graphic>
                    <FontIcon iconLiteral="fas-print" iconSize="16" iconColor="white"/>
                </graphic>
            </Button>

            <!-- Reimprimir (secundario) -->
            <Button prefHeight="42" prefWidth="140"
                    onAction="#handleReimprimir"
                    style="-fx-background-color: transparent;
                           -fx-border-color: #6B4226;
                           -fx-border-width: 1.4;
                           -fx-border-radius: 8;
                           -fx-text-fill: #6B4226;
                           -fx-font-size: 12px;
                           -fx-cursor: hand;"
                    text="Reimprimir"
                    graphicTextGap="8">
                <graphic>
                    <FontIcon iconLiteral="fas-redo" iconSize="13" iconColor="#6B4226"/>
                </graphic>
            </Button>
        </HBox>

        <!-- Cerrar -->
        <Button prefHeight="36" prefWidth="440"
                onAction="#handleCerrar"
                style="-fx-background-color: transparent;
                       -fx-border-color: #C0392B;
                       -fx-border-width: 1.2;
                       -fx-border-radius: 8;
                       -fx-text-fill: #C0392B;
                       -fx-font-size: 12px;
                       -fx-cursor: hand;"
                text="Cerrar sin imprimir"/>
    </VBox>

</VBox>
