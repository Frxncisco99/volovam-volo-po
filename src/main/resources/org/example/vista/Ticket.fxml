<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controlador.TicketController"
      prefWidth="500" prefHeight="700"
      spacing="0"
      style="-fx-background-color: #F5EFE6;">

    <!-- TOPBAR -->
    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color: #3D1F0D; -fx-padding: 14 20;">
        <VBox spacing="1">
            <Label style="-fx-text-fill: #D4A843; -fx-font-size: 16px; -fx-font-weight: bold;"
                   text="Volovan Volo"/>
            <Label style="-fx-text-fill: #C8A97E; -fx-font-size: 9px;"
                   text="Sistema de Punto de Venta"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblNumeroVenta"
               style="-fx-text-fill: #D4A843; -fx-font-size: 12px; -fx-font-weight: bold;"
               text="Folio # --"/>
    </HBox>

    <!-- RESUMEN -->
    <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 14 20;">

        <!-- Logo + Info negocio -->
        <HBox spacing="14" alignment="CENTER_LEFT">
            <ImageView fitWidth="80" fitHeight="80" preserveRatio="true">
                <image>
                    <Image url="@../Imagenes/logo_volovan.png"/>
                </image>
            </ImageView>
            <VBox spacing="3">
                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #6B4226;"
                       text="Volovan Volo"/>
                <Label style="-fx-font-size: 10px; -fx-text-fill: #7A5535;"
                       text="Panaderia y Reposteria"/>
                <Label style="-fx-font-size: 9px; -fx-text-fill: #7A5535;"
                       text="C. Francisco I Madero #1515"/>
                <Label style="-fx-font-size: 9px; -fx-text-fill: #7A5535;"
                       text="Col. Nogales, C.P. 26236"/>
                <Label style="-fx-font-size: 9px; -fx-text-fill: #9E7040; -fx-font-style: italic;"
                       text="Este ticket no es comprobante fiscal"/>
            </VBox>
        </HBox>

        <Separator/>

        <!-- Fecha / Cajero / Caja -->
        <HBox spacing="8">
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #7A5535; -fx-font-size: 9px; -fx-font-weight: bold;" text="FECHA"/>
                <Label fx:id="lblFecha"
                       style="-fx-text-fill: #3D1F0D; -fx-font-size: 11px; -fx-font-weight: bold;"
                       text="--/--/---- --:--"/>
            </VBox>
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label style="-fx-text-fill: #7A5535; -fx-font-size: 9px; -fx-font-weight: bold;" text="CAJERO"/>
                <Label fx:id="lblCajero"
                       style="-fx-text-fill: #3D1F0D; -fx-font-size: 11px; -fx-font-weight: bold;"
                       text="--"/>
            </VBox>
            <VBox spacing="2">
                <Label style="-fx-text-fill: #7A5535; -fx-font-size: 9px; -fx-font-weight: bold;" text="CAJA"/>
                <Label fx:id="lblCaja"
                       style="-fx-text-fill: #3D1F0D; -fx-font-size: 11px; -fx-font-weight: bold;"
                       text="--"/>
            </VBox>
        </HBox>

        <!-- Total / Recibido / Cambio / Articulos -->
        <HBox spacing="6" style="-fx-padding: 4 0 0 0;">
            <VBox spacing="2" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #F5EFE6; -fx-background-radius: 8; -fx-padding: 8 10;">
                <Label style="-fx-text-fill: #7A5535; -fx-font-size: 8px; -fx-font-weight: bold;" text="TOTAL"/>
                <Label fx:id="lblTotal"
                       style="-fx-text-fill: #6B4226; -fx-font-size: 17px; -fx-font-weight: bold;"
                       text="0.00"/>
            </VBox>
            <VBox spacing="2" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #F5EFE6; -fx-background-radius: 8; -fx-padding: 8 10;">
                <Label style="-fx-text-fill: #7A5535; -fx-font-size: 8px; -fx-font-weight: bold;" text="RECIBIDO"/>
                <Label fx:id="lblRecibido"
                       style="-fx-text-fill: #3D1F0D; -fx-font-size: 17px; -fx-font-weight: bold;"
                       text="0.00"/>
            </VBox>
            <VBox spacing="2" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #E8F5E9; -fx-background-radius: 8; -fx-padding: 8 10;">
                <Label style="-fx-text-fill: #2E7D32; -fx-font-size: 8px; -fx-font-weight: bold;" text="CAMBIO"/>
                <Label fx:id="lblCambio"
                       style="-fx-text-fill: #2E7D32; -fx-font-size: 17px; -fx-font-weight: bold;"
                       text="0.00"/>
            </VBox>
            <VBox spacing="2"
                  style="-fx-background-color: #FFF8E7; -fx-background-radius: 8; -fx-padding: 8 10;">
                <Label style="-fx-text-fill: #B8860B; -fx-font-size: 8px; -fx-font-weight: bold;" text="ARTICULOS"/>
                <Label fx:id="lblArticulos"
                       style="-fx-text-fill: #B8860B; -fx-font-size: 17px; -fx-font-weight: bold;"
                       text="0"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- VISTA PREVIA -->
    <VBox spacing="6" style="-fx-padding: 12 20;" VBox.vgrow="ALWAYS">
        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #6B4226;"
               text="Vista previa del ticket"/>
        <TextArea fx:id="txtVistaPrevia"
                  VBox.vgrow="ALWAYS"
                  wrapText="false"
                  style="-fx-font-family: 'Courier New', monospace;
                         -fx-font-size: 11px;
                         -fx-background-color: white;
                         -fx-border-color: #D4A843;
                         -fx-border-radius: 6;
                         -fx-background-radius: 6;
                         -fx-text-fill: #3D1F0D;"/>
    </VBox>

    <!-- BOTONES -->
    <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 12 20;">
        <Separator/>
        <HBox spacing="10">
            <Button prefHeight="42" HBox.hgrow="ALWAYS"
                    onAction="#handleImprimir"
                    style="-fx-background-color: #6B4226; -fx-text-fill: white; -fx-font-size: 13px;
                           -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                    text="Imprimir ticket" graphicTextGap="8">
                <graphic><FontIcon iconLiteral="fas-print" iconSize="16" iconColor="white"/></graphic>
            </Button>
            <Button prefHeight="42" prefWidth="130"
                    onAction="#handleReimprimir"
                    style="-fx-background-color: transparent; -fx-border-color: #6B4226;
                           -fx-border-width: 1.4; -fx-border-radius: 8; -fx-text-fill: #6B4226;
                           -fx-font-size: 12px; -fx-cursor: hand;"
                    text="Reimprimir" graphicTextGap="8">
                <graphic><FontIcon iconLiteral="fas-redo" iconSize="13" iconColor="#6B4226"/></graphic>
            </Button>
        </HBox>
        <Button prefHeight="36" prefWidth="460"
                onAction="#handleCerrar"
                style="-fx-background-color: transparent; -fx-border-color: #C0392B;
                       -fx-border-width: 1.2; -fx-border-radius: 8; -fx-text-fill: #C0392B;
                       -fx-font-size: 12px; -fx-cursor: hand;"
                text="Cerrar sin imprimir"/>
    </VBox>

</VBox>
