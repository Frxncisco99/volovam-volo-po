<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="700" prefWidth="1100" stylesheets="@menuPrincipal.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controlador.MenuPrincipal">

    <!-- ===================== SIDEBAR ===================== -->
    <left>
        <VBox prefWidth="230" style="-fx-background-color: #091e4e;">

            <!-- Marca -->
            <VBox prefHeight="72.0" prefWidth="219.0" spacing="3" style="-fx-padding: 24 18 16 18;">
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Volovan Volo" />
                <Label style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 9px;" text="SISTEMA DE PUNTO DE VENTA" />
            </VBox>

            <Separator style="-fx-opacity: 0.15;" />

            <!-- Usuario -->
            <HBox spacing="10" style="-fx-padding: 14 18;">
                <Label fx:id="lblAvatarIniciales" style="-fx-background-color: rgba(255,255,255,0.22);                               -fx-text-fill: white;                               -fx-font-weight: bold;                               -fx-font-size: 13px;                               -fx-min-width: 36; -fx-min-height: 36;                               -fx-background-radius: 18;                               -fx-alignment: center;" text="AD" />
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Usuario" />
                    <Label fx:id="lblRolUsuario" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 10px;" text="Rol" />
                </VBox>
            </HBox>

            <Separator style="-fx-opacity: 0.15;" />

            <!-- Navegación -->
            <VBox spacing="3" style="-fx-padding: 10 10;" VBox.vgrow="ALWAYS">

                <Label style="-fx-text-fill: rgba(255,255,255,0.35);                               -fx-font-size: 9px; -fx-font-weight: bold;                               -fx-padding: 8 8 3 8;" text="PRINCIPAL" />

                <!-- Dashboard (activo) -->
                <Button graphicTextGap="12" prefHeight="40" prefWidth="210" style="-fx-background-color: white;                                -fx-text-fill: #1a6fa8;                                -fx-font-weight: bold;                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Dashboard">
                    <graphic><FontIcon iconColor="#1a6fa8" iconLiteral="fas-tachometer-alt" iconSize="16" /></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAVentas" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Ventas / Caja">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-shopping-cart" iconSize="16" /></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#abrirInventario" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Inventario">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-box" iconSize="16" /></graphic>
                </Button>

                <Label style="-fx-text-fill: rgba(255,255,255,0.35);                               -fx-font-size: 9px; -fx-font-weight: bold;                               -fx-padding: 12 8 3 8;" text="GESTIÓN" />

                <Button graphicTextGap="12" onAction="#irAEmpleados" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Empleados">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-users" iconSize="16" /></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAClientes" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Clientes">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-user-friends" iconSize="16" /></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAReportes" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Reportes">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-chart-bar" iconSize="16" /></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irACorteCaja" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Corte de Caja">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-cash-register" iconSize="16" /></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAAuditoria"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Auditoría" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-shield-alt" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAConfiguracion" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Configuracion">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-cog" iconSize="16" /></graphic>
                </Button>

            </VBox>

            <Separator style="-fx-opacity: 0.15;" />

            <!-- Cerrar sesión -->
            <Button graphicTextGap="10" onAction="#btnCerrar" prefHeight="44" prefWidth="230" style="-fx-background-color: transparent;                            -fx-text-fill: rgba(255,180,180,0.9);                            -fx-cursor: hand;" text="Cerrar sesion" textFill="RED">
                <graphic><FontIcon iconColor="#ff0000e5" iconLiteral="fas-sign-out-alt" iconSize="16" /></graphic>
            </Button>

        </VBox>
    </left>

    <!-- ===================== CONTENIDO PRINCIPAL ===================== -->
    <center>
        <VBox style="-fx-background-color: #f0f7ff;">

            <!-- Topbar -->
            <HBox alignment="CENTER_LEFT" styleClass="topbar">
                <VBox spacing="2">
                    <Label style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Menu Principal" />
                    <Label fx:id="lblFecha" style="-fx-font-size: 11px; -fx-text-fill: #6a96b8;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="lblHora" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" />
                    <Label style="-fx-background-color: #e0f5e9;                                   -fx-text-fill: #1e7d3e;                                   -fx-background-radius: 10;                                   -fx-padding: 2 10;                                   -fx-font-size: 10px;" text="Caja abierta" />
                </VBox>
            </HBox>

            <!-- Scroll del contenido -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="14" style="-fx-padding: 18;">

                    <!-- ── TARJETAS STAT ── -->
                    <HBox spacing="10">

                        <!-- Ventas hoy -->
                        <VBox onMouseClicked="#irAReportes" spacing="5" style="-fx-cursor: hand;" styleClass="card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT">
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="VENTAS HOY" />
                                <Region HBox.hgrow="ALWAYS" />
                                <FontIcon iconColor="#1a6fa8" iconLiteral="fas-dollar-sign" iconSize="14" />
                            </HBox>
                            <Label fx:id="lblVentasHoy" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="\$0.00" />
                            <Label fx:id="lblVentasDelta" style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="sin ventas aun" />
                        </VBox>

                        <!-- Tickets hoy -->
                        <VBox onMouseClicked="#irAReportes" spacing="5" style="-fx-cursor: hand;" styleClass="card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT">
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="TICKETS HOY" />
                                <Region HBox.hgrow="ALWAYS" />
                                <FontIcon iconColor="#1a6fa8" iconLiteral="fas-receipt" iconSize="14" />
                            </HBox>
                            <Label fx:id="lblPedidosHoy" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="0" />
                            <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="ventas realizadas" />
                        </VBox>

                        <!-- Productos vendidos -->
                        <VBox spacing="5" styleClass="card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT">
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="PRODUCTOS VENDIDOS" />
                                <Region HBox.hgrow="ALWAYS" />
                                <FontIcon iconColor="#1a6fa8" iconLiteral="fas-box-open" iconSize="14" />
                            </HBox>
                            <Label fx:id="lblProductosVendidos" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="0" />
                            <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="unidades hoy" />
                        </VBox>

                        <!-- Stock bajo (card-dark = azul solido) -->
                        <VBox onMouseClicked="#abrirInventario" spacing="5" style="-fx-cursor: hand;" styleClass="card-dark" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT">
                                <Label style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 9px; -fx-font-weight: bold;" text="STOCK BAJO" />
                                <Region HBox.hgrow="ALWAYS" />
                                <FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-exclamation-triangle" iconSize="14" />
                            </HBox>
                            <Label fx:id="lblProductosBajos" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;" text="0" />
                            <Label style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 10px;" text="clic para ver" />
                        </VBox>

                    </HBox>

                    <!-- ── FILA INFERIOR ── -->
                    <HBox spacing="12">

                        <!-- Ultimas ventas -->
                        <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="7">
                                <FontIcon iconColor="#1a6fa8" iconLiteral="fas-history" iconSize="13" />
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 13px;" text="Ultimas ventas" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#irAReportes" style="-fx-background-color: transparent;                                                -fx-text-fill: #1a6fa8;                                                -fx-font-size: 11px;                                                -fx-cursor: hand;                                                -fx-underline: true;" text="Ver todas" />
                            </HBox>
                            <Separator style="-fx-opacity: 0.15;" />

                            <!-- Encabezado tabla -->
                            <HBox style="-fx-padding: 0 6 4 6;">
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px; -fx-font-weight: bold; -fx-min-width: 80;" text="HORA" />
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px; -fx-font-weight: bold; -fx-min-width: 60;" text="FOLIO" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px; -fx-font-weight: bold;" text="TOTAL" />
                            </HBox>

                            <VBox fx:id="listaUltimasVentas" spacing="3" />
                            <Label fx:id="lblSinVentas" style="-fx-text-fill: #6a96b8; -fx-font-size: 12px; -fx-alignment: center; -fx-padding: 20 0;" text="Sin ventas hoy" />
                        </VBox>

                        <!-- Panel derecho -->
                        <VBox prefWidth="290" spacing="12">

                            <!-- Grafica mas vendidos -->
                            <VBox spacing="8" styleClass="card">
                                <HBox alignment="CENTER_LEFT" spacing="7">
                                    <FontIcon iconColor="#1a6fa8" iconLiteral="fas-crown" iconSize="13" />
                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 13px;" text="Mas vendidos hoy" />
                                </HBox>
                                <Separator style="-fx-opacity: 0.15;" />
                                <PieChart fx:id="graficaVentas" labelsVisible="true" legendVisible="true" prefHeight="260" prefWidth="270" />
                                <Label fx:id="lblSinTop" style="-fx-text-fill: #6a96b8; -fx-font-size: 12px;" text="Sin datos aun" />
                            </VBox>

                            <!-- Acceso rapido -->
                            <VBox spacing="7" styleClass="card">
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 13px;" text="Acceso rapido" />
                                <Separator style="-fx-opacity: 0.15;" />

                                <Button graphicTextGap="10" onAction="#irAVentas" prefHeight="40" prefWidth="256" style="-fx-background-color: #1a6fa8;                                                -fx-background-radius: 8;                                                -fx-text-fill: white;                                                -fx-font-weight: bold;                                                -fx-cursor: hand;" text="Nueva Venta">
                                    <graphic><FontIcon iconColor="white" iconLiteral="fas-shopping-cart" iconSize="13" /></graphic>
                                </Button>

                                <Button graphicTextGap="10" onAction="#abrirInventario" prefHeight="40" prefWidth="256" style="-fx-background-color: transparent;                                                -fx-border-color: #1a6fa8;                                                -fx-border-radius: 8;                                                -fx-border-width: 1;                                                -fx-text-fill: #1a6fa8;                                                -fx-font-weight: bold;                                                -fx-cursor: hand;                                                -fx-background-radius: 8;" text="Inventario">
                                    <graphic><FontIcon iconColor="#1a6fa8" iconLiteral="fas-box" iconSize="13" /></graphic>
                                </Button>

                                <Button graphicTextGap="10" onAction="#irACorteCaja" prefHeight="40" prefWidth="256" style="-fx-background-color: transparent;                                                -fx-border-color: #C0392B;                                                -fx-border-radius: 8;                                                -fx-border-width: 1;                                                -fx-text-fill: #C0392B;                                                -fx-font-weight: bold;                                                -fx-cursor: hand;                                                -fx-background-radius: 8;" text="Corte de Caja">
                                    <graphic><FontIcon iconColor="#C0392B" iconLiteral="fas-cash-register" iconSize="13" /></graphic>
                                </Button>

                            </VBox>
                        </VBox>
                    </HBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
