<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controlador.InventarioController"
      style="-fx-background-color: #EDEADE;"
      VBox.vgrow="ALWAYS">

    <HBox alignment="CENTER_LEFT" style="-fx-padding: 22 28 16 28; -fx-background-color: #EDEADE;">
        <VBox spacing="2">
            <Label text="Inventario"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #6B1228;" />
            <Label text="Gestion de productos"
                   style="-fx-font-size: 11px; -fx-text-fill: #8B4A5A;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="+ Nuevo producto"
                onAction="#abrirFormularioNuevo"
                style="-fx-background-color: #6B1228; -fx-text-fill: #F5EFE0; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 9 20; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;" />
    </HBox>

    <HBox spacing="12" style="-fx-padding: 0 28 20 28;">
        <VBox spacing="6" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #F5EFE6; -fx-background-radius: 10; -fx-border-color: #D4C9B0; -fx-border-width: 0.5; -fx-border-radius: 10; -fx-padding: 16 18;">
            <Label text="TOTAL PRODUCTOS"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #8B4A5A;" />
            <Label fx:id="lblTotalProductos" text="0"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #6B1228;" />
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #F5EFE6; -fx-background-radius: 10; -fx-border-color: #D4C9B0; -fx-border-width: 0.5; -fx-border-radius: 10; -fx-padding: 16 18;">
            <Label text="STOCK BAJO"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #8B4A5A;" />
            <Label fx:id="lblStockBajo" text="0"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #A32D2D;" />
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #F5EFE6; -fx-background-radius: 10; -fx-border-color: #D4C9B0; -fx-border-width: 0.5; -fx-border-radius: 10; -fx-padding: 16 18;">
            <Label text="VALOR TOTAL"
                   style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #8B4A5A;" />
            <Label fx:id="lblValorTotal" text="0.00"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #C9A84C;" />
        </VBox>
    </HBox>

    <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 28 16 28;">
        <TextField fx:id="txtBuscar"
                   promptText="Buscar por nombre o categoria..."
                   prefWidth="300"
                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #C9A84C; -fx-border-width: 0.5; -fx-padding: 8 14; -fx-font-size: 12px; -fx-background-color: #F5EFE6;" />
        <ComboBox fx:id="cbCategoria" promptText="Categorias" prefWidth="150"
                  style="-fx-background-radius: 8; -fx-border-color: #C9A84C; -fx-border-width: 0.5; -fx-background-color: #F5EFE6; -fx-font-size: 12px;" />
        <ComboBox fx:id="cbEstado" promptText="Estado" prefWidth="130"
                  style="-fx-background-radius: 8; -fx-border-color: #C9A84C; -fx-border-width: 0.5; -fx-background-color: #F5EFE6; -fx-font-size: 12px;" />
        <Button text="Limpiar" onAction="#limpiarFiltros"
                style="-fx-background-color: #F5EFE6; -fx-text-fill: #6B1228; -fx-border-color: #C9A84C; -fx-border-width: 0.5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 14; -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold;" />
    </HBox>

    <VBox style="-fx-padding: 0 28 28 28;" VBox.vgrow="ALWAYS">
        <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: #F5EFE6; -fx-border-color: #D4C9B0; -fx-border-width: 0.5; -fx-background-radius: 10; -fx-border-radius: 10;">
            <columns>
                <TableColumn fx:id="colId"        text="ID"        prefWidth="55" />
                <TableColumn fx:id="colNombre"    text="Nombre"    prefWidth="200" />
                <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="150" />
                <TableColumn fx:id="colPrecio"    text="Precio"    prefWidth="100" />
                <TableColumn fx:id="colStock"     text="Stock"     prefWidth="80" />
                <TableColumn fx:id="colEstado"    text="Estado"    prefWidth="100" />
                <TableColumn fx:id="colAcciones"  text="Acciones"  prefWidth="150" />
            </columns>
        </TableView>
    </VBox>

</VBox>
