<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controlador.InventarioController"
      style="-fx-background-color: #F5EFE6;"
      VBox.vgrow="ALWAYS">

    <!-- TOPBAR -->
    <HBox alignment="CENTER_LEFT" styleClass="topbar">
        <VBox spacing="2">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #6B4226;"
                   text="Inventario" />
            <Label style="-fx-font-size: 11px; -fx-text-fill: #7A5535;"
                   text="Gestion de productos" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#abrirFormularioNuevo"
                style="-fx-background-color: #6B4226; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-weight: bold;"
                text="Nuevo producto">
            <graphic>
                <FontIcon iconColor="WHITE" iconLiteral="fas-plus" iconSize="13" />
            </graphic>
        </Button>
    </HBox>

    <!-- RESUMEN -->
    <HBox spacing="12" style="-fx-padding: 16 20 0 20;">
        <VBox spacing="4" styleClass="card" HBox.hgrow="ALWAYS">
            <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="TOTAL PRODUCTOS" />
            <Label fx:id="lblTotalProductos"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #6B4226;"
                   text="0" />
        </VBox>
        <VBox spacing="4" styleClass="card" HBox.hgrow="ALWAYS">
            <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="STOCK BAJO" />
            <Label fx:id="lblStockBajo"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #C0392B;"
                   text="0" />
        </VBox>
        <VBox spacing="4" styleClass="card" HBox.hgrow="ALWAYS">
            <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="VALOR TOTAL" />
            <Label fx:id="lblValorTotal"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3B6D11;"
                   text="0.00" />
        </VBox>
    </HBox>

    <!-- FILTROS -->
    <HBox spacing="10" style="-fx-padding: 14 20;">
        <TextField fx:id="txtBuscar"
                   promptText="Buscar por nombre o categoria..."
                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #D4B896; -fx-border-width: 1; -fx-padding: 8 12; -fx-font-size: 12px;"
                   prefWidth="280" />
        <ComboBox fx:id="cbCategoria" promptText="Categorias"
                  style="-fx-background-radius: 8;" prefWidth="150" />
        <ComboBox fx:id="cbEstado" promptText="Estados"
                  style="-fx-background-radius: 8;" prefWidth="130" />
        <Button onAction="#limpiarFiltros"
                style="-fx-background-color: transparent; -fx-text-fill: #7A5535; -fx-border-color: #D4B896; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 14; -fx-cursor: hand;"
                text="Limpiar" />
    </HBox>

    <!-- TABLA -->
    <VBox style="-fx-padding: 0 20 20 20;" VBox.vgrow="ALWAYS">
        <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS"
                   style="-fx-background-radius: 12; -fx-background-color: white;">
            <columns>
                <TableColumn fx:id="colId"        text="ID"        prefWidth="55" />
                <TableColumn fx:id="colNombre"    text="Nombre"    prefWidth="200" />
                <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="200" />
                <TableColumn fx:id="colPrecio"    text="Precio"    prefWidth="100" />
                <TableColumn fx:id="colStock"     text="Stock"     prefWidth="80" />
                <TableColumn fx:id="colEstado"    text="Estado"    prefWidth="100" />
                <TableColumn fx:id="colAcciones"  text="Acciones"  prefWidth="110" />
            </columns>
        </TableView>
    </VBox>

</VBox>
