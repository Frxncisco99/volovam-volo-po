<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="700" prefWidth="1100"
            xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controlador.InventarioController">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="230" style="-fx-background-color: #3D1F0D;">
            <!-- LOGO -->
            <VBox spacing="4" style="-fx-padding: 18 20 14 20;" alignment="CENTER_LEFT">
                <ImageView fitWidth="130" preserveRatio="true" pickOnBounds="true">

                </ImageView>
                <Label style="-fx-text-fill: #C8A97E; -fx-font-size: 10px;" text="Sistema de Punto de Venta"/>
            </VBox>
            <Separator style="-fx-opacity: 0.2;"/>
            <HBox spacing="12" style="-fx-padding: 16 20;">
                <Label fx:id="lblAvatarIniciales" style="-fx-background-color: #D4A843; -fx-text-fill: #864628; -fx-font-weight: bold; -fx-font-size: 14px; -fx-min-width: 38; -fx-min-height: 38; -fx-background-radius: 19; -fx-alignment: center;" text="AD"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" text="Usuario"/>
                    <Label fx:id="lblRolUsuario" style="-fx-text-fill: #C8A97E; -fx-font-size: 10px;" text="Rol"/>
                </VBox>
            </HBox>
            <Separator style="-fx-opacity: 0.2;"/>
            <VBox spacing="4" style="-fx-padding: 12;" VBox.vgrow="ALWAYS">
                <Label style="-fx-text-fill: #C8A97E; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 8 8 4 8;" text="PRINCIPAL"/>
                <Button graphicTextGap="12" onAction="#irADashboard" prefHeight="40" prefWidth="206"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;"
                        text="Dashboard">
                    <graphic><FontIcon iconLiteral="fas-tachometer-alt" iconSize="16" iconColor="#C8A97E"/></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irAVentas" prefHeight="40" prefWidth="206"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;"
                        text="Ventas / Caja">
                    <graphic><FontIcon iconLiteral="fas-shopping-cart" iconSize="16" iconColor="#C8A97E"/></graphic>
                </Button>
                <Button graphicTextGap="12" prefHeight="40" prefWidth="206"
                        style="-fx-background-color: #6B4226; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;"
                        text="Inventario">
                    <graphic><FontIcon iconLiteral="fas-box" iconSize="16" iconColor="white"/></graphic>
                </Button>
                <Label style="-fx-text-fill: #C8A97E; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 12 8 4 8;" text="GESTION"/>
                <Button onAction="#irAEmpleados" graphicTextGap="12" prefHeight="40" prefWidth="206"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;"
                        text="Empleados">
                    <graphic><FontIcon iconLiteral="fas-users" iconSize="16" iconColor="#C8A97E"/></graphic>
                </Button>
                <Button onAction="#irAReportes" graphicTextGap="12" prefHeight="40" prefWidth="206"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;"
                        text="Reportes">
                    <graphic><FontIcon iconColor="#C8A97E" iconLiteral="fas-chart-bar" iconSize="16" /></graphic>
                </Button>
                <Button onAction="#irACorteCaja" graphicTextGap="12" prefHeight="40" prefWidth="206"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;"
                        text="Corte de Caja">
                    <graphic><FontIcon iconColor="#C8A97E" iconLiteral="fas-cash-register" iconSize="16" /></graphic>
                </Button>
                <Button graphicTextGap="12" prefHeight="40" prefWidth="206"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;"
                        text="Configuracion">
                    <graphic><FontIcon iconLiteral="fas-cog" iconSize="16" iconColor="#C8A97E"/></graphic>
                </Button>
            </VBox>
            <Separator style="-fx-opacity: 0.2;"/>
            <Button graphicTextGap="10" onAction="#btnCerrar" prefHeight="44" prefWidth="230"
                    style="-fx-background-color: transparent; -fx-text-fill: #C0392B; -fx-cursor: hand;"
                    text="Cerrar sesion">
                <graphic><FontIcon iconLiteral="fas-sign-out-alt" iconSize="16" iconColor="#C0392B"/></graphic>
            </Button>
        </VBox>
    </left>

    <!-- CONTENIDO -->
    <center>
        <VBox xmlns="http://javafx.com/javafx/17"
              style="-fx-background-color: #EDEADE;"
              VBox.vgrow="ALWAYS">

            <HBox alignment="CENTER_LEFT" style="-fx-padding: 28 28 20 28; -fx-background-color: #EDEADE;">
                <VBox spacing="3">
                    <Label text="Inventario y Productos"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3D1A0A;" />
                    <Label text="Gestion de existencias"
                           style="-fx-font-size: 12px; -fx-text-fill: #8B4A5A;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Exportar" onAction="#exportarPDF"
                            style="-fx-background-color: #F5EFE6; -fx-text-fill: #6B1228; -fx-border-color: #C9A84C; -fx-border-width: 0.5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 18; -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold;" />
                    <Button text="+ Nuevo producto" onAction="#abrirFormularioNuevo"
                            style="-fx-background-color: #6B1228; -fx-text-fill: #F5EFE0; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 9 20; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 12px;" />
                </HBox>
            </HBox>

            <HBox spacing="14" style="-fx-padding: 0 28 24 28;">
                <HBox spacing="16" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #F5EFE6; -fx-background-radius: 12; -fx-border-color: #D4C9B0; -fx-border-width: 0.5; -fx-border-radius: 12; -fx-padding: 18 20;">
                    <VBox alignment="CENTER" style="-fx-background-color: #F0EAD0; -fx-background-radius: 10; -fx-min-width: 42; -fx-min-height: 42; -fx-max-width: 42; -fx-max-height: 42;">
                        <Label text="#" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #C9A84C;" />
                    </VBox>
                    <VBox spacing="4">
                        <Label text="TOTAL PRODUCTOS" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #8B4A5A;" />
                        <Label fx:id="lblTotalProductos" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #6B1228;" />
                    </VBox>
                </HBox>
                <HBox spacing="16" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #F5EFE6; -fx-background-radius: 12; -fx-border-color: #D4C9B0; -fx-border-width: 0.5; -fx-border-radius: 12; -fx-padding: 18 20;">
                    <VBox alignment="CENTER" style="-fx-background-color: #F7E0E0; -fx-background-radius: 10; -fx-min-width: 42; -fx-min-height: 42; -fx-max-width: 42; -fx-max-height: 42;">
                        <Label text="!" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #A32D2D;" />
                    </VBox>
                    <VBox spacing="4">
                        <Label text="STOCK BAJO" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #8B4A5A;" />
                        <Label fx:id="lblStockBajo" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #A32D2D;" />
                    </VBox>
                </HBox>
                <HBox spacing="16" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #F5EFE6; -fx-background-radius: 12; -fx-border-color: #D4C9B0; -fx-border-width: 0.5; -fx-border-radius: 12; -fx-padding: 18 20;">
                    <VBox alignment="CENTER" style="-fx-background-color: #F0EAD0; -fx-background-radius: 10; -fx-min-width: 42; -fx-min-height: 42; -fx-max-width: 42; -fx-max-height: 42;">
                        <Label text="\$\$" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #C9A84C;" />
                    </VBox>
                    <VBox spacing="4">
                        <Label text="VALOR TOTAL" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #8B4A5A;" />
                        <Label fx:id="lblValorTotal" text="0.00" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #C9A84C;" />
                    </VBox>
                </HBox>
            </HBox>

            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 28 16 28;">
                <TextField fx:id="txtBuscar" promptText="Buscar por nombre o categoria..."
                           prefWidth="320"
                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #C9A84C; -fx-border-width: 0.5; -fx-padding: 9 14; -fx-font-size: 12px; -fx-background-color: #F5EFE6;" />
                <ComboBox fx:id="cbCategoria" promptText="Categorias" prefWidth="160"
                          style="-fx-background-radius: 8; -fx-border-color: #C9A84C; -fx-border-width: 0.5; -fx-background-color: #F5EFE6; -fx-font-size: 12px;" />
                <ComboBox fx:id="cbEstado" promptText="Estado" prefWidth="140"
                          style="-fx-background-radius: 8; -fx-border-color: #C9A84C; -fx-border-width: 0.5; -fx-background-color: #F5EFE6; -fx-font-size: 12px;" />
                <Button text="Limpiar" onAction="#limpiarFiltros"
                        style="-fx-background-color: #F5EFE6; -fx-text-fill: #6B1228; -fx-border-color: #C9A84C; -fx-border-width: 0.5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 16; -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold;" />
            </HBox>

            <VBox style="-fx-padding: 0 28 28 28;" VBox.vgrow="ALWAYS">
                <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: #F5EFE6; -fx-border-color: #D4C9B0; -fx-border-width: 0.5; -fx-background-radius: 12; -fx-border-radius: 12;">
                    <columns>
                        <TableColumn fx:id="colId"        text="ID"        prefWidth="75" />
                        <TableColumn fx:id="colNombre"    text="NOMBRE"    prefWidth="190" />
                        <TableColumn fx:id="colCategoria" text="CATEGORIA" prefWidth="140" />
                        <TableColumn fx:id="colPrecio"    text="PRECIO"    prefWidth="100" />
                        <TableColumn fx:id="colStock"     text="STOCK"     prefWidth="80" />
                        <TableColumn fx:id="colEstado"    text="ESTADO"    prefWidth="130" />
                        <TableColumn fx:id="colAcciones"  text="ACCIONES"  prefWidth="255" />
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>

</BorderPane>
