<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane prefHeight="700" prefWidth="1100"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@menuPrincipal.css"
            fx:controller="org.example.controlador.InventarioController">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="230" style="-fx-background-color: #091e4e;">

            <VBox spacing="3" style="-fx-padding: 24 18 16 18;">
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Volovan Volo"/>
                <Label style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 9px;" text="SISTEMA DE PUNTO DE VENTA"/>
            </VBox>

            <Separator style="-fx-opacity: 0.15;"/>

            <HBox spacing="10" style="-fx-padding: 14 18;">
                <Label fx:id="lblAvatarIniciales"
                       style="-fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-min-width: 36; -fx-min-height: 36; -fx-background-radius: 18; -fx-alignment: center;"
                       text="AD"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Usuario"/>
                    <Label fx:id="lblRolUsuario" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 10px;" text="Rol"/>
                </VBox>
            </HBox>

            <Separator style="-fx-opacity: 0.15;"/>

            <VBox spacing="3" style="-fx-padding: 10 10;" VBox.vgrow="ALWAYS">

                <Label style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 8 8 3 8;" text="PRINCIPAL"/>

                <Button graphicTextGap="12" onAction="#irADashboard" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Dashboard">
                    <graphic><FontIcon iconLiteral="fas-tachometer-alt" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAVentas" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Ventas / Caja">
                    <graphic><FontIcon iconLiteral="fas-shopping-cart" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button graphicTextGap="12" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: white; -fx-text-fill: #1a6fa8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Inventario">
                    <graphic><FontIcon iconLiteral="fas-box" iconSize="16" iconColor="#1a6fa8"/></graphic>
                </Button>

                <Label style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 12 8 3 8;" text="GESTION"/>

                <Button onAction="#irAEmpleados" graphicTextGap="12" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Empleados">
                    <graphic><FontIcon iconLiteral="fas-users" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button prefHeight="40" prefWidth="210" onAction="#irAClientes"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Clientes" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button onAction="#irAReportes" graphicTextGap="12" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Reportes">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-chart-bar" iconSize="16"/></graphic>
                </Button>

                <Button onAction="#irACorteCaja" graphicTextGap="12" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Corte de Caja">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-cash-register" iconSize="16"/></graphic>
                </Button>

                <Button onAction="#irAConfiguracion" graphicTextGap="12" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Configuracion">
                    <graphic><FontIcon iconLiteral="fas-cog" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

            </VBox>

            <Separator style="-fx-opacity: 0.15;"/>

            <Button graphicTextGap="10" onAction="#btnCerrar" prefHeight="44" prefWidth="230"
                    style="-fx-background-color: transparent; -fx-text-fill: rgba(255,180,180,0.9); -fx-cursor: hand;"
                    text="Cerrar sesion">
                <graphic><FontIcon iconLiteral="fas-sign-out-alt" iconSize="16" iconColor="#ff0000e5"/></graphic>
            </Button>

        </VBox>
    </left>

    <!-- CONTENIDO -->
    <center>
        <VBox style="-fx-background-color: #f0f7ff;" VBox.vgrow="ALWAYS">

            <!-- TOPBAR -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 14 24; -fx-effect: dropshadow(gaussian, #1a6fa815, 8, 0, 0, 2);">
                <VBox spacing="2">
                    <Label style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Inventario"/>
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #6a96b8;" text="Gestion de productos y stock"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="lblHora" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;"/>
                    <Label style="-fx-background-color: #e0f5e9; -fx-text-fill: #1e7d3e; -fx-background-radius: 10; -fx-padding: 2 10; -fx-font-size: 10px;" text="Caja abierta"/>
                </VBox>
            </HBox>

            <!-- STAT CARDS -->
            <HBox spacing="10" style="-fx-padding: 18 18 14 18;">

                <VBox spacing="5" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="TOTAL PRODUCTOS"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <FontIcon iconColor="#1a6fa8" iconLiteral="fas-box" iconSize="14"/>
                    </HBox>
                    <Label fx:id="lblTotalProductos" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;"/>
                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="productos activos"/>
                </VBox>

                <VBox spacing="5" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #1a6fa8; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa840, 12, 0, 0, 2); -fx-padding: 18;">
                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 9px; -fx-font-weight: bold;" text="STOCK BAJO"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-exclamation-triangle" iconSize="14"/>
                    </HBox>
                    <Label fx:id="lblStockBajo" text="0" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 10px;" text="productos bajo minimo"/>
                </VBox>

                <VBox spacing="5" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="VALOR TOTAL"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <FontIcon iconColor="#1a6fa8" iconLiteral="fas-dollar-sign" iconSize="14"/>
                    </HBox>
                    <Label fx:id="lblValorTotal" text="\$0.00" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;"/>
                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="en inventario"/>
                </VBox>

            </HBox>

            <!-- FILTROS -->
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 18 16 18;">
                <TextField fx:id="txtBuscar" promptText="Buscar por nombre o categoria..."
                           prefWidth="320"
                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 9 14; -fx-font-size: 12px; -fx-background-color: white;"/>
                <ComboBox fx:id="cbCategoria" promptText="Categorias" prefWidth="160"
                          style="-fx-background-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-background-color: white; -fx-font-size: 12px;"/>
                <ComboBox fx:id="cbEstado" promptText="Estado" prefWidth="140"
                          style="-fx-background-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-background-color: white; -fx-font-size: 12px;"/>
                <Button text="Limpiar" onAction="#limpiarFiltros"
                        style="-fx-background-color: transparent; -fx-text-fill: #1a6fa8; -fx-border-color: #1a6fa8; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 16; -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Exportar" onAction="#exportarPDF"
                        style="-fx-background-color: transparent; -fx-text-fill: #1a6fa8; -fx-border-color: #1a6fa8; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 18; -fx-cursor: hand; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                <Button text="+ Nuevo producto" onAction="#abrirFormularioNuevo"
                        style="-fx-background-color: #1a6fa8; -fx-text-fill: white; -fx-background-radius: 8; -fx-border-radius: 8; -fx-padding: 9 20; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 12px;"/>
            </HBox>

            <!-- TABLA -->
            <VBox style="-fx-padding: 0 18 18 18;" VBox.vgrow="ALWAYS">
                <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-border-color: #1a6fa820; -fx-border-width: 1; -fx-background-radius: 12; -fx-border-radius: 12;">
                    <columns>
                        <TableColumn fx:id="colId"        text="ID"        prefWidth="75"/>
                        <TableColumn fx:id="colNombre"    text="NOMBRE"    prefWidth="190"/>
                        <TableColumn fx:id="colCategoria" text="CATEGORIA" prefWidth="140"/>
                        <TableColumn fx:id="colPrecio"    text="PRECIO"    prefWidth="100"/>
                        <TableColumn fx:id="colStock"     text="STOCK"     prefWidth="80"/>
                        <TableColumn fx:id="colEstado"    text="ESTADO"    prefWidth="130"/>
                        <TableColumn fx:id="colAcciones"  text="ACCIONES"  prefWidth="255"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </center>

</BorderPane>
