<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="0" alignment="CENTER"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controlador.AgregarProductoController"
      style="-fx-background-color: #f0f7ff;"
      prefHeight="590" prefWidth="380">

    <!-- ── HEADER ── -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #091e4e; -fx-padding: 18 24;">
        <FontIcon iconLiteral="fas-plus-circle" iconSize="18" iconColor="white"/>
        <VBox spacing="3">
            <Label text="Nuevo Producto"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Agregar al inventario · Volovan Volo"
                   style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.55);"/>
        </VBox>
    </HBox>

    <!-- ── FORMULARIO ── -->
    <VBox spacing="12" VBox.vgrow="ALWAYS"
          style="-fx-padding: 20 24 16 24; -fx-background-color: #f0f7ff;">

        <!-- Sección: Información general -->
        <Label text="INFORMACIÓN GENERAL"
               style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #6a96b8;
                      -fx-padding: 0 0 4 0; -fx-border-color: #c8dff0; -fx-border-width: 0 0 1 0;"/>

        <TextField fx:id="txtNombre" promptText="Nombre del producto"
                   style="-fx-background-color: white; -fx-border-color: #c8dff0;
                          -fx-border-radius: 7; -fx-background-radius: 7;
                          -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #0d3d5e;
                          -fx-prompt-text-fill: #9ab8d4;"/>

        <HBox spacing="10">
            <TextField fx:id="txtPrecio" promptText="Precio  ($)"
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-color: #c8dff0;
                              -fx-border-radius: 7; -fx-background-radius: 7;
                              -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #0d3d5e;
                              -fx-prompt-text-fill: #9ab8d4;"/>
            <TextField fx:id="txtCosto" promptText="Costo  ($)"
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-color: #c8dff0;
                              -fx-border-radius: 7; -fx-background-radius: 7;
                              -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #0d3d5e;
                              -fx-prompt-text-fill: #9ab8d4;"/>
        </HBox>

        <HBox spacing="10">
            <TextField fx:id="txtStock" promptText="Cantidad en stock"
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-color: #c8dff0;
                              -fx-border-radius: 7; -fx-background-radius: 7;
                              -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #0d3d5e;
                              -fx-prompt-text-fill: #9ab8d4;"/>
            <TextField fx:id="txtStockMinimo" promptText="Stock mínimo"
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-color: #c8dff0;
                              -fx-border-radius: 7; -fx-background-radius: 7;
                              -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #0d3d5e;
                              -fx-prompt-text-fill: #9ab8d4;"/>
        </HBox>

        <HBox spacing="8" alignment="CENTER_LEFT">
            <ComboBox fx:id="cbCategoria" promptText="Seleccionar categoría"
                      HBox.hgrow="ALWAYS" maxWidth="Infinity"
                      style="-fx-background-color: white; -fx-border-color: #c8dff0;
                             -fx-border-radius: 7; -fx-background-radius: 7;
                             -fx-font-size: 13px; -fx-padding: 2 4;"/>
            <Button text="+" onAction="#nuevaCategoria"
                    style="-fx-background-color: #1a6fa8; -fx-text-fill: white;
                           -fx-font-size: 16px; -fx-font-weight: bold;
                           -fx-background-radius: 7; -fx-min-width: 36; -fx-min-height: 34;
                           -fx-cursor: hand;"/>
        </HBox>

        <ComboBox fx:id="cbImpuesto" promptText="Impuesto del producto"
                  maxWidth="Infinity"
                  style="-fx-background-color: white; -fx-border-color: #c8dff0;
                         -fx-border-radius: 7; -fx-background-radius: 7;
                         -fx-font-size: 13px; -fx-padding: 2 4;"/>

        <!-- Sección: Código de barras -->
        <Label text="CÓDIGO DE BARRAS"
               style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #6a96b8;
                      -fx-padding: 4 0 4 0; -fx-border-color: #c8dff0; -fx-border-width: 0 0 1 0;"/>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="¿Lleva código de barras?"
                   style="-fx-font-size: 12px; -fx-text-fill: #0d3d5e;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnToggleCodigo" text="No lleva" onAction="#toggleCodigo"
                    style="-fx-background-color: #e8f0f8; -fx-text-fill: #6a96b8;
                           -fx-background-radius: 20; -fx-padding: 5 16;
                           -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>

        <HBox fx:id="hboxCodigo" spacing="8" alignment="CENTER_LEFT"
              visible="false" managed="false">
            <TextField fx:id="txtCodigoBarras" promptText="Escanea o escribe el código"
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-color: #1a6fa8;
                              -fx-border-radius: 7; -fx-background-radius: 7;
                              -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #0d3d5e;
                              -fx-prompt-text-fill: #9ab8d4;"/>
            <Button text="✕" onAction="#limpiarCodigo"
                    style="-fx-background-color: transparent; -fx-text-fill: #a83232;
                           -fx-font-size: 14px; -fx-cursor: hand; -fx-font-weight: bold;"/>
        </HBox>

    </VBox>

    <!-- ── FOOTER ── -->
    <HBox spacing="10" alignment="CENTER_RIGHT"
          style="-fx-padding: 14 24 20 24;
                 -fx-background-color: white;
                 -fx-border-color: #dde8f2; -fx-border-width: 1 0 0 0;">
        <Button text="Cancelar" onAction="#cancelar"
                style="-fx-background-color: transparent; -fx-border-color: #c8dff0;
                       -fx-border-radius: 7; -fx-background-radius: 7;
                       -fx-text-fill: #6a96b8; -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 8 18; -fx-cursor: hand;"/>
        <Button text="Agregar producto" onAction="#guardarProducto"
                style="-fx-background-color: #1a6fa8; -fx-text-fill: white;
                       -fx-background-radius: 7; -fx-border-radius: 7;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 8 20; -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, #1a6fa840, 8, 0, 0, 2);"/>
    </HBox>

</VBox>
