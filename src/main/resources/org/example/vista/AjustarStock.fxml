<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="0" alignment="CENTER"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controlador.AjustarStockController"
      style="-fx-background-color: #f0f7ff;"
      prefHeight="500" prefWidth="430"
      minHeight="500" minWidth="430"
      maxHeight="500" maxWidth="430">

    <fx:define>
        <ToggleGroup fx:id="grupoOperacion"/>
    </fx:define>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color: #091e4e; -fx-padding: 18 24;"
          minHeight="76" prefHeight="76" maxHeight="76">
        <FontIcon iconLiteral="fas-sliders-h" iconSize="18" iconColor="white"/>
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="Ajustar stock"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="lblNombreProducto" text="Producto"
                   style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.55);"/>
        </VBox>
    </HBox>

    <VBox spacing="14" VBox.vgrow="ALWAYS"
          style="-fx-padding: 18 24 16 24; -fx-background-color: #f0f7ff;">

        <VBox spacing="8"
              style="-fx-background-color: white; -fx-background-radius: 14;
                     -fx-border-color: #e8f0f8; -fx-border-width: 1; -fx-border-radius: 14;
                     -fx-effect: dropshadow(gaussian, #1a6fa818, 10, 0, 0, 2);
                     -fx-padding: 16;">
            <HBox alignment="CENTER_LEFT">
                <Label text="STOCK ACTUAL"
                       style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <StackPane style="-fx-background-color: #e8f3fb; -fx-background-radius: 8; -fx-padding: 6;">
                    <FontIcon iconLiteral="fas-box" iconSize="13" iconColor="#1a6fa8"/>
                </StackPane>
            </HBox>
            <Label fx:id="lblStockActual" text="0"
                   style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;"
                   minHeight="42" prefHeight="42" maxHeight="42"/>
            <Label text="Existencia registrada antes del ajuste"
                   style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;"/>
        </VBox>

        <VBox spacing="10">
            <Label text="OPERACION"
                   style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #6a96b8;
                          -fx-padding: 0 0 4 0; -fx-border-color: #c8dff0; -fx-border-width: 0 0 1 0;"/>
            <HBox spacing="10" alignment="CENTER">
                <ToggleButton fx:id="btnModoSumar" text="Sumar stock"
                              toggleGroup="$grupoOperacion" selected="true"
                              minWidth="181" prefWidth="181" maxWidth="181"
                              minHeight="38" prefHeight="38" maxHeight="38"
                              style="-fx-background-color: #1a6fa8; -fx-text-fill: white;
                                     -fx-background-radius: 8; -fx-border-radius: 8;
                                     -fx-font-size: 12px; -fx-font-weight: bold;
                                     -fx-cursor: hand; -fx-border-width: 1;
                                     -fx-border-color: #1a6fa8;">
                    <graphic><FontIcon iconLiteral="fas-plus" iconSize="12" iconColor="white"/></graphic>
                </ToggleButton>
                <ToggleButton fx:id="btnModoQuitar" text="Quitar stock"
                              toggleGroup="$grupoOperacion"
                              minWidth="181" prefWidth="181" maxWidth="181"
                              minHeight="38" prefHeight="38" maxHeight="38"
                              style="-fx-background-color: white; -fx-text-fill: #C0392B;
                                     -fx-background-radius: 8; -fx-border-radius: 8;
                                     -fx-font-size: 12px; -fx-font-weight: bold;
                                     -fx-cursor: hand; -fx-border-width: 1;
                                     -fx-border-color: #c8dff0;">
                    <graphic><FontIcon iconLiteral="fas-minus" iconSize="12" iconColor="#C0392B"/></graphic>
                </ToggleButton>
            </HBox>
        </VBox>

        <VBox spacing="10">
            <Label text="CANTIDAD"
                   style="-fx-font-size: 9px; -fx-font-weight: bold; -fx-text-fill: #6a96b8;
                          -fx-padding: 0 0 4 0; -fx-border-color: #c8dff0; -fx-border-width: 0 0 1 0;"/>
            <HBox spacing="10" alignment="CENTER">
                <Button text="-" onAction="#restar"
                        minWidth="44" prefWidth="44" maxWidth="44"
                        minHeight="44" prefHeight="44" maxHeight="44"
                        style="-fx-background-color: white; -fx-border-color: #c8dff0;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-text-fill: #1a6fa8; -fx-font-size: 20px;
                               -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0;"/>
                <TextField fx:id="txtCantidad" text="1" alignment="CENTER"
                           minWidth="112" prefWidth="112" maxWidth="112"
                           minHeight="44" prefHeight="44" maxHeight="44"
                           style="-fx-background-color: white; -fx-border-color: #c8dff0;
                                  -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 8 12; -fx-font-size: 20px;
                                  -fx-font-weight: bold; -fx-text-fill: #0d3d5e;
                                  -fx-alignment: center; -fx-prompt-text-fill: #9ab8d4;"/>
                <Button text="+" onAction="#sumar"
                        minWidth="44" prefWidth="44" maxWidth="44"
                        minHeight="44" prefHeight="44" maxHeight="44"
                        style="-fx-background-color: #1a6fa8; -fx-text-fill: white;
                               -fx-font-size: 20px; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-border-radius: 8;
                               -fx-cursor: hand; -fx-padding: 0;"/>
            </HBox>
        </VBox>

        <Label fx:id="lblPreview" text="Stock resultante: 1"
               alignment="CENTER" maxWidth="Infinity"
               minHeight="38" prefHeight="38" maxHeight="38"
               style="-fx-background-color: #e8f3fb; -fx-background-radius: 10;
                      -fx-text-fill: #1a6fa8; -fx-font-size: 12px;
                      -fx-font-weight: bold; -fx-padding: 0 12;"/>
    </VBox>

    <!-- FOOTER -->
    <HBox spacing="10" alignment="CENTER_RIGHT"
          style="-fx-padding: 14 24 20 24;
                 -fx-background-color: white;
                 -fx-border-color: #dde8f2; -fx-border-width: 1 0 0 0;"
          minHeight="72" prefHeight="72" maxHeight="72">
        <Button text="Cancelar" onAction="#cancelar"
                minWidth="110" prefWidth="110" maxWidth="110"
                minHeight="38" prefHeight="38" maxHeight="38"
                style="-fx-background-color: transparent; -fx-border-color: #c8dff0;
                       -fx-border-radius: 7; -fx-background-radius: 7;
                       -fx-text-fill: #6a96b8; -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 0 18; -fx-cursor: hand;"/>
        <Button fx:id="btnConfirmar" text="Sumar stock" onAction="#confirmar"
                minWidth="145" prefWidth="145" maxWidth="145"
                minHeight="38" prefHeight="38" maxHeight="38"
                style="-fx-background-color: #1a6fa8; -fx-text-fill: white;
                       -fx-background-radius: 7; -fx-border-radius: 7;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 0 20; -fx-cursor: hand;
                       -fx-effect: dropshadow(gaussian, #1a6fa840, 8, 0, 0, 2);">
            <graphic><FontIcon fx:id="iconConfirmar" iconLiteral="fas-plus" iconSize="12" iconColor="white"/></graphic>
        </Button>
    </HBox>
</VBox>
