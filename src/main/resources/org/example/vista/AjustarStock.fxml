<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" alignment="CENTER"
      xmlns="http://javafx.com/javafx/23"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controlador.AjustarStockController"
      style="-fx-background-color: #F5F0E8;"
      prefHeight="340" prefWidth="340">

    <!-- HEADER -->
    <VBox style="-fx-background-color: #2E7D50; -fx-padding: 20 24 16 24;" spacing="4">
        <Label text="Ajustar Stock"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" />
        <Label fx:id="lblNombreProducto" text="Producto"
               style="-fx-font-size: 12px; -fx-text-fill: #A8D5B8;" />
    </VBox>

    <!-- STOCK ACTUAL -->
    <VBox alignment="CENTER" spacing="4"
          style="-fx-background-color: #FDF8F0; -fx-padding: 22 24 10 24;">
        <Label text="STOCK ACTUAL"
               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #A07848;" />
        <Label fx:id="lblStockActual" text="0"
               style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: #3D1A0A;" />
    </VBox>

    <!-- CONTROLES -->
    <VBox spacing="14" style="-fx-padding: 10 24 14 24; -fx-background-color: #FDF8F0;">

        <Label text="CANTIDAD A AJUSTAR"
               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #A07848;" />

        <HBox spacing="10" alignment="CENTER">
            <Button fx:id="btnMenos" text="−" onAction="#restar"
                    style="-fx-background-color: #6B1228; -fx-text-fill: white;
                           -fx-font-size: 22px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-min-width: 48; -fx-min-height: 48;
                           -fx-cursor: hand;" />
            <TextField fx:id="txtCantidad" text="1" alignment="CENTER"
                       prefWidth="100"
                       style="-fx-background-color: white; -fx-border-color: #D4B896;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 10 12; -fx-font-size: 20px;
                              -fx-font-weight: bold; -fx-text-fill: #3A1F06;
                              -fx-alignment: center;" />
            <Button fx:id="btnMas" text="+" onAction="#sumar"
                    style="-fx-background-color: #2E7D50; -fx-text-fill: white;
                           -fx-font-size: 22px; -fx-font-weight: bold;
                           -fx-background-radius: 8; -fx-min-width: 48; -fx-min-height: 48;
                           -fx-cursor: hand;" />
        </HBox>

        <Label fx:id="lblPreview" text="Stock resultante: 1"
               style="-fx-font-size: 12px; -fx-text-fill: #5A8A6A;
                      -fx-alignment: center; -fx-font-weight: bold;"
               alignment="CENTER" maxWidth="Infinity" />
    </VBox>

    <!-- FOOTER -->
    <HBox spacing="10" style="-fx-padding: 14 24 20 24;
                               -fx-background-color: #FAF4EA;
                               -fx-border-color: #E8D8C4; -fx-border-width: 1 0 0 0;"
          alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#cancelar"
                style="-fx-background-color: transparent; -fx-border-color: #C4A070;
                       -fx-border-radius: 7; -fx-background-radius: 7;
                       -fx-text-fill: #7A4E28; -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 8 18; -fx-cursor: hand;" />
        <Button text="Restar stock" onAction="#confirmarRestar"
                style="-fx-background-color: #6B1228; -fx-text-fill: white;
                       -fx-background-radius: 7; -fx-border-radius: 7;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 8 18; -fx-cursor: hand;" />
        <Button text="Añadir stock" onAction="#confirmarAnadir"
                style="-fx-background-color: #2E7D50; -fx-text-fill: white;
                       -fx-background-radius: 7; -fx-border-radius: 7;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 8 18; -fx-cursor: hand;" />
    </HBox>

</VBox>
