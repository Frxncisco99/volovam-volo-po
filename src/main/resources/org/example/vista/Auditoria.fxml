<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@menuPrincipal.css"
            fx:controller="org.example.controlador.AuditoriaController">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="230" style="-fx-background-color: #091e4e;">
            <VBox spacing="3" style="-fx-padding: 24 18 16 18;">
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Volovan Volo"/>
                <Label style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 9px;" text="SISTEMA DE PUNTO DE VENTA"/>
            </VBox>
            <Separator style="-fx-opacity: 0.15;"/>
            <HBox spacing="10" style="-fx-padding: 14 18;">
                <Label fx:id="lblAvatarIniciales"
                       style="-fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-min-width: 36; -fx-min-height: 36; -fx-background-radius: 18; -fx-alignment: center;"
                       text="AD"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Usuario"/>
                    <Label fx:id="lblRolUsuario" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 10px;" text="Rol"/>
                </VBox>
            </HBox>
            <Separator style="-fx-opacity: 0.15;"/>
            <VBox spacing="3" style="-fx-padding: 10 10;" VBox.vgrow="ALWAYS">
                <Label style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 8 8 3 8;" text="PRINCIPAL"/>
                <Button prefHeight="40" prefWidth="210" onAction="#irADashboard"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;" text="Dashboard" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-tachometer-alt" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAVentas"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;" text="Ventas / Caja" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-shopping-cart" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAInventario"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;" text="Inventario" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-box" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Label style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 12 8 3 8;" text="GESTION"/>
                <Button prefHeight="40" prefWidth="210" onAction="#irAEmpleados"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;" text="Empleados" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-users" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAClientes"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;" text="Clientes" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAReportes"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;" text="Reportes" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-chart-bar" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irACorteCaja"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;" text="Corte de Caja" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-cash-register" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <!-- Activo -->
                <Button prefHeight="40" prefWidth="210"
                        style="-fx-background-color: white; -fx-text-fill: #1a6fa8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;" text="Auditoría" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-shield-alt" iconSize="16" iconColor="#1a6fa8"/></graphic>
                </Button>

                <Button prefHeight="40" prefWidth="210" onAction="#irAConfiguracion"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;" text="Configuracion" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-cog" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
            </VBox>
            <Separator style="-fx-opacity: 0.15;"/>
            <Button onAction="#btnCerrar" prefHeight="44" prefWidth="230" text="Cambiar sesion" graphicTextGap="10"
                    style="-fx-background-color: transparent; -fx-text-fill: #fecaca; -fx-cursor: hand;">
                <graphic><FontIcon iconLiteral="fas-exchange-alt" iconSize="16" iconColor="#f87171"/></graphic>
            </Button>
        </VBox>
    </left>

    <!-- CENTRO -->
    <center>
        <VBox style="-fx-background-color: #f0f7ff;">

            <!-- TOPBAR -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 14 24; -fx-effect: dropshadow(gaussian, #1a6fa815, 8, 0, 0, 2);">
                <VBox spacing="2">
                    <Label style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Auditoría del Sistema"/>
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #6a96b8;" text="Registro completo de acciones y accesos"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblAcceso"
                       style="-fx-background-color: #e0f5e9; -fx-text-fill: #1e7d3e; -fx-background-radius: 10; -fx-padding: 4 12; -fx-font-size: 11px;"
                       text="Solo Administrador"/>
            </HBox>

            <!-- STATS CARDS -->
            <HBox spacing="12" style="-fx-padding: 16 20 0 20;">
                <VBox spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="TOTAL ACCIONES HOY"/>
                    <Label fx:id="lblTotalAcciones" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="0"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="INICIOS DE SESION HOY"/>
                    <Label fx:id="lblLogins" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e7d3e;" text="0"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="CANCELACIONES HOY"/>
                    <Label fx:id="lblCancelaciones" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #C0392B;" text="0"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="AJUSTES DE STOCK HOY"/>
                    <Label fx:id="lblAjustes" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #e88c1a;" text="0"/>
                </VBox>
            </HBox>

            <!-- FILTROS -->
            <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 14 20 10 20;">
                <DatePicker fx:id="dateInicio"
                            style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #b8d4ea; -fx-border-width: 1;"/>
                <DatePicker fx:id="dateFin"
                            style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #b8d4ea; -fx-border-width: 1;"/>
                <TextField fx:id="txtFiltroUsuario" promptText="Filtrar por usuario..."
                           prefWidth="160"
                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #b8d4ea; -fx-border-width: 1; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                <ComboBox fx:id="cmbFiltroAccion" promptText="Todas las acciones" prefWidth="180"
                          style="-fx-background-radius: 8; -fx-border-color: #b8d4ea; -fx-border-width: 1; -fx-background-color: white;"/>
                <Button onAction="#buscar"
                        style="-fx-background-color: #1a6fa8; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 9 20; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 12px;"
                        text="Buscar"/>
                <Button onAction="#limpiar"
                        style="-fx-background-color: transparent; -fx-text-fill: #1a6fa8; -fx-border-color: #1a6fa8; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 16; -fx-cursor: hand; -fx-font-size: 12px;"
                        text="Limpiar"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblConteo" style="-fx-text-fill: #6a96b8; -fx-font-size: 11px;" text=""/>
            </HBox>

            <!-- TABLA -->
            <VBox style="-fx-padding: 0 20 20 20;" VBox.vgrow="ALWAYS">
                <TableView fx:id="tablaAuditoria" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #1a6fa820; -fx-border-width: 1; -fx-border-radius: 12;">
                    <columns>
                        <TableColumn fx:id="colFecha"    text="Fecha y Hora"  prefWidth="155"/>
                        <TableColumn fx:id="colUsuario"  text="Usuario"        prefWidth="130"/>
                        <TableColumn fx:id="colAccion"   text="Acción"         prefWidth="120"/>
                        <TableColumn fx:id="colTabla"    text="Módulo"         prefWidth="100"/>
                        <TableColumn fx:id="colDetalle"  text="Detalle"        prefWidth="500"/>
                    </columns>
                    <placeholder>
                        <Label style="-fx-text-fill: #6a96b8;" text="Selecciona un rango de fechas y presiona Buscar"/>
                    </placeholder>
                </TableView>
            </VBox>

        </VBox>
    </center>

</BorderPane>