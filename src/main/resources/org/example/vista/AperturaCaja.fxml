<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.controlador.AperturaCajaController"
           stylesheets="@apertura-caja.css">

    <VBox alignment="CENTER"
          maxWidth="420"
          spacing="26"
          styleClass="apertura-card"
          StackPane.alignment="CENTER">

        <VBox alignment="CENTER" spacing="6">
            <Label styleClass="apertura-title" text="Apertura de Caja" />
            <HBox alignment="CENTER" spacing="8">
                <Label fx:id="lblUsuario" styleClass="apertura-meta" />
                <Label styleClass="apertura-dot" text="•" />
                <Label fx:id="lblFecha" styleClass="apertura-meta" />
            </HBox>
        </VBox>

        <Region prefHeight="1" prefWidth="340" styleClass="apertura-separator" />

        <VBox spacing="8">
            <Label styleClass="apertura-label" text="Monto inicial en caja" />
            <HBox alignment="CENTER_LEFT" spacing="0" styleClass="money-field">
                <Label styleClass="money-prefix" text="\$" />
                <TextField fx:id="txtMontoInicial"
                           promptText="0.00"
                           styleClass="money-input"
                           HBox.hgrow="ALWAYS" />
                <Label styleClass="money-suffix" text="MXN" />
            </HBox>
        </VBox>

        <VBox spacing="8">
            <Label styleClass="apertura-label" text="Tipo de cambio del dólar" />
            <HBox alignment="CENTER_LEFT" spacing="0" styleClass="money-field">
                <Label styleClass="money-prefix" text="\$" />
                <TextField fx:id="txtTipoCambio"
                           promptText="17.50"
                           styleClass="money-input"
                           HBox.hgrow="ALWAYS" />
                <Label styleClass="money-suffix" text="MXN / USD" />
            </HBox>

            <HBox fx:id="boxEjemplo" alignment="CENTER" spacing="6" styleClass="apertura-example">
                <Label styleClass="apertura-example-icon" text="↔" />
                <Label fx:id="lblEjemplo"
                       styleClass="apertura-example-text"
                       text="Ingresa el tipo de cambio" />
            </HBox>
        </VBox>

        <Button onAction="#handleAbrirCaja"
                prefHeight="50"
                prefWidth="340"
                styleClass="apertura-primary"
                text="Abrir Caja" />
    </VBox>
</StackPane>
