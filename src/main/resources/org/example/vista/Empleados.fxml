<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@menuPrincipal.css"
            styleClass="empleados-root"
            fx:controller="org.example.controlador.EmpleadosController">

    <!--SIDEBAR-->
    <left>
        <VBox prefWidth="230" styleClass="empleados-sidebar">

            <VBox spacing="3" styleClass="empleados-brand-block">
                <Label styleClass="empleados-brand-title" text="Volovan Volo"/>
                <Label styleClass="empleados-brand-subtitle" text="SISTEMA DE PUNTO DE VENTA"/>
            </VBox>

            <Separator styleClass="empleados-divider"/>

            <HBox spacing="10" styleClass="empleados-profile-row">
                <Label fx:id="lblAvatarIniciales" styleClass="empleados-sidebar-avatar" text="AD"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" styleClass="empleados-profile-name" text="Usuario"/>
                    <Label fx:id="lblRolUsuario" styleClass="empleados-profile-role" text="Rol"/>
                </VBox>
            </HBox>

            <Separator styleClass="empleados-divider"/>

            <VBox spacing="3" styleClass="empleados-nav-container" VBox.vgrow="ALWAYS">

                <Label styleClass="empleados-nav-heading" text="PRINCIPAL"/>

                <Button prefHeight="40" prefWidth="210" onAction="#irADashboard"
                        styleClass="empleados-nav-button"
                        text="Dashboard" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-tachometer-alt" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button prefHeight="40" prefWidth="210" onAction="#irAVentas"
                        styleClass="empleados-nav-button"
                        text="Ventas / Caja" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-shopping-cart" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAInventario" prefHeight="40" prefWidth="210"
                        styleClass="empleados-nav-button"
                        text="Inventario">
                    <graphic><FontIcon iconLiteral="fas-box" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Label styleClass="empleados-nav-heading" text="GESTIÓN"/>

                <Button graphicTextGap="12" prefHeight="40" prefWidth="210"
                        styleClass="empleados-nav-button-active"
                        text="Empleados">
                    <graphic><FontIcon iconColor="#1a6fa8" iconLiteral="fas-users" iconSize="16"/></graphic>
                </Button>

                <Button prefHeight="40" prefWidth="210" onAction="#irAClientes"
                        styleClass="empleados-nav-button"
                        text="Clientes" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button onAction="#irAReportes" graphicTextGap="12" prefHeight="40" prefWidth="210"
                        styleClass="empleados-nav-button"
                        text="Reportes">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-chart-bar" iconSize="16"/></graphic>
                </Button>

                <Button onAction="#irACorteCaja" graphicTextGap="12" prefHeight="40" prefWidth="210"
                        styleClass="empleados-nav-button"
                        text="Corte de Caja">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-cash-register" iconSize="16"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAAuditoria"
                        styleClass="empleados-nav-button"
                        text="Auditoría" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-shield-alt" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button onAction="#irAConfiguracion" prefHeight="40" prefWidth="210"
                        styleClass="empleados-nav-button"
                        text="Configuración" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-cog" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

            </VBox>

            <Separator styleClass="empleados-divider"/>

            <Button onAction="#btnCerrar" prefHeight="44" prefWidth="230" text="Cambiar sesión" graphicTextGap="10"
                    styleClass="empleados-session-button">
                <graphic><FontIcon iconLiteral="fas-exchange-alt" iconSize="16" iconColor="#22c55e"/></graphic>
            </Button>
            <Button onAction="#salirAplicacion" prefHeight="44" prefWidth="230" text="Salir del sistema" graphicTextGap="10"
                    styleClass="sidebar-exit-button">
                <graphic><FontIcon iconLiteral="fas-power-off" iconSize="16" iconColor="#22c55e"/></graphic>
            </Button>

        </VBox>
    </left>

    <!--CENTRO-->
    <center>
        <VBox styleClass="empleados-page">

            <!-- TOPBAR -->
            <HBox alignment="CENTER_LEFT" styleClass="empleados-topbar">
                <VBox spacing="2">
                    <Label styleClass="empleados-title" text="Empleados"/>
                    <Label styleClass="empleados-subtitle" text="Gestión de usuarios"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#handleNuevoEmpleado"
                        styleClass="empleados-primary-button"
                        text="Nuevo empleado" graphicTextGap="8">
                    <graphic><FontIcon iconLiteral="fas-user-plus" iconSize="14" iconColor="white"/></graphic>
                </Button>
            </HBox>

            <!-- STATS BAR -->
            <HBox spacing="14" styleClass="empleados-stats-row">

                <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      styleClass="empleados-stat-card">
                    <Label styleClass="empleados-stat-icon-blue">
                        <graphic><FontIcon iconLiteral="fas-users" iconSize="16" iconColor="#1a6fa8"/></graphic>
                    </Label>
                    <VBox spacing="2">
                        <Label styleClass="empleados-stat-label" text="TOTAL"/>
                        <Label fx:id="lblStatTotal" styleClass="empleados-stat-value-main" text="0"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      styleClass="empleados-stat-card">
                    <Label styleClass="empleados-stat-icon-green">
                        <graphic><FontIcon iconLiteral="fas-check-circle" iconSize="16" iconColor="#2e7d32"/></graphic>
                    </Label>
                    <VBox spacing="2">
                        <Label styleClass="empleados-stat-label" text="ACTIVOS"/>
                        <Label fx:id="lblStatActivos" styleClass="empleados-stat-value-green" text="0"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      styleClass="empleados-stat-card">
                    <Label styleClass="empleados-stat-icon-orange">
                        <graphic><FontIcon iconLiteral="fas-pause-circle" iconSize="16" iconColor="#e65100"/></graphic>
                    </Label>
                    <VBox spacing="2">
                        <Label styleClass="empleados-stat-label" text="INACTIVOS"/>
                        <Label fx:id="lblStatInactivos" styleClass="empleados-stat-value-orange" text="0"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                      styleClass="empleados-stat-card">
                    <Label styleClass="empleados-stat-icon-blue">
                        <graphic><FontIcon iconLiteral="fas-key" iconSize="16" iconColor="#1a6fa8"/></graphic>
                    </Label>
                    <VBox spacing="2">
                        <Label styleClass="empleados-stat-label" text="ROLES"/>
                        <Label fx:id="lblStatRoles" styleClass="empleados-stat-value-blue" text="0"/>
                    </VBox>
                </HBox>

            </HBox>

            <!-- FILTROS -->
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="empleados-filters">
                <TextField fx:id="txtBuscar" promptText="Buscar por nombre o usuario..." prefWidth="240"
                           styleClass="empleados-search-field"/>
                <ComboBox fx:id="cmbFiltroRol" promptText="Todos los roles" prefWidth="150"
                          styleClass="empleados-filter-combo"/>
                <ComboBox fx:id="cmbFiltroEstado" promptText="Todos los estados" prefWidth="150"
                          styleClass="empleados-filter-combo"/>
                <Button onAction="#limpiarFiltros"
                        styleClass="empleados-outline-button"
                        text="Limpiar"/>
                <Label fx:id="lblConteo" styleClass="empleados-count" text=""/>
            </HBox>

            <!-- TARJETAS -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        styleClass="empleados-scroll">
                <FlowPane fx:id="flowTarjetas" hgap="16" vgap="16"
                          styleClass="empleados-flow"/>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>
