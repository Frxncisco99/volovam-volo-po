<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.example.modelo.*?>
<?import org.kordamp.ikonli.javafx.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@menuPrincipal.css, @configuracion.css"
            fx:controller="org.example.controlador.ConfiguracionController">

    <!-- ═══════════════ SIDEBAR ═══════════════ -->
    <left>
        <VBox prefWidth="230" style="-fx-background-color: #091e4e;">

            <!-- Marca -->
            <VBox spacing="3" style="-fx-padding: 24 18 16 18;">
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Volovan Volo"/>
                <Label style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 9px;" text="SISTEMA DE PUNTO DE VENTA"/>
            </VBox>

            <Separator style="-fx-opacity: 0.15;"/>

            <!-- Usuario -->
            <HBox spacing="10" style="-fx-padding: 14 18;">
                <Label fx:id="lblAvatarIniciales"
                       style="-fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-min-width: 36; -fx-min-height: 36; -fx-background-radius: 18; -fx-alignment: center;"
                       text="AD"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Usuario"/>
                    <Label fx:id="lblRolUsuario" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 10px;" text="Rol"/>
                </VBox>
            </HBox>

            <Separator style="-fx-opacity: 0.15;"/>

            <!-- Navegación -->
            <VBox spacing="3" style="-fx-padding: 10 10;" VBox.vgrow="ALWAYS">

                <Label style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 8 8 3 8;" text="PRINCIPAL"/>

                <Button graphicTextGap="12" onAction="#irADashboard" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand; -fx-background-insets: 0;"
                        text="Dashboard">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-tachometer-alt" iconSize="16"/></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAVentas" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand; -fx-background-insets: 0;"
                        text="Ventas / Caja">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-shopping-cart" iconSize="16"/></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAInventario" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand; -fx-background-insets: 0;"
                        text="Inventario">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-box" iconSize="16"/></graphic>
                </Button>

                <Label style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 12 8 3 8;" text="GESTIÓN"/>

                <Button graphicTextGap="12" onAction="#irAEmpleados" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand; -fx-background-insets: 0;"
                        text="Empleados">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-users" iconSize="16"/></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAClientes" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand; -fx-background-insets: 0;"
                        text="Clientes">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-user-friends" iconSize="16"/></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAReportes" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand; -fx-background-insets: 0;"
                        text="Reportes">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-chart-bar" iconSize="16"/></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irACorteCaja" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand; -fx-background-insets: 0;"
                        text="Corte de Caja">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-cash-register" iconSize="16"/></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAAuditoria" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand; -fx-background-insets: 0;"
                        text="Auditoría">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-shield-alt" iconSize="16"/></graphic>
                </Button>

                <!-- ACTIVO -->
                <Button graphicTextGap="12" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: white; -fx-text-fill: #1a6fa8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand; -fx-background-insets: 0;"
                        text="Configuracion">
                    <graphic><FontIcon iconColor="#1a6fa8" iconLiteral="fas-cog" iconSize="16"/></graphic>
                </Button>

            </VBox>

            <Separator style="-fx-opacity: 0.15;"/>

            <Button graphicTextGap="10" onAction="#btnCerrar" prefHeight="44" prefWidth="230"
                    style="-fx-background-color: transparent; -fx-text-fill: rgba(255,180,180,0.9); -fx-cursor: hand; -fx-background-insets: 0;"
                    text="Cerrar sesion">
                <graphic><FontIcon iconColor="#ff0000e5" iconLiteral="fas-sign-out-alt" iconSize="16"/></graphic>
            </Button>

        </VBox>
    </left>

    <!-- ═══════════════ CONTENIDO PRINCIPAL ═══════════════ -->
    <center>
        <VBox prefWidth="960" style="-fx-background-color: #f0f7ff;">

            <!-- ── TOPBAR ────────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: white; -fx-padding: 16 24;
                         -fx-border-color: transparent transparent #e8eef5 transparent;
                         -fx-border-width: 0 0 1 0;
                         -fx-effect: dropshadow(gaussian, rgba(13,61,94,0.06), 8, 0, 0, 2);">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Configuracion"/>
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #6a96b8;" text="Administra los parametros generales del sistema"/>
                </VBox>
                <!-- Botón Restablecer -->
                <Button onAction="#restablecerConfiguracion"
                        prefHeight="36" prefWidth="120"
                        style="-fx-background-color: white; -fx-text-fill: #1a6fa8;
                               -fx-border-color: #c8dcea; -fx-border-width: 1;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-padding: 0 20; -fx-cursor: hand; -fx-font-size: 12px;
                               -fx-background-insets: 0;"
                        text="Restablecer"/>
                <!-- Botón Guardar -->
                <Button onAction="#guardarConfiguracion"
                        prefHeight="36" prefWidth="148"
                        style="-fx-background-color: #1a6fa8; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 8;
                               -fx-border-radius: 8; -fx-border-color: transparent;
                               -fx-border-width: 1; -fx-padding: 0 20; -fx-cursor: hand;
                               -fx-font-size: 12px; -fx-background-insets: 0;"
                        text="Guardar Cambios"/>
            </HBox>

            <!-- ── BARRA DE PESTAÑAS ─────────────────────── -->
            <HBox styleClass="cfg-tab-bar">
                <Button fx:id="btnTabNegocio"       onAction="#tabNegocio"       styleClass="cfg-tab-active" text="Negocio"/>
                <Button fx:id="btnTabPOS"           onAction="#tabPOS"           styleClass="cfg-tab"        text="POS / Caja"/>
                <Button fx:id="btnTabUsuarios"      onAction="#tabUsuarios"      styleClass="cfg-tab"        text="Usuarios y Roles"/>
                <Button fx:id="btnTabFiscal"        onAction="#tabFiscal"        styleClass="cfg-tab"        text="Fiscal / Tickets"/>
                <Button fx:id="btnTabIntegraciones" onAction="#tabIntegraciones" styleClass="cfg-tab"        text="Integraciones"/>
                <Button fx:id="btnTabBaseDatos"     onAction="#tabBaseDatos"     styleClass="cfg-tab"        text="Base de Datos"/>
            </HBox>

            <!-- ── SCROLL AREA ──────────────────────────── -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox style="-fx-padding: 20 24 28 24; -fx-spacing: 18;">

                    <!-- ╔══════════════════════════════════════╗
                         ║  PANEL NEGOCIO                       ║
                         ╚══════════════════════════════════════╝ -->
                    <VBox fx:id="panelNegocio" spacing="16">
                        <HBox spacing="16">

                            <!-- Info General -->
                            <VBox spacing="0" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 14;
                                         -fx-border-color: transparent; -fx-padding: 20;
                                         -fx-effect: dropshadow(gaussian, rgba(13,61,94,0.07), 12, 0, 0, 2);">
                                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 14 0;">
                                    <FontIcon iconLiteral="fas-store" iconSize="15" iconColor="#1a6fa8"/>
                                    <VBox spacing="2">
                                        <Label styleClass="cfg-card-title" text="Informacion General"/>
                                        <Label styleClass="cfg-card-subtitle" text="Datos principales del negocio"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <VBox spacing="4" style="-fx-padding: 14 0 0 0;">
                                    <Label styleClass="cfg-label-key" text="NOMBRE DEL NEGOCIO"/>
                                    <TextField fx:id="txtNombreNegocio" promptText="Ej. Volovan Volo"/>
                                    <Label styleClass="cfg-label-key" text="SLOGAN / DESCRIPCION CORTA"/>
                                    <TextField fx:id="txtSlogan" promptText="Ej. El sabor de casa"/>
                                    <Label styleClass="cfg-label-key" text="TELEFONO"/>
                                    <TextField fx:id="txtTelefono" promptText="878-123-4567"/>
                                    <Label styleClass="cfg-label-key" text="CORREO ELECTRONICO"/>
                                    <TextField fx:id="txtCorreo" promptText="admin@negocio.mx"/>
                                    <Label styleClass="cfg-label-key" text="SITIO WEB"/>
                                    <TextField fx:id="txtSitioWeb" promptText="www.negocio.mx"/>
                                </VBox>
                            </VBox>

                            <!-- Configuracion Regional -->
                            <VBox spacing="0" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 14;
                                         -fx-border-color: transparent; -fx-padding: 20;
                                         -fx-effect: dropshadow(gaussian, rgba(13,61,94,0.07), 12, 0, 0, 2);">
                                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 14 0;">
                                    <FontIcon iconLiteral="fas-map-marker-alt" iconSize="15" iconColor="#1a6fa8"/>
                                    <VBox spacing="2">
                                        <Label styleClass="cfg-card-title" text="Configuracion Regional"/>
                                        <Label styleClass="cfg-card-subtitle" text="Ubicacion, moneda y zona horaria"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <VBox spacing="4" style="-fx-padding: 14 0 0 0;">
                                    <Label styleClass="cfg-label-key" text="DIRECCION"/>
                                    <TextField fx:id="txtDireccion" promptText="Calle, Num, Colonia"/>
                                    <HBox spacing="10">
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label styleClass="cfg-label-key" text="CIUDAD"/>
                                            <TextField fx:id="txtCiudad" promptText="Ej. Piedras Negras"/>
                                        </VBox>
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label styleClass="cfg-label-key" text="C.P."/>
                                            <TextField fx:id="txtCP" promptText="26000"/>
                                        </VBox>
                                    </HBox>
                                    <Label styleClass="cfg-label-key" text="RFC"/>
                                    <TextField fx:id="txtRFC" promptText="XAXX010101000"/>
                                    <Label styleClass="cfg-label-key" text="MONEDA"/>
                                    <ComboBox fx:id="cmbMoneda" maxWidth="Infinity"/>
                                    <Label styleClass="cfg-label-key" text="ZONA HORARIA"/>
                                    <ComboBox fx:id="cmbZonaHoraria" maxWidth="Infinity"/>
                                </VBox>
                            </VBox>

                            <!-- Horario y Operacion -->
                            <VBox spacing="0" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 14;
                                         -fx-border-color: transparent; -fx-padding: 20;
                                         -fx-effect: dropshadow(gaussian, rgba(13,61,94,0.07), 12, 0, 0, 2);">
                                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 14 0;">
                                    <FontIcon iconLiteral="fas-clock" iconSize="15" iconColor="#1a6fa8"/>
                                    <VBox spacing="2">
                                        <Label styleClass="cfg-card-title" text="Horario y Operacion"/>
                                        <Label styleClass="cfg-card-subtitle" text="Dias y horas de atencion"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <VBox spacing="4" style="-fx-padding: 14 0 0 0;">
                                    <HBox spacing="10">
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label styleClass="cfg-label-key" text="HORA DE APERTURA"/>
                                            <TextField fx:id="txtHoraApertura" promptText="08:00"/>
                                        </VBox>
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label styleClass="cfg-label-key" text="HORA DE CIERRE"/>
                                            <TextField fx:id="txtHoraCierre" promptText="21:00"/>
                                        </VBox>
                                    </HBox>
                                    <Label styleClass="cfg-label-key" text="DIAS DE OPERACION"/>
                                    <HBox spacing="5" style="-fx-padding: 2 0 4 0;">
                                        <ToggleButton fx:id="tglLun" text="L"  selected="true"/>
                                        <ToggleButton fx:id="tglMar" text="M"  selected="true"/>
                                        <ToggleButton fx:id="tglMie" text="Mi" selected="true"/>
                                        <ToggleButton fx:id="tglJue" text="J"  selected="true"/>
                                        <ToggleButton fx:id="tglVie" text="V"  selected="true"/>
                                        <ToggleButton fx:id="tglSab" text="S"  selected="true"/>
                                        <ToggleButton fx:id="tglDom" text="D"/>
                                    </HBox>
                                    <Separator style="-fx-padding: 4 0;"/>
                                    <Label styleClass="cfg-label-key" text="LIMITE DE CREDITO INTERNO"/>
                                    <TextField fx:id="txtLimiteCredito" promptText="Ej. 500.00"/>
                                    <Label styleClass="cfg-label-key" text="NUMERO DE SUCURSAL / CAJA"/>
                                    <TextField fx:id="txtNumSucursal" promptText="Ej. 01 - Centro"/>

                                    <!-- Toggle mantenimiento -->
                                    <HBox alignment="CENTER_LEFT" spacing="12"
                                          style="-fx-background-color: #f5f9ff; -fx-padding: 10 14;
                                                 -fx-background-radius: 10; -fx-min-height: 52;
                                                 -fx-max-height: 52;">
                                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 12px;" text="Modo mantenimiento"/>
                                            <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="Bloquea acceso a cajeros"/>
                                        </VBox>
                                        <ToggleButton fx:id="tglMantenimiento"
                                                      style="-fx-background-color: #b0c4d8; -fx-background-radius: 12;
                                                             -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;
                                                             -fx-border-color: transparent; -fx-border-width: 1;
                                                             -fx-background-insets: 0;" text=""/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- ╔══════════════════════════════════════╗
                         ║  PANEL POS / CAJA                    ║
                         ╚══════════════════════════════════════╝ -->
                    <VBox fx:id="panelPOS" spacing="16" visible="false" managed="false">
                        <HBox spacing="16">

                            <!-- Operacion de Caja -->
                            <VBox spacing="0" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 14;
                                         -fx-padding: 20;
                                         -fx-effect: dropshadow(gaussian, rgba(13,61,94,0.07), 12, 0, 0, 2);">
                                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 14 0;">
                                    <FontIcon iconLiteral="fas-cash-register" iconSize="15" iconColor="#1a6fa8"/>
                                    <VBox spacing="2">
                                        <Label styleClass="cfg-card-title" text="Operacion de Caja"/>
                                        <Label styleClass="cfg-card-subtitle" text="Comportamiento del punto de venta"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <VBox spacing="4" style="-fx-padding: 14 0 0 0;">
                                    <Label styleClass="cfg-label-key" text="METODO DE PAGO PREDETERMINADO"/>
                                    <ComboBox fx:id="cmbMetodoPago" maxWidth="Infinity"/>
                                    <Label styleClass="cfg-label-key" text="MONEDA DE REDONDEO"/>
                                    <ComboBox fx:id="cmbRedondeo" maxWidth="Infinity"/>

                                    <HBox alignment="CENTER_LEFT" spacing="12"
                                          style="-fx-background-color: #f5f9ff; -fx-padding: 10 14; -fx-background-radius: 10; -fx-min-height: 52; -fx-max-height: 52;">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 12px;" text="Requerir apertura de caja"/>
                                            <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="Cajero debe registrar fondo inicial"/>
                                        </VBox>
                                        <SwitchToggle fx:id="tglAperturaCaja" selected="true"
                                                      style="-fx-background-color: #1a6fa8; -fx-background-radius: 12; -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="12"
                                          style="-fx-background-color: #f5f9ff; -fx-padding: 10 14; -fx-background-radius: 10; -fx-min-height: 52; -fx-max-height: 52;">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 12px;" text="Confirmar antes de cobrar"/>
                                            <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="Pantalla de resumen previa al cobro"/>
                                        </VBox>
                                        <SwitchToggle fx:id="tglConfirmarCobro" selected="true"
                                                      style="-fx-background-color: #1a6fa8; -fx-background-radius: 12; -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="12"
                                          style="-fx-background-color: #f5f9ff; -fx-padding: 10 14; -fx-background-radius: 10; -fx-min-height: 52; -fx-max-height: 52;">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 12px;" text="Imprimir ticket automaticamente"/>
                                            <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="No pregunta, imprime al cerrar venta"/>
                                        </VBox>
                                        <SwitchToggle fx:id="tglAutoImprimir"
                                                      style="-fx-background-color: #b0c4d8; -fx-background-radius: 12; -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;"/>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <!-- Productos y Busqueda -->
                            <VBox spacing="0" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-background-radius: 14;
                                         -fx-padding: 20;
                                         -fx-effect: dropshadow(gaussian, rgba(13,61,94,0.07), 12, 0, 0, 2);">
                                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 14 0;">
                                    <FontIcon iconLiteral="fas-barcode" iconSize="15" iconColor="#1a6fa8"/>
                                    <VBox spacing="2">
                                        <Label styleClass="cfg-card-title" text="Productos y Busqueda"/>
                                        <Label styleClass="cfg-card-subtitle" text="Como se muestran y buscan los articulos"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <VBox spacing="4" style="-fx-padding: 14 0 0 0;">
                                    <Label styleClass="cfg-label-key" text="BUSQUEDA POR"/>
                                    <ComboBox fx:id="cmbBusqueda" maxWidth="Infinity"/>
                                    <Label styleClass="cfg-label-key" text="ORDEN DE PRODUCTOS EN CAJA"/>
                                    <ComboBox fx:id="cmbOrdenProductos" maxWidth="Infinity"/>

                                    <HBox alignment="CENTER_LEFT" spacing="12"
                                          style="-fx-background-color: #f5f9ff; -fx-padding: 10 14; -fx-background-radius: 10; -fx-min-height: 52; -fx-max-height: 52;">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 12px;" text="Mostrar imagen de producto en caja"/>
                                            <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="Miniatura en cada articulo del carrito"/>
                                        </VBox>
                                        <SwitchToggle fx:id="tglImagenesProducto" selected="true"
                                                      style="-fx-background-color: #1a6fa8; -fx-background-radius: 12; -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="12"
                                          style="-fx-background-color: #f5f9ff; -fx-padding: 10 14; -fx-background-radius: 10; -fx-min-height: 52; -fx-max-height: 52;">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 12px;" text="Alertar stock bajo en caja"/>
                                            <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="Aviso al agregar producto con poco inventario"/>
                                        </VBox>
                                        <SwitchToggle fx:id="tglAlertaStock" selected="true"
