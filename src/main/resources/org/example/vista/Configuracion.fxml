                                        <graphic><FontIcon iconLiteral="fas-download" iconSize="13" iconColor="white"/></graphic>
                                    </Button>
                                </VBox>
                            </GridPane>
                        </VBox>

                        <VBox fx:id="panelCatalogoWeb" spacing="18" visible="false" managed="false">
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="section-heading">
                                <FontIcon iconLiteral="fas-cloud" iconSize="20" iconColor="#0b3b75"/>
