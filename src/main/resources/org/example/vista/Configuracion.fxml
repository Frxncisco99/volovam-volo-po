<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.example.modelo.*?>
<?import org.kordamp.ikonli.javafx.*?>

<BorderPane prefHeight="720" prefWidth="1180"
            styleClass="cfg-root"
            stylesheets="@configuracion.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controlador.ConfiguracionController">

    <left>
        <VBox minWidth="232" prefWidth="232" maxWidth="232" styleClass="cfg-sidebar">
            <VBox spacing="4" styleClass="cfg-sidebar-brand">
                <Label styleClass="cfg-brand-title" text="Volovan Volo"/>
                <Label styleClass="cfg-brand-subtitle" text="SISTEMA DE PUNTO DE VENTA"/>
            </VBox>

            <Separator styleClass="cfg-sidebar-separator"/>

            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="cfg-user-box">
                <Label fx:id="lblAvatarIniciales" styleClass="cfg-avatar" text="AD"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" styleClass="cfg-user-name" text="Usuario"/>
                    <Label fx:id="lblRolUsuario" styleClass="cfg-user-role" text="Rol"/>
                </VBox>
            </HBox>

            <Separator styleClass="cfg-sidebar-separator"/>

            <VBox spacing="4" styleClass="cfg-nav" VBox.vgrow="ALWAYS">
                <Label styleClass="cfg-nav-section" text="PRINCIPAL"/>

                <Button graphicTextGap="12" onAction="#irADashboard" styleClass="cfg-sidebar-btn" text="Dashboard">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.82)" iconLiteral="fas-tachometer-alt" iconSize="16"/></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irAVentas" styleClass="cfg-sidebar-btn" text="Ventas / Caja">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.82)" iconLiteral="fas-shopping-cart" iconSize="16"/></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irAInventario" styleClass="cfg-sidebar-btn" text="Inventario">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.82)" iconLiteral="fas-box" iconSize="16"/></graphic>
                </Button>

                <Label styleClass="cfg-nav-section" text="GESTION"/>

                <Button graphicTextGap="12" onAction="#irAEmpleados" styleClass="cfg-sidebar-btn" text="Empleados">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.82)" iconLiteral="fas-users" iconSize="16"/></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irAClientes" styleClass="cfg-sidebar-btn" text="Clientes">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.82)" iconLiteral="fas-user-friends" iconSize="16"/></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irAReportes" styleClass="cfg-sidebar-btn" text="Reportes">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.82)" iconLiteral="fas-chart-bar" iconSize="16"/></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irACorteCaja" styleClass="cfg-sidebar-btn" text="Corte de Caja">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.82)" iconLiteral="fas-cash-register" iconSize="16"/></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irAAuditoria" styleClass="cfg-sidebar-btn" text="Auditoria">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.82)" iconLiteral="fas-shield-alt" iconSize="16"/></graphic>
                </Button>
                <Button graphicTextGap="12" styleClass="cfg-sidebar-btn-active" text="Configuracion">
                    <graphic><FontIcon iconColor="#1a6fa8" iconLiteral="fas-cog" iconSize="16"/></graphic>
                </Button>
            </VBox>

            <Separator styleClass="cfg-sidebar-separator"/>

            <Button graphicTextGap="10" onAction="#btnCerrar" styleClass="cfg-logout-btn" text="Cambiar sesion">
                <graphic><FontIcon iconColor="#f87171" iconLiteral="fas-exchange-alt" iconSize="16"/></graphic>
            </Button>
        </VBox>
    </left>

    <center>
        <VBox styleClass="cfg-main">
            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="cfg-topbar">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <FontIcon iconColor="#1a6fa8" iconLiteral="fas-sliders-h" iconSize="17"/>
                        <Label styleClass="cfg-page-title" text="Configuracion"/>
                    </HBox>
                    <Label styleClass="cfg-page-subtitle" text="Administra parametros generales, seguridad, tickets, integraciones y base de datos"/>
                </VBox>

                <Label fx:id="lblEstadoCaja" styleClass="cfg-status-pill" text="Sistema activo"/>
                <Label fx:id="lblHora" styleClass="cfg-clock" text="--:--:--"/>
                <Label fx:id="lblGuardadoAt" managed="false" styleClass="cfg-save-feedback" text="" visible="false"/>

                <Button graphicTextGap="8" onAction="#restablecerConfiguracion" styleClass="cfg-btn-secondary" text="Restablecer">
                    <graphic><FontIcon iconColor="#1a6fa8" iconLiteral="fas-undo-alt" iconSize="13"/></graphic>
                    <tooltip><Tooltip text="Restaurar valores predeterminados"/></tooltip>
                </Button>
                <Button fx:id="btnGuardar" graphicTextGap="8" onAction="#guardarConfiguracion" styleClass="cfg-btn-primary" text="Guardar Cambios">
                    <graphic><FontIcon iconColor="white" iconLiteral="fas-save" iconSize="13"/></graphic>
                    <tooltip><Tooltip text="Guardar configuracion actual"/></tooltip>
                </Button>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="6" styleClass="cfg-tab-bar">
                <Button fx:id="btnTabNegocio" onAction="#tabNegocio" styleClass="cfg-tab" text="General"/>
                <Button fx:id="btnTabPOS" onAction="#tabPOS" styleClass="cfg-tab" text="Sistema POS"/>
                <Button fx:id="btnTabUsuarios" onAction="#tabUsuarios" styleClass="cfg-tab" text="Seguridad"/>
                <Button fx:id="btnTabFiscal" onAction="#tabFiscal" styleClass="cfg-tab" text="Tickets"/>
                <Button fx:id="btnTabIntegraciones" onAction="#tabIntegraciones" styleClass="cfg-tab" text="Integraciones"/>
                <Button fx:id="btnTabBaseDatos" onAction="#tabBaseDatos" styleClass="cfg-tab" text="Base de Datos"/>
            </HBox>

            <ScrollPane fitToWidth="true" pannable="true" styleClass="cfg-scroll" VBox.vgrow="ALWAYS">
                <VBox spacing="18" styleClass="cfg-content">

                    <VBox fx:id="panelNegocio" spacing="18">
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="cfg-section-heading">
                            <FontIcon iconColor="#1a6fa8" iconLiteral="fas-store" iconSize="16"/>
                            <VBox spacing="1">
                                <Label styleClass="cfg-section-title" text="Configuracion General"/>
                                <Label styleClass="cfg-section-subtitle" text="Datos comerciales, ubicacion y operacion diaria"/>
                            </VBox>
                        </HBox>

                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="260" percentWidth="33.33"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="260" percentWidth="33.33"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="260" percentWidth="33.33"/>
                            </columnConstraints>

                            <VBox spacing="10" styleClass="cfg-card" GridPane.columnIndex="0">
                                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="cfg-card-header">
                                    <FontIcon iconColor="#1a6fa8" iconLiteral="fas-store" iconSize="16"/>
                                    <VBox spacing="1">
                                        <Label styleClass="cfg-card-title" text="Informacion General"/>
                                        <Label styleClass="cfg-card-subtitle" text="Datos principales del negocio"/>
                                    </VBox>
                                </HBox>
                                <Separator/>

                                <Label styleClass="cfg-label-key" text="NOMBRE DEL NEGOCIO"/>
                                <TextField fx:id="txtNombreNegocio" maxWidth="Infinity" promptText="Ej. Volovan Volo"/>
                                <Label styleClass="cfg-label-key" text="SLOGAN / DESCRIPCION CORTA"/>
                                <TextField fx:id="txtSlogan" maxWidth="Infinity" promptText="Ej. El sabor de casa"/>
                                <Label styleClass="cfg-label-key" text="TELEFONO"/>
                                <TextField fx:id="txtTelefono" maxWidth="Infinity" promptText="878-123-4567"/>
                                <Label styleClass="cfg-label-key" text="CORREO ELECTRONICO"/>
                                <TextField fx:id="txtCorreo" maxWidth="Infinity" promptText="admin@negocio.mx"/>
                                <Label styleClass="cfg-label-key" text="SITIO WEB"/>
                                <TextField fx:id="txtSitioWeb" maxWidth="Infinity" promptText="www.negocio.mx"/>
                            </VBox>

                            <VBox spacing="10" styleClass="cfg-card" GridPane.columnIndex="1">
                                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="cfg-card-header">
                                    <FontIcon iconColor="#1a6fa8" iconLiteral="fas-map-marker-alt" iconSize="16"/>
                                    <VBox spacing="1">
                                        <Label styleClass="cfg-card-title" text="Configuracion Regional"/>
                                        <Label styleClass="cfg-card-subtitle" text="Ubicacion, moneda y zona horaria"/>
                                    </VBox>
                                </HBox>
                                <Separator/>

                                <Label styleClass="cfg-label-key" text="DIRECCION"/>
                                <TextField fx:id="txtDireccion" maxWidth="Infinity" promptText="Calle, Num, Colonia"/>
                                <HBox spacing="10">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-label-key" text="CIUDAD"/>
                                        <TextField fx:id="txtCiudad" maxWidth="Infinity" promptText="Ej. Piedras Negras"/>
                                    </VBox>
                                    <VBox minWidth="88" prefWidth="96" spacing="5">
                                        <Label styleClass="cfg-label-key" text="C.P."/>
                                        <TextField fx:id="txtCP" maxWidth="Infinity" promptText="26000"/>
                                    </VBox>
                                </HBox>
                                <Label styleClass="cfg-label-key" text="RFC"/>
                                <TextField fx:id="txtRFC" maxWidth="Infinity" promptText="XAXX010101000"/>
                                <Label styleClass="cfg-label-key" text="MONEDA"/>
                                <ComboBox fx:id="cmbMoneda" maxWidth="Infinity"/>
                                <Label styleClass="cfg-label-key" text="ZONA HORARIA"/>
                                <ComboBox fx:id="cmbZonaHoraria" maxWidth="Infinity"/>
                            </VBox>

                            <VBox spacing="10" styleClass="cfg-card" GridPane.columnIndex="2">
                                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="cfg-card-header">
                                    <FontIcon iconColor="#1a6fa8" iconLiteral="fas-clock" iconSize="16"/>
                                    <VBox spacing="1">
                                        <Label styleClass="cfg-card-title" text="Horario y Operacion"/>
                                        <Label styleClass="cfg-card-subtitle" text="Dias, horario y control operativo"/>
                                    </VBox>
                                </HBox>
                                <Separator/>

                                <HBox spacing="10">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-label-key" text="HORA DE APERTURA"/>
                                        <TextField fx:id="txtHoraApertura" maxWidth="Infinity" promptText="08:00"/>
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-label-key" text="HORA DE CIERRE"/>
                                        <TextField fx:id="txtHoraCierre" maxWidth="Infinity" promptText="21:00"/>
                                    </VBox>
                                </HBox>

                                <Label styleClass="cfg-label-key" text="DIAS DE OPERACION"/>
                                <HBox spacing="5" styleClass="cfg-days-row">
                                    <ToggleButton fx:id="tglLun" selected="true" text="L"/>
                                    <ToggleButton fx:id="tglMar" selected="true" text="M"/>
                                    <ToggleButton fx:id="tglMie" selected="true" text="Mi"/>
                                    <ToggleButton fx:id="tglJue" selected="true" text="J"/>
                                    <ToggleButton fx:id="tglVie" selected="true" text="V"/>
                                    <ToggleButton fx:id="tglSab" selected="true" text="S"/>
                                    <ToggleButton fx:id="tglDom" text="D"/>
                                </HBox>

                                <Separator/>
                                <Label styleClass="cfg-label-key" text="LIMITE DE CREDITO INTERNO"/>
                                <TextField fx:id="txtLimiteCredito" maxWidth="Infinity" promptText="Ej. 500.00"/>
                                <Label styleClass="cfg-label-key" text="NUMERO DE SUCURSAL / CAJA"/>
                                <TextField fx:id="txtNumSucursal" maxWidth="Infinity" promptText="Ej. 01 - Centro"/>

                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-toggle-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-toggle-title" text="Modo mantenimiento"/>
                                        <Label styleClass="cfg-toggle-desc" text="Bloquea acceso a cajeros"/>
                                    </VBox>
                                    <ToggleButton fx:id="tglMantenimiento" styleClass="cfg-switch-button" text=""/>
                                </HBox>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <VBox fx:id="panelPOS" managed="false" spacing="18" visible="false">
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="cfg-section-heading">
                            <FontIcon iconColor="#1a6fa8" iconLiteral="fas-cash-register" iconSize="16"/>
                            <VBox spacing="1">
                                <Label styleClass="cfg-section-title" text="Sistema POS"/>
                                <Label styleClass="cfg-section-subtitle" text="Caja, productos, ventas y comportamiento operativo"/>
                            </VBox>
                        </HBox>

                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="260" percentWidth="33.33"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="260" percentWidth="33.33"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="260" percentWidth="33.33"/>
                            </columnConstraints>

                            <VBox spacing="10" styleClass="cfg-card" GridPane.columnIndex="0">
                                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="cfg-card-header">
                                    <FontIcon iconColor="#1a6fa8" iconLiteral="fas-cash-register" iconSize="16"/>
                                    <VBox spacing="1">
                                        <Label styleClass="cfg-card-title" text="Operacion de Caja"/>
                                        <Label styleClass="cfg-card-subtitle" text="Comportamiento del punto de venta"/>
                                    </VBox>
                                </HBox>
                                <Separator/>

                                <Label styleClass="cfg-label-key" text="METODO DE PAGO PREDETERMINADO"/>
                                <ComboBox fx:id="cmbMetodoPago" maxWidth="Infinity"/>
                                <Label styleClass="cfg-label-key" text="MONEDA DE REDONDEO"/>
                                <ComboBox fx:id="cmbRedondeo" maxWidth="Infinity"/>

                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-toggle-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-toggle-title" text="Requerir apertura de caja"/>
                                        <Label styleClass="cfg-toggle-desc" text="Cajero debe registrar fondo inicial"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglAperturaCaja" selected="true"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-toggle-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-toggle-title" text="Confirmar antes de cobrar"/>
                                        <Label styleClass="cfg-toggle-desc" text="Pantalla de resumen previa al cobro"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglConfirmarCobro" selected="true"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-toggle-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-toggle-title" text="Imprimir ticket automaticamente"/>
                                        <Label styleClass="cfg-toggle-desc" text="Imprime al cerrar la venta"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglAutoImprimir"/>
                                </HBox>
                            </VBox>

                            <VBox spacing="10" styleClass="cfg-card" GridPane.columnIndex="1">
                                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="cfg-card-header">
                                    <FontIcon iconColor="#1a6fa8" iconLiteral="fas-barcode" iconSize="16"/>
                                    <VBox spacing="1">
                                        <Label styleClass="cfg-card-title" text="Productos y Busqueda"/>
                                        <Label styleClass="cfg-card-subtitle" text="Como se muestran y buscan articulos"/>
                                    </VBox>
                                </HBox>
                                <Separator/>

                                <Label styleClass="cfg-label-key" text="BUSQUEDA POR"/>
                                <ComboBox fx:id="cmbBusqueda" maxWidth="Infinity"/>
                                <Label styleClass="cfg-label-key" text="ORDEN DE PRODUCTOS EN CAJA"/>
                                <ComboBox fx:id="cmbOrdenProductos" maxWidth="Infinity"/>

                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-toggle-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-toggle-title" text="Mostrar imagen de producto"/>
                                        <Label styleClass="cfg-toggle-desc" text="Miniatura en articulos del carrito"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglImagenesProducto" selected="true"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-toggle-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-toggle-title" text="Alertar stock bajo"/>
                                        <Label styleClass="cfg-toggle-desc" text="Aviso al agregar producto con poco inventario"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglAlertaStock" selected="true"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-toggle-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-toggle-title" text="Vender sin stock"/>
                                        <Label styleClass="cfg-toggle-desc" text="Permite vender con inventario en cero"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglVentaSinStock"/>
                                </HBox>
                            </VBox>

                            <VBox spacing="10" styleClass="cfg-card" GridPane.columnIndex="2">
                                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="cfg-card-header">
                                    <FontIcon iconColor="#1a6fa8" iconLiteral="fas-tags" iconSize="16"/>
                                    <VBox spacing="1">
                                        <Label styleClass="cfg-card-title" text="Ventas y Clientes"/>
                                        <Label styleClass="cfg-card-subtitle" text="Reglas avanzadas de venta"/>
                                    </VBox>
                                </HBox>
                                <Separator/>

                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-toggle-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-toggle-title" text="Asociar cliente a la venta"/>
                                        <Label styleClass="cfg-toggle-desc" text="Permite buscar cliente al vender"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglAsociarCliente" selected="true"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-toggle-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-toggle-title" text="Ventas a credito"/>
                                        <Label styleClass="cfg-toggle-desc" text="Cobro diferido a clientes registrados"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglVentaCredito"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-toggle-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-toggle-title" text="Habilitar devoluciones"/>
                                        <Label styleClass="cfg-toggle-desc" text="Genera nota de credito o reembolso"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglDevoluciones" selected="true"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-toggle-row">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-toggle-title" text="Modo de venta rapida"/>
                                        <Label styleClass="cfg-toggle-desc" text="Cobra sin pantalla de pago"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglVentaRapida"/>
                                </HBox>

                                <Label styleClass="cfg-label-key" text="NOTA INTERNA EN TICKET"/>
                                <TextField fx:id="txtNotaInterna" maxWidth="Infinity" promptText="Ej. Para llevar / Nombre cliente"/>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <VBox fx:id="panelUsuarios" managed="false" spacing="18" visible="false">
                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="cfg-hero-card">
                            <FontIcon iconColor="#1a6fa8" iconLiteral="fas-users-cog" iconSize="20"/>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label styleClass="cfg-section-title" text="Seguridad, Usuarios y Roles"/>
                                <Label styleClass="cfg-section-subtitle" text="Administra accesos, permisos y controles de sesion"/>
                            </VBox>
                            <Button graphicTextGap="8" onAction="#agregarUsuario" styleClass="cfg-btn-primary" text="Nuevo Usuario">
                                <graphic><FontIcon iconColor="white" iconLiteral="fas-user-plus" iconSize="13"/></graphic>
                            </Button>
                        </HBox>

                        <HBox spacing="16">
                            <VBox minWidth="520" spacing="10" styleClass="cfg-card" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <FontIcon iconColor="#1a6fa8" iconLiteral="fas-users" iconSize="15"/>
                                    <Label styleClass="cfg-card-title" text="Usuarios Registrados"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <TextField fx:id="txtBuscarUsuario" maxWidth="220" prefWidth="200" promptText="Buscar usuario..."/>
                                </HBox>
                                <Separator/>

                                <TableView fx:id="tablaUsuarios" prefHeight="368" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colUsuNombre" prefWidth="190" text="USUARIO"/>
                                        <TableColumn fx:id="colUsuRol" prefWidth="130" text="ROL"/>
                                        <TableColumn fx:id="colUsuEstado" prefWidth="95" text="ESTADO"/>
                                        <TableColumn fx:id="colUsuUltimoAcceso" prefWidth="135" text="ULTIMO ACCESO"/>
                                        <TableColumn fx:id="colUsuAcciones" prefWidth="190" text="ACCIONES"/>
                                    </columns>
                                </TableView>
                            </VBox>

                            <VBox minWidth="320" prefWidth="340" spacing="10" styleClass="cfg-card">
                                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="cfg-card-header">
                                    <FontIcon iconColor="#1a6fa8" iconLiteral="fas-shield-alt" iconSize="15"/>
                                    <Label styleClass="cfg-card-title" text="Roles y Permisos"/>
                                </HBox>
                                <Separator/>

                                <VBox spacing="6" styleClass="cfg-role-admin">
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <FontIcon iconColor="#1a6fa8" iconLiteral="fas-crown" iconSize="13"/>
                                        <Label styleClass="cfg-role-title" text="Administrador"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label styleClass="cfg-role-badge-blue" text="Acceso total"/>
                                    </HBox>
                                    <Label styleClass="cfg-role-ok" text="Ventas  Inventario  Reportes  Usuarios"/>
                                    <Label styleClass="cfg-role-ok" text="Configuracion  Corte de caja  Clientes"/>
                                </VBox>

                                <VBox spacing="6" styleClass="cfg-role-gerente">
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <FontIcon iconColor="#27AE60" iconLiteral="fas-user-tie" iconSize="13"/>
                                        <Label styleClass="cfg-role-title" text="Gerente"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label styleClass="cfg-role-badge-green" text="Amplio"/>
                                    </HBox>
                                    <Label styleClass="cfg-role-ok" text="Ventas  Inventario  Reportes  Clientes  Corte"/>
                                    <Label styleClass="cfg-role-no" text="Sin acceso: Usuarios  Configuracion"/>
                                </VBox>

                                <VBox spacing="6" styleClass="cfg-role-cajero">
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <FontIcon iconColor="#2980B9" iconLiteral="fas-user" iconSize="13"/>
                                        <Label styleClass="cfg-role-title" text="Cajero"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label styleClass="cfg-role-badge-sky" text="Basico"/>
                                    </HBox>
                                    <Label styleClass="cfg-role-ok" text="Ventas  Clientes"/>
