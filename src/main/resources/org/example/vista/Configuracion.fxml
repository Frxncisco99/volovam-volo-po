                                        <Label text="Facebook" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtWebFacebook" promptText="https://facebook.com/VolovanVoloPyR" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
                                    </GridPane>
                                </VBox>

                                <VBox spacing="16" styleClass="settings-card" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="card-header">
                                        <FontIcon iconLiteral="fas-link" iconSize="18" iconColor="#0b3b75"/>
