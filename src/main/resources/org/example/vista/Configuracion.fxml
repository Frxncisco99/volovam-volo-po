<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.example.modelo.*?>
<?import org.kordamp.ikonli.javafx.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@menuPrincipal.css"
            fx:controller="org.example.controlador.ConfiguracionController">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="230" style="-fx-background-color: #091e4e;">

            <!-- Marca -->
            <VBox prefHeight="72.0" prefWidth="219.0" spacing="3" style="-fx-padding: 24 18 16 18;">
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Volovan Volo" />
                <Label style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 9px;" text="SISTEMA DE PUNTO DE VENTA" />
            </VBox>

            <Separator style="-fx-opacity: 0.15;" />

            <!-- Usuario -->
            <HBox spacing="10" style="-fx-padding: 14 18;">
                <Label fx:id="lblAvatarIniciales" style="-fx-background-color: rgba(255,255,255,0.22);                               -fx-text-fill: white;                               -fx-font-weight: bold;                               -fx-font-size: 13px;                               -fx-min-width: 36; -fx-min-height: 36;                               -fx-background-radius: 18;                               -fx-alignment: center;" text="AD" />
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Usuario" />
                    <Label fx:id="lblRolUsuario" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 10px;" text="Rol" />
                </VBox>
            </HBox>

            <Separator style="-fx-opacity: 0.15;" />

            <!-- Navegación -->
            <VBox spacing="3" style="-fx-padding: 10 10;" VBox.vgrow="ALWAYS">

                <Label style="-fx-text-fill: rgba(255,255,255,0.35);                               -fx-font-size: 9px; -fx-font-weight: bold;                               -fx-padding: 8 8 3 8;" text="PRINCIPAL" />


                <Button graphicTextGap="12" onAction="#irADashboard" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Dashboard">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-tachometer-alt" iconSize="16" /></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAVentas" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Ventas / Caja">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-shopping-cart" iconSize="16" /></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAInventario" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Inventario">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-box" iconSize="16" /></graphic>
                </Button>

                <Label style="-fx-text-fill: rgba(255,255,255,0.35);                               -fx-font-size: 9px; -fx-font-weight: bold;                               -fx-padding: 12 8 3 8;" text="GESTIÓN" />

                <Button graphicTextGap="12" onAction="#irAEmpleados" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Empleados">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-users" iconSize="16" /></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAClientes" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Clientes">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-user-friends" iconSize="16" /></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAReportes" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Reportes">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-chart-bar" iconSize="16" /></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irACorteCaja" prefHeight="40" prefWidth="210" style="-fx-background-color: transparent;                                -fx-text-fill: rgba(255,255,255,0.8);                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Corte de Caja">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-cash-register" iconSize="16" /></graphic>
                </Button>

                <Button graphicTextGap="12" prefHeight="40" prefWidth="210" style="-fx-background-color: white;                                -fx-text-fill: #1a6fa8;                                -fx-font-weight: bold;                                -fx-background-radius: 8;                                -fx-alignment: CENTER_LEFT;                                -fx-padding: 0 14;                                -fx-cursor: hand;" text="Configuracion">
                    <graphic><FontIcon iconColor="#1a6fa8" iconLiteral="fas-cog" iconSize="16" /></graphic>
                </Button>

            </VBox>

            <Separator style="-fx-opacity: 0.15;" />

            <!-- Cerrar sesión -->
            <Button graphicTextGap="10" onAction="#btnCerrar" prefHeight="44" prefWidth="230" style="-fx-background-color: transparent;                            -fx-text-fill: rgba(255,180,180,0.9);                            -fx-cursor: hand;" text="Cerrar sesion" textFill="RED">
                <graphic><FontIcon iconColor="#ff0000e5" iconLiteral="fas-sign-out-alt" iconSize="16" /></graphic>
            </Button>

        </VBox>
    </left>

    <!-- CONTENIDO -->
    <center>
        <VBox prefWidth="960" style="-fx-background-color: #f0f7ff;">

            <!-- TOPBAR -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 18 24; -fx-spacing: 12; -fx-effect: dropshadow(gaussian, #1a6fa815, 8, 0, 0, 2);">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Configuracion"/>
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #6a96b8;" text="Administra los parametros generales del sistema"/>
                </VBox>
                <Button onAction="#restablecerConfiguracion"
                        style="-fx-background-color: transparent; -fx-text-fill: #1a6fa8; -fx-border-color: #1a6fa8; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 20; -fx-cursor: hand; -fx-font-size: 12px;"
                        text="Restablecer"/>
                <Button onAction="#guardarConfiguracion"
                        style="-fx-background-color: #1a6fa8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 9 20; -fx-cursor: hand; -fx-font-size: 12px;"
                        text="Guardar Cambios"/>
            </HBox>

            <!-- PESTAÑAS -->
            <HBox spacing="6" style="-fx-padding: 0 24 14 24; -fx-background-color: #f0f7ff;">
                <Button fx:id="btnTabNegocio" onAction="#tabNegocio"
                        style="-fx-background-color: #1a6fa8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"
                        text="Negocio"/>
                <Button fx:id="btnTabPOS" onAction="#tabPOS"
                        style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"
                        text="POS / Caja"/>
                <Button fx:id="btnTabUsuarios" onAction="#tabUsuarios"
                        style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"
                        text="Usuarios y Roles"/>
                <Button fx:id="btnTabFiscal" onAction="#tabFiscal"
                        style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"
                        text="Fiscal / Tickets"/>
                <Button fx:id="btnTabIntegraciones" onAction="#tabIntegraciones"
                        style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"
                        text="Integraciones"/>
                <Button fx:id="btnTabBaseDatos" onAction="#tabBaseDatos"
                        style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"
                        text="Base de Datos"/>
            </HBox>

            <ScrollPane fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox style="-fx-padding: 0 24 24 24; -fx-spacing: 16;">

                    <!-- PANEL NEGOCIO -->
                    <VBox fx:id="panelNegocio" spacing="16">
                        <HBox spacing="16">

                            <!-- Info general -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-store" iconSize="16" iconColor="#1a6fa8"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 13px;" text="Informacion General"/>
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="Datos principales del negocio"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="NOMBRE DEL NEGOCIO"/>
                                <TextField fx:id="txtNombreNegocio" promptText="Ej. Volovan Volo"
                                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="SLOGAN / DESCRIPCION CORTA"/>
                                <TextField fx:id="txtSlogan" promptText="Ej. El sabor de casa"
                                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="TELEFONO"/>
                                <TextField fx:id="txtTelefono" promptText="878-123-4567"
                                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="CORREO ELECTRONICO"/>
                                <TextField fx:id="txtCorreo" promptText="admin@negocio.mx"
                                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="SITIO WEB"/>
                                <TextField fx:id="txtSitioWeb" promptText="www.negocio.mx"
                                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                            </VBox>

                            <!-- Regional -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-map-marker-alt" iconSize="16" iconColor="#1a6fa8"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 13px;" text="Configuracion Regional"/>
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="Ubicacion, moneda y zona horaria"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="DIRECCION"/>
                                <TextField fx:id="txtDireccion" promptText="Calle, Num, Colonia"
                                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                <HBox spacing="10">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="CIUDAD"/>
                                        <TextField fx:id="txtCiudad" promptText="Ej. Piedras Negras"
                                                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                    </VBox>
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="C.P."/>
                                        <TextField fx:id="txtCP" promptText="26000"
                                                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                    </VBox>
                                </HBox>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="RFC"/>
                                <TextField fx:id="txtRFC" promptText="XAXX010101000"
                                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="MONEDA"/>
                                <ComboBox fx:id="cmbMoneda" maxWidth="Infinity"
                                          style="-fx-background-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-background-color: white; -fx-font-size: 12px;"/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="ZONA HORARIA"/>
                                <ComboBox fx:id="cmbZonaHoraria" maxWidth="Infinity"
                                          style="-fx-background-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-background-color: white; -fx-font-size: 12px;"/>
                            </VBox>

                            <!-- Horario -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-clock" iconSize="16" iconColor="#1a6fa8"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 13px;" text="Horario y Operacion"/>
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="Dias y horas de atencion"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <HBox spacing="10">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="HORA DE APERTURA"/>
                                        <TextField fx:id="txtHoraApertura" promptText="08:00"
                                                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                    </VBox>
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="HORA DE CIERRE"/>
                                        <TextField fx:id="txtHoraCierre" promptText="21:00"
                                                   style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                    </VBox>
                                </HBox>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="DIAS DE OPERACION"/>
                                <HBox spacing="5">
                                    <ToggleButton fx:id="tglLun" text="L" selected="true"
                                                  style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 20; -fx-padding: 6 10; -fx-font-size: 11px; -fx-cursor: hand; -fx-border-color: #1a6fa8; -fx-border-radius: 20; -fx-border-width: 0.5;"/>
                                    <ToggleButton fx:id="tglMar" text="M" selected="true"
                                                  style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 20; -fx-padding: 6 10; -fx-font-size: 11px; -fx-cursor: hand; -fx-border-color: #1a6fa8; -fx-border-radius: 20; -fx-border-width: 0.5;"/>
                                    <ToggleButton fx:id="tglMie" text="Mi" selected="true"
                                                  style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 20; -fx-padding: 6 10; -fx-font-size: 11px; -fx-cursor: hand; -fx-border-color: #1a6fa8; -fx-border-radius: 20; -fx-border-width: 0.5;"/>
                                    <ToggleButton fx:id="tglJue" text="J" selected="true"
                                                  style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 20; -fx-padding: 6 10; -fx-font-size: 11px; -fx-cursor: hand; -fx-border-color: #1a6fa8; -fx-border-radius: 20; -fx-border-width: 0.5;"/>
                                    <ToggleButton fx:id="tglVie" text="V" selected="true"
                                                  style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 20; -fx-padding: 6 10; -fx-font-size: 11px; -fx-cursor: hand; -fx-border-color: #1a6fa8; -fx-border-radius: 20; -fx-border-width: 0.5;"/>
                                    <ToggleButton fx:id="tglSab" text="S" selected="true"
                                                  style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 20; -fx-padding: 6 10; -fx-font-size: 11px; -fx-cursor: hand; -fx-border-color: #1a6fa8; -fx-border-radius: 20; -fx-border-width: 0.5;"/>
                                    <ToggleButton fx:id="tglDom" text="D"
                                                  style="-fx-background-color: white; -fx-text-fill: #6a96b8; -fx-background-radius: 20; -fx-padding: 6 10; -fx-font-size: 11px; -fx-cursor: hand; -fx-border-color: #1a6fa8; -fx-border-radius: 20; -fx-border-width: 0.5;"/>
                                </HBox>
                                <Separator/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="LIMITE DE CREDITO INTERNO"/>
                                <TextField fx:id="txtLimiteCredito" promptText="Ej. 500.00"
                                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="NUMERO DE SUCURSAL / CAJA"/>
                                <TextField fx:id="txtNumSucursal" promptText="Ej. 01 - Centro"
                                           style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;"/>
                                <HBox alignment="CENTER_LEFT" spacing="12"
                                      style="-fx-background-color: #f5f9ff; -fx-padding: 10; -fx-background-radius: 8;">
                                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                                        <Label text="Modo mantenimiento" style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 12px;"/>
                                        <Label text="Bloquea acceso a cajeros" style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;"/>
                                    </VBox>
                                    <ToggleButton fx:id="tglMantenimiento"
                                                  style="-fx-background-color: #b0c4d8; -fx-background-radius: 12; -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" text=""/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- PANEL POS -->
                    <VBox fx:id="panelPOS" spacing="16" visible="false" managed="false">
                        <HBox spacing="16">

                            <!-- Operacion de Caja -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-cash-register" iconSize="16" iconColor="#1a6fa8"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 13px;" text="Operacion de Caja"/>
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="Comportamiento del punto de venta"/>
                                    </VBox>
