                                        <Label text="Costo envio" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtWebCostoEnvio" promptText="50.00" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="WhatsApp" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
