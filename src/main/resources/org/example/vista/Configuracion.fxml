                                        </VBox>
                                        <SwitchToggle fx:id="tglWebOcultarSinStock"/>
                                    </HBox>
                                </VBox>

                                <VBox spacing="16" styleClass="settings-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="card-header">
                                        <FontIcon iconLiteral="fas-shopping-bag" iconSize="18" iconColor="#0b3b75"/>
                                        <VBox>
                                            <Label text="Pedidos y contacto" styleClass="card-title"/>
