                                        <graphic><FontIcon iconLiteral="fas-plug" iconSize="13"/></graphic>
                                    </Button>
                                </VBox>
                                <VBox spacing="16" styleClass="settings-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
