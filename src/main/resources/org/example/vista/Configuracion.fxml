                                        </Button>
                                        <Button fx:id="btnWebSubirInventario" text="Subir inventario local" onAction="#subirInventarioWeb" graphicTextGap="8" styleClass="secondary-button" GridPane.rowIndex="0" GridPane.columnIndex="1">
