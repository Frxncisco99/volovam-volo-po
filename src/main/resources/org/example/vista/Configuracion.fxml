<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.example.modelo.SwitchToggle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@configuracion.css"
            fx:controller="org.example.controlador.ConfiguracionController">
    <left>
        <VBox prefWidth="230" styleClass="app-sidebar">
            <VBox spacing="3" style="-fx-padding: 24 18 16 18;">
                <Label text="Volovan Volo" styleClass="sidebar-brand"/>
                <Label text="SISTEMA DE PUNTO DE VENTA" styleClass="sidebar-subtitle"/>
            </VBox>
            <Separator style="-fx-opacity: 0.15;"/>
            <HBox spacing="10" style="-fx-padding: 14 18;">
                <Label fx:id="lblAvatarIniciales" text="US" styleClass="sidebar-avatar"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" text="Usuario" styleClass="sidebar-user"/>
                    <Label fx:id="lblRolUsuario" text="Rol" styleClass="sidebar-role"/>
                </VBox>
            </HBox>
            <Separator style="-fx-opacity: 0.15;"/>
            <VBox spacing="3" style="-fx-padding: 10 10;" VBox.vgrow="ALWAYS">
                <Label text="PRINCIPAL" styleClass="sidebar-section"/>
                <Button text="Dashboard" onAction="#irADashboard" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-tachometer-alt" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Ventas / Caja" onAction="#irAVentas" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-shopping-cart" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Inventario" onAction="#irAInventario" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-box" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Label text="GESTION" styleClass="sidebar-section"/>
                <Button text="Empleados" onAction="#irAEmpleados" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-users" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Clientes" onAction="#irAClientes" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Reportes" onAction="#irAReportes" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-chart-bar" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Corte de Caja" onAction="#irACorteCaja" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-cash-register" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Auditoria" onAction="#irAAuditoria" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-shield-alt" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Configuracion" graphicTextGap="12" styleClass="sidebar-button-active">
                    <graphic><FontIcon iconLiteral="fas-cog" iconSize="16" iconColor="#1a6fa8"/></graphic>
                </Button>
            </VBox>
            <Separator style="-fx-opacity: 0.15;"/>
            <Button text="Cerrar sesion" onAction="#btnCerrar" graphicTextGap="10" styleClass="sidebar-logout">
                <graphic><FontIcon iconLiteral="fas-sign-out-alt" iconSize="16" iconColor="#ff0000e5"/></graphic>
            </Button>
        </VBox>
    </left>

    <center>
        <VBox styleClass="config-root">
            <HBox alignment="CENTER_LEFT" styleClass="topbar">
                <VBox spacing="2">
                    <Label text="Configuracion" styleClass="view-title"/>
                    <Label text="Datos del negocio, ticket, caja, correo, usuarios y base de datos" styleClass="view-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblFeedbackGuardado" text="" styleClass="save-feedback"/>
            </HBox>

            <HBox VBox.vgrow="ALWAYS">
                <VBox prefWidth="210" spacing="8" styleClass="config-tabs">
                    <Button fx:id="btnTabNegocio" text="Negocio" onAction="#tabNegocio" styleClass="cfg-tab-button"/>
                    <Button fx:id="btnTabTicket" text="Ticket" onAction="#tabTicket" styleClass="cfg-tab-button"/>
                    <Button fx:id="btnTabCajon" text="Cajon de dinero" onAction="#tabCajon" styleClass="cfg-tab-button"/>
                    <Button fx:id="btnTabEmail" text="Correo / Email" onAction="#tabEmail" styleClass="cfg-tab-button"/>
                    <Button fx:id="btnTabUsuarios" text="Usuarios" onAction="#tabUsuarios" styleClass="cfg-tab-button"/>
                    <Button fx:id="btnTabBaseDatos" text="Base de datos" onAction="#tabBaseDatos" styleClass="cfg-tab-button"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS">
                    <ScrollPane fitToWidth="true" styleClass="config-scroll" VBox.vgrow="ALWAYS">
                        <VBox spacing="16" style="-fx-padding: 18 22 22 22;">
                            <VBox fx:id="panelNegocio" spacing="14">
                                <TitledPane text="Datos del negocio" expanded="true" collapsible="false">
                                    <GridPane hgap="14" vgap="10" styleClass="section-grid">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="50"/>
                                            <ColumnConstraints percentWidth="50"/>
                                        </columnConstraints>
                                        <Label text="Nombre del negocio" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtNombreNegocio" promptText="Volovan Volo" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Slogan" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtSlogan" promptText="El sabor de casa" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        <Label text="Telefono" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTelefono" promptText="8781234567" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <Label text="Correo" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtCorreo" promptText="contacto@negocio.mx" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                        <Label text="Direccion" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtDireccion" promptText="Calle, numero, colonia" styleClass="cfg-field" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                        <Label text="Ciudad" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtCiudad" promptText="Piedras Negras" styleClass="cfg-field" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                                        <Label text="Codigo postal" styleClass="field-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtCP" promptText="26000" styleClass="cfg-field" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                                        <Label text="Sitio web" styleClass="field-label" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtSitioWeb" promptText="www.negocio.mx" styleClass="cfg-field" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                                        <Label text="RFC" styleClass="field-label" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtRFC" promptText="XAXX010101000" styleClass="cfg-field" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                                    </GridPane>
                                </TitledPane>
                            </VBox>

                            <VBox fx:id="panelTicket" spacing="14" visible="false" managed="false">
                                <TitledPane text="Identidad del ticket" expanded="true" collapsible="false">
                                    <GridPane hgap="14" vgap="10" styleClass="section-grid">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="50"/>
                                            <ColumnConstraints percentWidth="50"/>
                                        </columnConstraints>
                                        <Label text="Nombre" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTicketNombre" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Giro" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtTicketGiro" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        <Label text="Direccion" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTicketDireccion" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <Label text="Ciudad" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtTicketCiudad" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                        <Label text="Telefono" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTicketTelefono" styleClass="cfg-field" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                    </GridPane>
                                </TitledPane>
                                <TitledPane text="Textos e impresion" expanded="true" collapsible="false">
                                    <VBox spacing="12" styleClass="section-grid">
                                        <Label text="Encabezado" styleClass="field-label"/>
                                        <TextArea fx:id="txtMensajeEncabezado" prefRowCount="2" styleClass="cfg-area"/>
                                        <Label text="Pie" styleClass="field-label"/>
                                        <TextArea fx:id="txtMensajePie" prefRowCount="3" styleClass="cfg-area"/>
                                        <Label text="Aviso" styleClass="field-label"/>
                                        <TextArea fx:id="txtAvisoFiscal" prefRowCount="2" styleClass="cfg-area"/>
                                        <HBox spacing="18" alignment="CENTER_LEFT">
                                            <VBox spacing="4"><Label text="Logo" styleClass="field-label"/><SwitchToggle fx:id="tglLogoTicket"/></VBox>
                                            <VBox spacing="4"><Label text="Folio" styleClass="field-label"/><SwitchToggle fx:id="tglFolioTicket"/></VBox>
                                            <VBox spacing="4"><Label text="Desglose" styleClass="field-label"/><SwitchToggle fx:id="tglDesglose"/></VBox>
                                            <VBox spacing="4"><Label text="QR" styleClass="field-label"/><SwitchToggle fx:id="tglQR"/></VBox>
                                        </HBox>
                                        <GridPane hgap="14" vgap="10">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="50"/>
                                                <ColumnConstraints percentWidth="50"/>
                                            </columnConstraints>
                                            <Label text="Impresora" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                            <ComboBox fx:id="cmbImpresora" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                            <Label text="Ancho de papel" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                            <ComboBox fx:id="cmbAnchoPapel" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        </GridPane>
                                        <Button text="Vista previa" onAction="#abrirVistaPrevia" styleClass="primary-button"/>
                                    </VBox>
                                </TitledPane>
                            </VBox>

                            <VBox fx:id="panelCajon" spacing="14" visible="false" managed="false">
                                <TitledPane text="Apertura automatica al vender" expanded="true" collapsible="false">
                                    <VBox spacing="14" styleClass="section-grid">
                                        <HBox alignment="CENTER_LEFT" spacing="14">
                                            <VBox HBox.hgrow="ALWAYS">
                                                <Label text="Abrir cajon automaticamente" styleClass="section-title"/>
                                                <Label text="Se ejecuta despues de imprimir el ticket de venta." styleClass="muted-label"/>
                                            </VBox>
                                            <SwitchToggle fx:id="tglCajonActivo"/>
                                        </HBox>
                                        <GridPane hgap="14" vgap="10">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="50"/>
                                                <ColumnConstraints percentWidth="50"/>
                                            </columnConstraints>
                                            <Label text="Puerto del cajon" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                            <ComboBox fx:id="cmbCajonPuerto" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                            <Label text="Pulso" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                            <ComboBox fx:id="cmbCajonPulso" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        </GridPane>
                                        <Label text="Para impresoras termicas el cajon se abre enviando el comando ESC/POS a la misma impresora" styleClass="info-note"/>
                                    </VBox>
                                </TitledPane>
                            </VBox>

                            <VBox fx:id="panelEmail" spacing="14" visible="false" managed="false">
                                <TitledPane text="Ticket por correo" expanded="true" collapsible="false">
                                    <VBox spacing="14" styleClass="section-grid">
                                        <HBox alignment="CENTER_LEFT" spacing="14">
                                            <VBox HBox.hgrow="ALWAYS">
                                                <Label text="Envio de ticket por correo" styleClass="section-title"/>
                                                <Label text="Usa SMTP con TLS y password de aplicacion cuando el proveedor lo requiera." styleClass="muted-label"/>
                                            </VBox>
                                            <SwitchToggle fx:id="tglEmailActivo"/>
                                        </HBox>
                                        <GridPane hgap="14" vgap="10">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="50"/>
                                                <ColumnConstraints percentWidth="50"/>
                                            </columnConstraints>
                                            <Label text="Proveedor SMTP" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                            <ComboBox fx:id="cmbEmailSmtp" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                            <Label text="Remitente" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                            <TextField fx:id="txtEmailRemitente" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                            <Label text="Password / App Password" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                            <PasswordField fx:id="txtEmailPassword" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        </GridPane>
                                        <VBox fx:id="boxSmtpPersonalizado" spacing="10">
                                            <GridPane hgap="14" vgap="10">
                                                <columnConstraints>
                                                    <ColumnConstraints percentWidth="70"/>
                                                    <ColumnConstraints percentWidth="30"/>
                                                </columnConstraints>
                                                <Label text="Servidor SMTP" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                                <TextField fx:id="txtEmailHost" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                                <Label text="Puerto" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                                <TextField fx:id="txtEmailPuerto" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                            </GridPane>
                                        </VBox>
                                        <HBox alignment="CENTER_LEFT" spacing="14">
                                            <VBox HBox.hgrow="ALWAYS">
                                                <Label text="Reporte diario por correo" styleClass="section-title"/>
                                                <Label text="Guarda la preferencia para automatizar reportes diarios." styleClass="muted-label"/>
                                            </VBox>
                                            <SwitchToggle fx:id="tglEmailReporteDiario"/>
                                        </HBox>
                                        <Button text="Probar conexion" onAction="#probarCorreo" styleClass="primary-button"/>
                                    </VBox>
                                </TitledPane>
                            </VBox>

                            <VBox fx:id="panelUsuarios" spacing="14" visible="false" managed="false">
                                <TitledPane text="Usuarios del sistema" expanded="true" collapsible="false">
                                    <VBox spacing="12" styleClass="section-grid">
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <TextField fx:id="txtBuscarUsuario" promptText="Buscar usuario, nombre o rol..." styleClass="cfg-field" HBox.hgrow="ALWAYS"/>
                                            <Button text="Nuevo usuario" onAction="#agregarUsuario" styleClass="primary-button"/>
                                        </HBox>
                                        <TableView fx:id="tablaUsuarios" prefHeight="420">
                                            <columns>
                                                <TableColumn fx:id="colUsuarioNombre" text="Nombre" prefWidth="240"/>
                                                <TableColumn fx:id="colUsuarioRol" text="Rol" prefWidth="120"/>
                                                <TableColumn fx:id="colUsuarioEstado" text="Estado" prefWidth="110"/>
                                                <TableColumn fx:id="colUsuarioAcciones" text="Acciones" prefWidth="270"/>
                                            </columns>
                                        </TableView>
                                    </VBox>
                                </TitledPane>
                            </VBox>

                            <VBox fx:id="panelBaseDatos" spacing="14" visible="false" managed="false">
                                <TitledPane text="Estado de conexion" expanded="true" collapsible="false">
                                    <VBox spacing="14" styleClass="section-grid">
                                        <GridPane hgap="14" vgap="10">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="25"/>
                                                <ColumnConstraints percentWidth="25"/>
                                                <ColumnConstraints percentWidth="50"/>
                                            </columnConstraints>
                                            <Label text="Estado" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                            <Label fx:id="lblEstadoDB" text="Sin conexion" styleClass="cfg-status" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                            <Label text="Host" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                            <Label fx:id="lblDBHost" text="localhost:3306" styleClass="value-label" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                            <Label text="Base de datos" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                            <Label fx:id="lblDBNombre" text="pospanaderia" styleClass="value-label" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                                            <Label text="Version del motor" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                            <Label fx:id="lblDBVersion" text="No disponible" styleClass="value-label" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="3"/>
                                        </GridPane>
                                        <HBox spacing="10">
                                            <Button text="Probar conexion" onAction="#probarConexionDB" styleClass="primary-button"/>
                                        </HBox>
                                    </VBox>
                                </TitledPane>
                                <TitledPane text="Respaldo SQL" expanded="true" collapsible="false">
                                    <VBox spacing="12" styleClass="section-grid">
                                        <Label text="Carpeta destino" styleClass="field-label"/>
                                        <HBox spacing="8">
                                            <TextField fx:id="txtRutaRespaldo" promptText="C:/Respaldos/POS" styleClass="cfg-field" HBox.hgrow="ALWAYS"/>
                                            <Button text="..." onAction="#seleccionarCarpetaRespaldo" styleClass="secondary-button"/>
                                        </HBox>
                                        <Button text="Exportar respaldo SQL" onAction="#exportarRespaldo" styleClass="success-button"/>
                                    </VBox>
                                </TitledPane>
                            </VBox>
                        </VBox>
                    </ScrollPane>
                    <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="bottom-save-bar">
                        <Button fx:id="btnGuardarCambios" text="Guardar Cambios" onAction="#guardarConfiguracion" styleClass="primary-button"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
