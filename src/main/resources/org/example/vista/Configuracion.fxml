<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.example.modelo.*?>
<?import org.kordamp.ikonli.javafx.*?>

<BorderPane stylesheets="@menuPrincipal.css, @configuracion.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controlador.ConfiguracionController">

    <!--Sidebar-->
    <left>
        <VBox prefWidth="230" style="-fx-background-color: #3D1F0D;">
            <VBox spacing="2" style="-fx-padding: 28 20 16 20;">
                <Label style="-fx-text-fill: #D4A843; -fx-font-size: 22px; -fx-font-weight: bold;" text="Volovan Volo" />
                <Label style="-fx-text-fill: #C8A97E; -fx-font-size: 10px;" text="Sistema de Punto de Venta" />
            </VBox>
            <Separator style="-fx-opacity: 0.2;" />
            <HBox spacing="12" style="-fx-padding: 16 20;">
                <Label fx:id="lblAvatarIniciales" style="-fx-background-color: #D4A843; -fx-text-fill: #864628; -fx-font-weight: bold;                               -fx-font-size: 14px; -fx-min-width: 38; -fx-min-height: 38;                               -fx-background-radius: 19; -fx-alignment: center;" text="--" />
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" text="Usuario" />
                    <Label fx:id="lblRolUsuario" style="-fx-text-fill: #C8A97E; -fx-font-size: 10px;" text="Rol" />
                </VBox>
            </HBox>
            <Separator style="-fx-opacity: 0.2;" />
            <VBox spacing="4" style="-fx-padding: 12;" VBox.vgrow="ALWAYS">
                <Label style="-fx-text-fill: #C8A97E; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 8 8 4 8;" text="PRINCIPAL" />
                <Button graphicTextGap="12" onAction="#irADashboard" prefHeight="40" prefWidth="206" style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Dashboard">
                    <graphic><FontIcon iconColor="#C8A97E" iconLiteral="fas-tachometer-alt" iconSize="16" /></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irAVentas" prefHeight="40" prefWidth="206" style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Ventas / Caja">
                    <graphic><FontIcon iconColor="#C8A97E" iconLiteral="fas-shopping-cart" iconSize="16" /></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irAInventario" prefHeight="40" prefWidth="206" style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Inventario">
                    <graphic><FontIcon iconColor="#C8A97E" iconLiteral="fas-box" iconSize="16" /></graphic>
                </Button>
                <Label style="-fx-text-fill: #C8A97E; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 12 8 4 8;" text="GESTION" />
                <Button graphicTextGap="12" onAction="#irAEmpleados" prefHeight="40" prefWidth="206" style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Empleados">
                    <graphic><FontIcon iconColor="#C8A97E" iconLiteral="fas-users" iconSize="16" /></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irAClientes" prefHeight="40" prefWidth="206" style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Clientes">
                    <graphic><FontIcon iconColor="#C8A97E" iconLiteral="fas-user-friends" iconSize="16" /></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irAReportes" prefHeight="40" prefWidth="206" style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Reportes">
                    <graphic><FontIcon iconColor="#C8A97E" iconLiteral="fas-chart-bar" iconSize="16" /></graphic>
                </Button>
                <Button graphicTextGap="12" onAction="#irACorteCaja" prefHeight="40" prefWidth="206" style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Corte de Caja">
                    <graphic><FontIcon iconColor="#C8A97E" iconLiteral="fas-cash-register" iconSize="16" /></graphic>
                </Button>
                <Button graphicTextGap="12" prefHeight="40" prefWidth="206" style="-fx-background-color: #6B4226; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Configuracion">
                    <graphic><FontIcon iconColor="white" iconLiteral="fas-cog" iconSize="16" /></graphic>
                </Button>
            </VBox>
            <Separator style="-fx-opacity: 0.2;" />
            <Button graphicTextGap="10" onAction="#btnCerrar" prefHeight="44" prefWidth="230" style="-fx-background-color: transparent; -fx-text-fill: #C0392B; -fx-cursor: hand;" text="Cerrar sesion">
                <graphic><FontIcon iconColor="#C0392B" iconLiteral="fas-sign-out-alt" iconSize="16" /></graphic>
            </Button>
        </VBox>
    </left>

    <!-- Contenido-->
    <center>
        <VBox prefWidth="960" style="-fx-background-color: #F5EFE6;">

            <!--Topbar-->
            <HBox alignment="CENTER_LEFT" styleClass="topbar" style="-fx-padding: 18 24; -fx-spacing: 12;">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3D1F0D;" text="Configuracion" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7A5535;" text="Administra los parametros generales del sistema" />
                </VBox>
                <Button onAction="#restablecerConfiguracion" style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-border-color: #D4C5B0;                                -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 20; -fx-cursor: hand; -fx-font-size: 12px;" text="Restablecer" />
                <Button onAction="#guardarConfiguracion" style="-fx-background-color: #D4A843; -fx-text-fill: white; -fx-font-weight: bold;                                -fx-background-radius: 8; -fx-padding: 9 20; -fx-cursor: hand; -fx-font-size: 12px;" text="Guardar Cambios" />
            </HBox>

            <!--Barra de pestañas-->
            <HBox spacing="6" style="-fx-padding: 0 24 14 24; -fx-background-color: #F5EFE6;">
                <Button fx:id="btnTabNegocio" onAction="#tabNegocio" style="-fx-background-color: #6B4226; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;" text="Negocio" />
                <Button fx:id="btnTabPOS" onAction="#tabPOS" style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand; -fx-border-color: #D4C5B0; -fx-border-radius: 20;" text="POS / Caja" />
                <Button fx:id="btnTabUsuarios" onAction="#tabUsuarios" style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand; -fx-border-color: #D4C5B0; -fx-border-radius: 20;" text="Usuarios y Roles" />
                <Button fx:id="btnTabFiscal" onAction="#tabFiscal" style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand; -fx-border-color: #D4C5B0; -fx-border-radius: 20;" text="Fiscal / Tickets" />
                <Button fx:id="btnTabIntegraciones" onAction="#tabIntegraciones" style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand; -fx-border-color: #D4C5B0; -fx-border-radius: 20;" text="Integraciones" />
                <Button fx:id="btnTabBaseDatos" onAction="#tabBaseDatos" style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand; -fx-border-color: #D4C5B0; -fx-border-radius: 20;" text="Base de Datos" />
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox style="-fx-padding: 0 24 24 24; -fx-spacing: 16;">

                    <!--Panel de negocios-->
                    <VBox fx:id="panelNegocio" spacing="16">
                        <HBox spacing="16">

                            <!--info general-->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-store" iconSize="16" iconColor="#6B4226"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 13px;" text="Informacion General" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="Datos principales del negocio" />
                                    </VBox>
                                </HBox>
                                <Separator />
                                <Label styleClass="cfg-label" text="NOMBRE DEL NEGOCIO" />
                                <TextField fx:id="txtNombreNegocio" promptText="Ej. Volovan Volo" styleClass="cfg-field" />
                                <Label styleClass="cfg-label" text="SLOGAN / DESCRIPCION CORTA" />
                                <TextField fx:id="txtSlogan" promptText="Ej. El sabor de casa" styleClass="cfg-field" />
                                <Label styleClass="cfg-label" text="TELEFONO" />
                                <TextField fx:id="txtTelefono" promptText="878-123-4567" styleClass="cfg-field" />
                                <Label styleClass="cfg-label" text="CORREO ELECTRONICO" />
                                <TextField fx:id="txtCorreo" promptText="admin@negocio.mx" styleClass="cfg-field" />
                                <Label styleClass="cfg-label" text="SITIO WEB" />
                                <TextField fx:id="txtSitioWeb" promptText="www.negocio.mx" styleClass="cfg-field" />
                            </VBox>


                            <!--Regional-->

                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-map-marker-alt" iconSize="16" iconColor="#6B4226"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 13px;" text="Configuracion Regional" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="Ubicacion, moneda y zona horaria" />
                                    </VBox>
                                </HBox>
                                <Separator />
                                <Label styleClass="cfg-label" text="DIRECCION" />
                                <TextField fx:id="txtDireccion" promptText="Calle, Num, Colonia" styleClass="cfg-field" />
                                <HBox spacing="10">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-label" text="CIUDAD" />
                                        <TextField fx:id="txtCiudad" promptText="Ej. Piedras Negras" styleClass="cfg-field" />
                                    </VBox>
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-label" text="C.P." />
                                        <TextField fx:id="txtCP" promptText="26000" styleClass="cfg-field" />
                                    </VBox>
                                </HBox>
                                <Label styleClass="cfg-label" text="RFC" />
                                <TextField fx:id="txtRFC" promptText="XAXX010101000" styleClass="cfg-field" />
                                <Label styleClass="cfg-label" text="MONEDA" />
                                <ComboBox fx:id="cmbMoneda" maxWidth="Infinity" styleClass="cfg-combo" />
                                <Label styleClass="cfg-label" text="ZONA HORARIA" />
                                <ComboBox fx:id="cmbZonaHoraria" maxWidth="Infinity" styleClass="cfg-combo" />
                            </VBox>

                            <!-- HORARIO Y OPERACION-->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-clock" iconSize="16" iconColor="#6B4226"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 13px;" text="Horario y Operacion" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="Dias y horas de atencion" />
                                    </VBox>
                                </HBox>
                                <Separator />
                                <HBox spacing="10">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-label" text="HORA DE APERTURA" />
                                        <TextField fx:id="txtHoraApertura" promptText="08:00" styleClass="cfg-field" />
                                    </VBox>
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label styleClass="cfg-label" text="HORA DE CIERRE" />
                                        <TextField fx:id="txtHoraCierre" promptText="21:00" styleClass="cfg-field" />
                                    </VBox>
                                </HBox>
                                <Label styleClass="cfg-label" text="DIAS DE OPERACION" />
                                <HBox spacing="5">
                                    <ToggleButton fx:id="tglLun" text="L" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglMar" text="M" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglMie" text="Mi" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglJue" text="J" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglVie" text="V" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglSab" text="S" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglDom" text="D" styleClass="dia-btn"/>
                                </HBox>
                                <Separator/>
                                <Label text="LIMITE DE CREDITO INTERNO ($)" styleClass="cfg-label"/>
                                <TextField fx:id="txtLimiteCredito" promptText="Ej. 500.00" styleClass="cfg-field"/>
                                <Label text="NUMERO DE SUCURSAL / CAJA" styleClass="cfg-label"/>
                                <TextField fx:id="txtNumSucursal" promptText="Ej. 01 - Centro" styleClass="cfg-field"/>
                                <HBox alignment="CENTER_LEFT" spacing="12"
                                      style="-fx-background-color: #FDF8F2; -fx-padding: 10; -fx-background-radius: 8;">
                                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                                        <Label text="Modo mantenimiento"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;"/>
                                        <Label text="Bloquea acceso a cajeros"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                    <ToggleButton fx:id="tglMantenimiento"
                                                  style="-fx-background-color: #CCBBAA; -fx-background-radius: 12;
                                                         -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" text=""/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!--PANEL pos y caja-->
                    <VBox fx:id="panelPOS" spacing="16" visible="false" managed="false">
                        <HBox spacing="16">

                            <!-- OPERACION DE CAJA-->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-cash-register" iconSize="16" iconColor="#6B4226"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 13px;" text="Operacion de Caja" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="Comportamiento del punto de venta" />
                                    </VBox>
                                </HBox>
                                <Separator />
                                <Label styleClass="cfg-label" text="METODO DE PAGO PREDETERMINADO" />
                                <ComboBox fx:id="cmbMetodoPago" maxWidth="Infinity" styleClass="cfg-combo" />
                                <Label styleClass="cfg-label" text="MONEDA DE REDONDEO" />
                                <ComboBox fx:id="cmbRedondeo" maxWidth="Infinity" styleClass="cfg-combo" />
                                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;" text="Requerir apertura de caja" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="Cajero debe registrar fondo inicial" />
                                    </VBox>
                                    <SwitchToggle fx:id="tglAperturaCaja" selected="true" style="-fx-background-color: #D4A843; -fx-background-radius: 12;                                                          -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;" text="Confirmar antes de cobrar" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="Pantalla de resumen previa al cobro" />
                                    </VBox>
                                    <SwitchToggle fx:id="tglConfirmarCobro" selected="true" style="-fx-background-color: #D4A843; -fx-background-radius: 12;                                                          -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;" text="Imprimir ticket automaticamente" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="No pregunta, imprime al cerrar venta" />
                                    </VBox>
                                    <SwitchToggle fx:id="tglAutoImprimir" style="-fx-background-color: #CCBBAA; -fx-background-radius: 12;                                                          -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" />
                                </HBox>
                            </VBox>

                            <!--PRODUCTOS Y BUSQUEDA-->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-barcode" iconSize="16" iconColor="#6B4226"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 13px;" text="Productos y Busqueda" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="Como se muestran y buscan los articulos" />
                                    </VBox>
                                </HBox>
                                <Separator />
                                <Label styleClass="cfg-label" text="BUSQUEDA POR" />
                                <ComboBox fx:id="cmbBusqueda" maxWidth="Infinity" styleClass="cfg-combo" />
                                <Label styleClass="cfg-label" text="ORDEN DE PRODUCTOS EN CAJA" />
                                <ComboBox fx:id="cmbOrdenProductos" maxWidth="Infinity" styleClass="cfg-combo" />
                                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;" text="Mostrar imagen de producto en caja" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="Miniatura en cada articulo del carrito" />
                                    </VBox>
                                    <SwitchToggle fx:id="tglImagenesProducto" selected="true" style="-fx-background-color: #D4A843; -fx-background-radius: 12;                                                          -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;" text="Alertar stock bajo en caja" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="Aviso al agregar producto con poco inventario" />
                                    </VBox>
                                    <SwitchToggle fx:id="tglAlertaStock" selected="true" style="-fx-background-color: #D4A843; -fx-background-radius: 12;                                                          -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" />
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;" text="Vender producto sin stock" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="Permite vender aunque el inventario sea 0" />
                                    </VBox>
                                    <SwitchToggle fx:id="tglVentaSinStock" style="-fx-background-color: #CCBBAA; -fx-background-radius: 12;                                                          -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" />
                                </HBox>
                            </VBox>

                            <!--VENTAS Y CLIENTES-->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-tags" iconSize="16" iconColor="#6B4226"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 13px;" text="Ventas y Clientes" />
                                        <Label style="-fx-text-fill: #7A5535; -fx-font-size: 10px;" text="Comportamiento avanzado de ventas" />
