                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="HOST / IP"/>
                                        <TextField fx:id="txtDBHost" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;" text="localhost"/>
                                    </VBox>
                                    <VBox prefWidth="80" spacing="4">
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="PUERTO"/>
                                        <TextField fx:id="txtDBPuerto" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;" text="3306"/>
                                    </VBox>
                                </HBox>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="BASE DE DATOS"/>
                                <TextField fx:id="txtDBNombre" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;" text="pospanaderia"/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="USUARIO"/>
                                <TextField fx:id="txtDBUsuario" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-padding: 8 12; -fx-font-size: 12px; -fx-background-color: white;" text="root"/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="CONTRASENA"/>
                                <PasswordField fx:id="txtDBPassword" promptText="Contrasena de BD"
                                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5;"/>
                                <HBox spacing="10">
                                    <Button maxWidth="Infinity" onAction="#probarConexionDB" HBox.hgrow="ALWAYS"
                                            style="-fx-background-color: #1a6fa8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 11px;"
                                            text="Probar Conexion"/>
                                    <Button maxWidth="Infinity" onAction="#aplicarConexionDB" HBox.hgrow="ALWAYS"
                                            style="-fx-background-color: #0d3d5e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 11px;"
                                            text="Aplicar"/>
                                </HBox>
                            </VBox>

                            <!-- Respaldos -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-hdd" iconSize="16" iconColor="#1a6fa8"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 13px;" text="Respaldos"/>
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="Exporta y restaura tu base de datos"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="CARPETA DE RESPALDOS"/>
                                <HBox spacing="8">
                                    <TextField fx:id="txtRutaRespaldo" promptText="C:/Respaldos/POS"
                                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5;" HBox.hgrow="ALWAYS"/>
                                    <Button onAction="#seleccionarCarpetaRespaldo"
                                            style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-cursor: hand;"
                                            text="..."/>
                                </HBox>
                                <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="FRECUENCIA DE RESPALDO AUTOMATICO"/>
                                <ComboBox fx:id="cmbFrecuenciaRespaldo" maxWidth="Infinity"
                                          style="-fx-background-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 0.5; -fx-background-color: white; -fx-font-size: 12px;"/>
                                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #f5f9ff; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 12px;" text="Respaldo automatico activado"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglRespaldoAuto" selected="true"
                                                  style="-fx-background-color: #1a6fa8; -fx-background-radius: 12; -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;"/>
                                </HBox>
                                <VBox style="-fx-background-color: #f5f9ff; -fx-padding: 12; -fx-background-radius: 8;">
                                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="ULTIMO RESPALDO"/>
                                    <Label fx:id="lblUltimoRespaldo" style="-fx-text-fill: #6a96b8; -fx-font-size: 11px;" text="Ningun respaldo realizado"/>
                                    <Label fx:id="lblTamanoRespaldo" style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;"/>
                                </VBox>
                                <HBox spacing="10">
                                    <Button maxWidth="Infinity" onAction="#exportarRespaldo" HBox.hgrow="ALWAYS"
                                            style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 11px;"
                                            text="Exportar Respaldo"/>
                                    <Button maxWidth="Infinity" onAction="#restaurarRespaldo" HBox.hgrow="ALWAYS"
                                            style="-fx-background-color: #E67E22; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 11px;"
                                            text="Restaurar"/>
                                </HBox>
                            </VBox>

                            <!-- Mantenimiento -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-tools" iconSize="16" iconColor="#1a6fa8"/>
                                    <VBox>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 13px;" text="Mantenimiento"/>
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="Optimizacion y limpieza del sistema"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <VBox style="-fx-background-color: #f5f9ff; -fx-padding: 12; -fx-background-radius: 8;">
                                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 9px; -fx-font-weight: bold;" text="INFORMACION DE LA BASE DE DATOS"/>
                                    <HBox>
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 11px;" text="Tamano total:" HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="lblTamanoDB" style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 11px;" text="calculando..."/>
                                    </HBox>
                                    <HBox>
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 11px;" text="Registros de ventas:" HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="lblRegVentas" style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 11px;" text="---"/>
                                    </HBox>
                                    <HBox>
                                        <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 11px;" text="Productos registrados:" HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="lblRegProductos" style="-fx-font-weight: bold; -fx-text-fill: #0d3d5e; -fx-font-size: 11px;" text="---"/>
                                    </HBox>
                                </VBox>
                                <Button maxWidth="Infinity" onAction="#actualizarEstadisticasDB"
                                        style="-fx-background-color: #1a6fa8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 11px;"
                                        text="Actualizar Estadisticas"/>
                                <Separator/>
                                <Button maxWidth="Infinity" onAction="#limpiarTemporales"
                                        style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 11px;"
                                        text="Limpiar Registros Temporales"/>
                                <Button maxWidth="Infinity" onAction="#optimizarTablas"
                                        style="-fx-background-color: #e8f3fb; -fx-text-fill: #1a6fa8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 11px;"
                                        text="Optimizar Tablas"/>
                                <Button maxWidth="Infinity" onAction="#limpiarAuditoria"
                                        style="-fx-background-color: #FDE8E8; -fx-text-fill: #C0392B; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand; -fx-font-size: 11px;"
                                        text="Limpiar Log de Auditoria"/>
                            </VBox>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
