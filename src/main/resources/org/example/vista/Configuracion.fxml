                                        <Label text="Enlace inventario" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                        <ComboBox fx:id="cmbWebModoEnlace" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
