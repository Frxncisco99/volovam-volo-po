                                <FontIcon iconLiteral="fas-envelope" iconSize="20" iconColor="#0b3b75"/>
                                <VBox>
                                    <Label text="Correo y ticket por email" styleClass="section-title"/>
                                    <Label text="Configura SMTP para pruebas, envio de tickets y reportes diarios." styleClass="section-subtitle"/>
