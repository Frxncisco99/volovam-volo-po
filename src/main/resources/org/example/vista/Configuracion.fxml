<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.example.modelo.SwitchToggle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@configuracion.css"
            fx:controller="org.example.controlador.ConfiguracionController">

    <left>
        <VBox prefWidth="230" styleClass="app-sidebar">
            <VBox spacing="4" styleClass="brand-block">
                <Label fx:id="lblMarcaNegocio" text="Volovan Volo" styleClass="sidebar-brand"/>
                <Label text="SISTEMA DE PUNTO DE VENTA" styleClass="sidebar-subtitle"/>
            </VBox>
            <Separator styleClass="sidebar-separator"/>
            <HBox spacing="10" styleClass="sidebar-user-box">
                <Label fx:id="lblAvatarIniciales" text="US" styleClass="sidebar-avatar"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" text="Usuario" styleClass="sidebar-user"/>
                    <Label fx:id="lblRolUsuario" text="Rol" styleClass="sidebar-role"/>
                </VBox>
            </HBox>
            <Separator styleClass="sidebar-separator"/>
            <VBox spacing="4" styleClass="main-menu" VBox.vgrow="ALWAYS">
                <Label text="PRINCIPAL" styleClass="sidebar-section"/>
                <Button text="Dashboard" onAction="#irADashboard" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-tachometer-alt" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Ventas / Caja" onAction="#irAVentas" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-shopping-cart" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Inventario" onAction="#irAInventario" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-box" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Label text="GESTION" styleClass="sidebar-section"/>
                <Button text="Empleados" onAction="#irAEmpleados" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-users" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Clientes" onAction="#irAClientes" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Reportes" onAction="#irAReportes" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-chart-bar" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Corte de Caja" onAction="#irACorteCaja" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-cash-register" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Auditoria" onAction="#irAAuditoria" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-shield-alt" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button text="Configuracion" graphicTextGap="12" styleClass="sidebar-button-active">
                    <graphic><FontIcon iconLiteral="fas-cog" iconSize="16" iconColor="#1a6fa8"/></graphic>
                </Button>
            </VBox>
            <Separator styleClass="sidebar-separator"/>
            <Button text="Cambiar sesion" onAction="#btnCerrar" graphicTextGap="10" styleClass="sidebar-logout">
                <graphic><FontIcon iconLiteral="fas-exchange-alt" iconSize="16" iconColor="#f87171"/></graphic>
            </Button>
        </VBox>
    </left>

    <center>
        <VBox styleClass="config-root">
            <HBox alignment="CENTER_LEFT" styleClass="config-header">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Configuracion" styleClass="view-title"/>
                    <Label text="Administra negocio, tickets, caja, correo, usuarios y base de datos." styleClass="view-subtitle"/>
                </VBox>
                <Label fx:id="lblFeedbackGuardado" text="" styleClass="save-feedback"/>
                <Button fx:id="btnGuardarCambios" text="Guardar cambios" onAction="#guardarConfiguracion" styleClass="primary-button">
                    <graphic><FontIcon iconLiteral="fas-save" iconSize="14" iconColor="white"/></graphic>
                </Button>
            </HBox>

            <VBox VBox.vgrow="ALWAYS" styleClass="workspace">
                <HBox spacing="8" alignment="CENTER_LEFT" styleClass="config-tabs">
                    <Button fx:id="btnTabNegocio" text="General" onAction="#tabNegocio" graphicTextGap="8" styleClass="cfg-tab-button">
                        <graphic><FontIcon iconLiteral="fas-store" iconSize="13"/></graphic>
                    </Button>
                    <Button fx:id="btnTabFiscal" text="Fiscal" onAction="#tabFiscal" graphicTextGap="8" styleClass="cfg-tab-button">
                        <graphic><FontIcon iconLiteral="fas-file-invoice-dollar" iconSize="13"/></graphic>
                    </Button>
                    <Button fx:id="btnTabTicket" text="Tickets" onAction="#tabTicket" graphicTextGap="8" styleClass="cfg-tab-button">
                        <graphic><FontIcon iconLiteral="fas-receipt" iconSize="13"/></graphic>
                    </Button>
                    <Button fx:id="btnTabCajon" text="Caja" onAction="#tabCajon" graphicTextGap="8" styleClass="cfg-tab-button">
                        <graphic><FontIcon iconLiteral="fas-cash-register" iconSize="13"/></graphic>
                    </Button>
                    <Button fx:id="btnTabEmail" text="Correo" onAction="#tabEmail" graphicTextGap="8" styleClass="cfg-tab-button">
                        <graphic><FontIcon iconLiteral="fas-envelope" iconSize="13"/></graphic>
                    </Button>
                    <Button fx:id="btnTabUsuarios" text="Seguridad" onAction="#tabUsuarios" graphicTextGap="8" styleClass="cfg-tab-button">
                        <graphic><FontIcon iconLiteral="fas-user-shield" iconSize="13"/></graphic>
                    </Button>
                    <Button fx:id="btnTabBaseDatos" text="Sistema" onAction="#tabBaseDatos" graphicTextGap="8" styleClass="cfg-tab-button">
                        <graphic><FontIcon iconLiteral="fas-database" iconSize="13"/></graphic>
                    </Button>
                    <Button fx:id="btnTabCatalogoWeb" text="Catalogo Web" onAction="#tabCatalogoWeb" graphicTextGap="8" styleClass="cfg-tab-button">
                        <graphic><FontIcon iconLiteral="fas-cloud" iconSize="13"/></graphic>
                    </Button>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="BD + Web" styleClass="nav-note-text"/>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="config-scroll" VBox.vgrow="ALWAYS">
                    <VBox spacing="18" maxWidth="1180" styleClass="content-shell">

                        <VBox fx:id="panelNegocio" spacing="18">
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="section-heading">
                                <FontIcon iconLiteral="fas-building" iconSize="20" iconColor="#0b3b75"/>
                                <VBox>
                                    <Label text="Configuracion general" styleClass="section-title"/>
                                    <Label text="Informacion publica del negocio usada en reportes, pantalla y tickets." styleClass="section-subtitle"/>
                                </VBox>
                            </HBox>
                            <GridPane hgap="18" vgap="18" styleClass="card-grid">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="58"/>
                                    <ColumnConstraints percentWidth="42"/>
                                </columnConstraints>

                                <VBox spacing="14" styleClass="settings-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                                        <FontIcon iconLiteral="fas-store" iconSize="18" iconColor="#0b3b75"/>
                                        <VBox>
                                            <Label text="Identidad del negocio" styleClass="card-title"/>
                                            <Label text="Datos principales para operacion y documentos." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
                                        <Label text="Nombre del negocio" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtNombreNegocio" promptText="Volovan Volo" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Slogan" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtSlogan" promptText="El sabor de casa" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        <Label text="Telefono" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTelefono" promptText="8781234567" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <Label text="Correo" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtCorreo" promptText="contacto@negocio.mx" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                        <Label text="Sitio web" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtSitioWeb" promptText="www.negocio.mx" styleClass="cfg-field" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                        <Label text="RFC" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtRFC" promptText="XAXX010101000" styleClass="cfg-field" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                                    </GridPane>
                                </VBox>

                                <VBox spacing="14" styleClass="settings-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                                        <FontIcon iconLiteral="fas-map-marker-alt" iconSize="18" iconColor="#0b3b75"/>
                                        <VBox>
                                            <Label text="Ubicacion" styleClass="card-title"/>
                                            <Label text="Direccion fiscal o punto de atencion." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <Label text="Direccion" styleClass="field-label"/>
                                    <TextField fx:id="txtDireccion" promptText="Calle, numero, colonia" styleClass="cfg-field"/>
                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints><ColumnConstraints percentWidth="64"/><ColumnConstraints percentWidth="36"/></columnConstraints>
                                        <Label text="Ciudad" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtCiudad" promptText="Piedras Negras" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="CP" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtCP" promptText="26000" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                    </GridPane>
                                    <VBox spacing="8" styleClass="info-panel">
                                        <Label text="Guardado seguro" styleClass="option-title"/>
                                        <Label text="Estos datos se guardan en la tabla configuracion y tambien en Preferences como respaldo local." wrapText="true" styleClass="card-subtitle"/>
                                    </VBox>
                                </VBox>
                            </GridPane>
                        </VBox>

                        <VBox fx:id="panelFiscal" spacing="18" visible="false" managed="false">
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="section-heading">
                                <FontIcon iconLiteral="fas-file-invoice-dollar" iconSize="20" iconColor="#0b3b75"/>
                                <VBox>
                                    <Label text="Facturacion e impuestos" styleClass="section-title"/>
                                    <Label text="Base fiscal configurable para prefacturas, impuestos por producto y tickets." styleClass="section-subtitle"/>
                                </VBox>
                            </HBox>
                            <GridPane hgap="18" vgap="18" styleClass="card-grid">
                                <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>

                                <VBox spacing="14" styleClass="settings-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                                        <FontIcon iconLiteral="fas-id-card" iconSize="18" iconColor="#0b3b75"/>
                                        <VBox>
                                            <Label text="Datos fiscales del negocio" styleClass="card-title"/>
                                            <Label text="Informacion del emisor para facturacion mexicana." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
                                        <Label text="RFC negocio" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtFiscalRfc" promptText="XAXX010101000" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Codigo postal fiscal" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtFiscalCP" promptText="26000" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        <Label text="Razon social" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtFiscalRazonSocial" promptText="Razon social del negocio" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
                                        <Label text="Regimen fiscal" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                        <ComboBox fx:id="cmbFiscalRegimen" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="5" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
                                    </GridPane>
                                </VBox>

                                <VBox spacing="14" styleClass="settings-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                                        <FontIcon iconLiteral="fas-percentage" iconSize="18" iconColor="#0b3b75"/>
                                        <VBox>
                                            <Label text="Politica de impuestos" styleClass="card-title"/>
                                            <Label text="Las tasas se leen de la tabla impuestos, no desde calculos fijos." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
                                        <Label text="IVA predeterminado" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <ComboBox fx:id="cmbFiscalImpuestoDefault" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Region fiscal" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <ComboBox fx:id="cmbRegionFiscal" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                    </GridPane>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="inline-option">
                                        <VBox HBox.hgrow="ALWAYS">
                                            <Label text="Precio incluye impuesto" styleClass="option-title"/>
                                            <Label text="Si esta activo, el impuesto se desglosa desde el precio final." styleClass="card-subtitle"/>
                                        </VBox>
                                        <SwitchToggle fx:id="tglPrecioIncluyeImpuesto"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="inline-option">
                                        <VBox HBox.hgrow="ALWAYS">
                                            <Label text="Impuesto por producto" styleClass="option-title"/>
                                            <Label text="Permite que cada producto use una tasa fiscal distinta." styleClass="card-subtitle"/>
                                        </VBox>
                                        <SwitchToggle fx:id="tglImpuestoPorProducto"/>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="inline-option">
                                        <VBox HBox.hgrow="ALWAYS">
                                            <Label text="Mostrar desglose fiscal en ticket" styleClass="option-title"/>
                                            <Label text="Preferencia lista para TicketRenderer en la siguiente fase." styleClass="card-subtitle"/>
                                        </VBox>
                                        <SwitchToggle fx:id="tglMostrarDesgloseFiscal"/>
                                    </HBox>
                                </VBox>

                                <VBox spacing="14" styleClass="settings-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                                        <FontIcon iconLiteral="fas-file-signature" iconSize="18" iconColor="#0b3b75"/>
                                        <VBox>
                                            <Label text="Prefactura" styleClass="card-title"/>
                                            <Label text="Folios internos listos para integracion PAC futura." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints><ColumnConstraints percentWidth="32"/><ColumnConstraints percentWidth="34"/><ColumnConstraints percentWidth="34"/></columnConstraints>
                                        <Label text="Serie" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtSerieFactura" promptText="A" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Folio inicial" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtFolioInicial" promptText="1" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        <Label text="Modo" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                        <ComboBox fx:id="cmbModoFacturacion" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                                    </GridPane>
                                </VBox>

                                <VBox spacing="14" styleClass="settings-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                                        <FontIcon iconLiteral="fas-university" iconSize="18" iconColor="#0b3b75"/>
                                        <VBox>
                                            <Label text="Datos SAT predeterminados" styleClass="card-title"/>
                                            <Label text="Valores iniciales para ventas al publico o clientes sin datos completos." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <Label text="Uso CFDI default" styleClass="field-label"/>
                                    <ComboBox fx:id="cmbUsoCfdiDefault" maxWidth="Infinity" styleClass="cfg-combo"/>
                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
                                        <Label text="Metodo de pago SAT" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <ComboBox fx:id="cmbMetodoPagoSat" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Forma de pago SAT" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <ComboBox fx:id="cmbFormaPagoSat" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                    </GridPane>
                                </VBox>
                            </GridPane>
                        </VBox>

                        <VBox fx:id="panelTicket" spacing="18" visible="false" managed="false">
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="section-heading">
                                <FontIcon iconLiteral="fas-receipt" iconSize="20" iconColor="#0b3b75"/>
                                <VBox>
                                    <Label text="Tickets e impresion" styleClass="section-title"/>
                                    <Label text="Mantiene las mismas claves usadas por TicketService, TicketImpresora y TicketRenderer." styleClass="section-subtitle"/>
                                </VBox>
                            </HBox>
                            <GridPane hgap="18" vgap="18" styleClass="card-grid">
                                <columnConstraints><ColumnConstraints percentWidth="52"/><ColumnConstraints percentWidth="48"/></columnConstraints>
                                <VBox spacing="14" styleClass="settings-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                                        <FontIcon iconLiteral="fas-heading" iconSize="18" iconColor="#0b3b75"/>
                                        <VBox>
                                            <Label text="Encabezado del ticket" styleClass="card-title"/>
                                            <Label text="Datos impresos en la parte superior del comprobante." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
                                        <Label text="Nombre" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTicketNombre" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Giro" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtTicketGiro" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        <Label text="Direccion" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTicketDireccion" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <Label text="Ciudad" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtTicketCiudad" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                        <Label text="Telefono" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTicketTelefono" styleClass="cfg-field" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                    </GridPane>
                                    <Label text="Encabezado" styleClass="field-label"/>
                                    <TextArea fx:id="txtMensajeEncabezado" prefRowCount="2" styleClass="cfg-area"/>
                                </VBox>

                                <VBox spacing="14" styleClass="settings-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="card-header">
                                        <FontIcon iconLiteral="fas-print" iconSize="18" iconColor="#0b3b75"/>
                                        <VBox HBox.hgrow="ALWAYS">
                                            <Label text="Formato e impresora" styleClass="card-title"/>
                                            <Label text="Opciones visuales y salida termica." styleClass="card-subtitle"/>
                                        </VBox>
                                        <Button text="Vista previa" onAction="#abrirVistaPrevia" graphicTextGap="8" styleClass="secondary-button">
                                            <graphic><FontIcon iconLiteral="fas-eye" iconSize="13"/></graphic>
                                        </Button>
                                    </HBox>
                                    <Label text="Pie" styleClass="field-label"/>
                                    <TextArea fx:id="txtMensajePie" prefRowCount="3" styleClass="cfg-area"/>
                                    <Label text="Aviso" styleClass="field-label"/>
                                    <TextArea fx:id="txtAvisoFiscal" prefRowCount="2" styleClass="cfg-area"/>
                                    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="switch-row">
                                        <VBox spacing="5"><Label text="Logo" styleClass="field-label"/><SwitchToggle fx:id="tglLogoTicket"/></VBox>
                                        <VBox spacing="5"><Label text="Folio" styleClass="field-label"/><SwitchToggle fx:id="tglFolioTicket"/></VBox>
                                        <VBox spacing="5"><Label text="Desglose" styleClass="field-label"/><SwitchToggle fx:id="tglDesglose"/></VBox>
                                        <VBox spacing="5"><Label text="QR" styleClass="field-label"/><SwitchToggle fx:id="tglQR"/></VBox>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="inline-option">
                                        <VBox HBox.hgrow="ALWAYS">
                                            <Label text="Ticket por defecto en ventas" styleClass="option-title"/>
                                            <Label text="Al cobrar, deja seleccionada la opcion Generar e imprimir. Puede cambiarse en cada venta." wrapText="true" styleClass="card-subtitle"/>
                                        </VBox>
                                        <SwitchToggle fx:id="tglTicketPorDefecto"/>
                                    </HBox>
                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints><ColumnConstraints percentWidth="62"/><ColumnConstraints percentWidth="38"/></columnConstraints>
                                        <Label text="Impresora" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <ComboBox fx:id="cmbImpresora" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Ancho" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <ComboBox fx:id="cmbAnchoPapel" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                    </GridPane>
                                </VBox>
