<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controlador.ConfiguracionController"
            stylesheets="@menuPrincipal.css, @configuracion.css">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="230" style="-fx-background-color: #3D1F0D;">
            <VBox spacing="2" style="-fx-padding: 28 20 16 20;">
                <Label style="-fx-text-fill: #D4A843; -fx-font-size: 22px; -fx-font-weight: bold;" text="Volovan Volo"/>
                <Label style="-fx-text-fill: #C8A97E; -fx-font-size: 10px;" text="Sistema de Punto de Venta"/>
            </VBox>
            <Separator style="-fx-opacity: 0.2;"/>
            <HBox spacing="12" style="-fx-padding: 16 20;">
                <Label fx:id="lblAvatarIniciales"
                       style="-fx-background-color: #D4A843; -fx-text-fill: #864628; -fx-font-weight: bold;
                              -fx-font-size: 14px; -fx-min-width: 38; -fx-min-height: 38;
                              -fx-background-radius: 19; -fx-alignment: center;" text="--"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" text="Usuario"/>
                    <Label fx:id="lblRolUsuario"    style="-fx-text-fill: #C8A97E; -fx-font-size: 10px;" text="Rol"/>
                </VBox>
            </HBox>
            <Separator style="-fx-opacity: 0.2;"/>
            <VBox spacing="4" style="-fx-padding: 12;" VBox.vgrow="ALWAYS">
                <Label style="-fx-text-fill: #C8A97E; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 8 8 4 8;" text="PRINCIPAL"/>
                <Button prefHeight="40" prefWidth="206" onAction="#irADashboard" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Dashboard">
                    <graphic><FontIcon iconLiteral="fas-tachometer-alt" iconSize="16" iconColor="#C8A97E"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="206" onAction="#irAVentas" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Ventas / Caja">
                    <graphic><FontIcon iconLiteral="fas-shopping-cart" iconSize="16" iconColor="#C8A97E"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="206" onAction="#irAInventario" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Inventario">
                    <graphic><FontIcon iconLiteral="fas-box" iconSize="16" iconColor="#C8A97E"/></graphic>
                </Button>
                <Label style="-fx-text-fill: #C8A97E; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 12 8 4 8;" text="GESTION"/>
                <Button prefHeight="40" prefWidth="206" onAction="#irAEmpleados" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Empleados">
                    <graphic><FontIcon iconLiteral="fas-users" iconSize="16" iconColor="#C8A97E"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="206" onAction="#irAClientes" style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Clientes" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="16" iconColor="#C8A97E"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="206" onAction="#irAReportes" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Reportes">
                    <graphic><FontIcon iconLiteral="fas-chart-bar" iconSize="16" iconColor="#C8A97E"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="206" onAction="#irACorteCaja" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: #C8A97E; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Corte de Caja">
                    <graphic><FontIcon iconLiteral="fas-cash-register" iconSize="16" iconColor="#C8A97E"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="206" graphicTextGap="12"
                        style="-fx-background-color: #6B4226; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 15; -fx-cursor: hand;" text="Configuracion">
                    <graphic><FontIcon iconLiteral="fas-cog" iconSize="16" iconColor="white"/></graphic>
                </Button>
            </VBox>
            <Separator style="-fx-opacity: 0.2;"/>
            <Button onAction="#btnCerrar" prefHeight="44" prefWidth="230" graphicTextGap="10"
                    style="-fx-background-color: transparent; -fx-text-fill: #C0392B; -fx-cursor: hand;" text="Cerrar sesion">
                <graphic><FontIcon iconLiteral="fas-sign-out-alt" iconSize="16" iconColor="#C0392B"/></graphic>
            </Button>
        </VBox>
    </left>

    <!-- CONTENIDO -->
    <center>
        <VBox style="-fx-background-color: #F5EFE6;" prefWidth="960">

            <!-- Topbar -->
            <HBox alignment="CENTER_LEFT" styleClass="topbar" style="-fx-padding: 18 24; -fx-spacing: 12;">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Configuracion"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3D1F0D;"/>
                    <Label text="Administra los parametros generales del sistema"
                           style="-fx-font-size: 11px; -fx-text-fill: #7A5535;"/>
                </VBox>
                <Button text="Restablecer" onAction="#restablecerConfiguracion"
                        style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-border-color: #D4C5B0;
                               -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 20; -fx-cursor: hand; -fx-font-size: 12px;"/>
                <Button text="Guardar Cambios" onAction="#guardarConfiguracion"
                        style="-fx-background-color: #D4A843; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 9 20; -fx-cursor: hand; -fx-font-size: 12px;"/>
            </HBox>

            <!-- Barra de pestanas - sin Apariencia -->
            <HBox spacing="6" style="-fx-padding: 0 24 14 24; -fx-background-color: #F5EFE6;">
                <Button fx:id="btnTabNegocio"       text="Negocio"           onAction="#tabNegocio"
                        style="-fx-background-color: #6B4226; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand;"/>
                <Button fx:id="btnTabPOS"           text="POS / Caja"        onAction="#tabPOS"
                        style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand; -fx-border-color: #D4C5B0; -fx-border-radius: 20;"/>
                <Button fx:id="btnTabUsuarios"      text="Usuarios y Roles"  onAction="#tabUsuarios"
                        style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand; -fx-border-color: #D4C5B0; -fx-border-radius: 20;"/>
                <Button fx:id="btnTabFiscal"        text="Fiscal / Tickets"  onAction="#tabFiscal"
                        style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand; -fx-border-color: #D4C5B0; -fx-border-radius: 20;"/>
                <Button fx:id="btnTabIntegraciones" text="Integraciones"      onAction="#tabIntegraciones"
                        style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand; -fx-border-color: #D4C5B0; -fx-border-radius: 20;"/>
                <Button fx:id="btnTabBaseDatos"     text="Base de Datos"     onAction="#tabBaseDatos"
                        style="-fx-background-color: white; -fx-text-fill: #6B4226; -fx-background-radius: 20; -fx-padding: 6 16; -fx-cursor: hand; -fx-border-color: #D4C5B0; -fx-border-radius: 20;"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                <VBox style="-fx-padding: 0 24 24 24; -fx-spacing: 16;">

                    <!-- PANEL: NEGOCIO -->
                    <VBox fx:id="panelNegocio" spacing="16">
                        <HBox spacing="16">
                            <!-- Info General -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-store" iconSize="16" iconColor="#6B4226"/>
                                    <VBox>
                                        <Label text="Informacion General"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 13px;"/>
                                        <Label text="Datos principales del negocio"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <Label text="NOMBRE DEL NEGOCIO" styleClass="cfg-label"/>
                                <TextField fx:id="txtNombreNegocio" promptText="Ej. Volovan Volo" styleClass="cfg-field"/>
                                <Label text="SLOGAN / DESCRIPCION CORTA" styleClass="cfg-label"/>
                                <TextField fx:id="txtSlogan" promptText="Ej. El sabor de casa" styleClass="cfg-field"/>
                                <Label text="TELEFONO" styleClass="cfg-label"/>
                                <TextField fx:id="txtTelefono" promptText="878-123-4567" styleClass="cfg-field"/>
                                <Label text="CORREO ELECTRONICO" styleClass="cfg-label"/>
                                <TextField fx:id="txtCorreo" promptText="admin@negocio.mx" styleClass="cfg-field"/>
                                <Label text="SITIO WEB" styleClass="cfg-label"/>
                                <TextField fx:id="txtSitioWeb" promptText="www.negocio.mx" styleClass="cfg-field"/>
                            </VBox>

                            <!-- Regional -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-map-marker-alt" iconSize="16" iconColor="#6B4226"/>
                                    <VBox>
                                        <Label text="Configuracion Regional"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 13px;"/>
                                        <Label text="Ubicacion, moneda y zona horaria"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <Label text="DIRECCION" styleClass="cfg-label"/>
                                <TextField fx:id="txtDireccion" promptText="Calle, Num, Colonia" styleClass="cfg-field"/>
                                <HBox spacing="10">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="CIUDAD" styleClass="cfg-label"/>
                                        <TextField fx:id="txtCiudad" promptText="Ej. Piedras Negras" styleClass="cfg-field"/>
                                    </VBox>
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="C.P." styleClass="cfg-label"/>
                                        <TextField fx:id="txtCP" promptText="26000" styleClass="cfg-field"/>
                                    </VBox>
                                </HBox>
                                <Label text="RFC" styleClass="cfg-label"/>
                                <TextField fx:id="txtRFC" promptText="XAXX010101000" styleClass="cfg-field"/>
                                <Label text="MONEDA" styleClass="cfg-label"/>
                                <ComboBox fx:id="cmbMoneda" maxWidth="Infinity" styleClass="cfg-combo"/>
                                <Label text="ZONA HORARIA" styleClass="cfg-label"/>
                                <ComboBox fx:id="cmbZonaHoraria" maxWidth="Infinity" styleClass="cfg-combo"/>
                            </VBox>

                            <!-- Horario y Operacion -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-clock" iconSize="16" iconColor="#6B4226"/>
                                    <VBox>
                                        <Label text="Horario y Operacion"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 13px;"/>
                                        <Label text="Dias y horas de atencion"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <HBox spacing="10">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="HORA DE APERTURA" styleClass="cfg-label"/>
                                        <TextField fx:id="txtHoraApertura" promptText="08:00" styleClass="cfg-field"/>
                                    </VBox>
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="HORA DE CIERRE" styleClass="cfg-label"/>
                                        <TextField fx:id="txtHoraCierre" promptText="21:00" styleClass="cfg-field"/>
                                    </VBox>
                                </HBox>
                                <Label text="DIAS DE OPERACION" styleClass="cfg-label"/>
                                <HBox spacing="5">
                                    <ToggleButton fx:id="tglLun" text="L" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglMar" text="M" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglMie" text="X" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglJue" text="J" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglVie" text="V" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglSab" text="S" styleClass="dia-btn" selected="true"/>
                                    <ToggleButton fx:id="tglDom" text="D" styleClass="dia-btn"/>
                                </HBox>
                                <Separator/>
                                <Label text="LIMITE DE CREDITO INTERNO ($)" styleClass="cfg-label"/>
                                <TextField fx:id="txtLimiteCredito" promptText="Ej. 500.00" styleClass="cfg-field"/>
                                <Label text="NUMERO DE SUCURSAL / CAJA" styleClass="cfg-label"/>
                                <TextField fx:id="txtNumSucursal" promptText="Ej. 01 - Centro" styleClass="cfg-field"/>
                                <HBox alignment="CENTER_LEFT" spacing="12"
                                      style="-fx-background-color: #FDF8F2; -fx-padding: 10; -fx-background-radius: 8;">
                                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                                        <Label text="Modo mantenimiento"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;"/>
                                        <Label text="Bloquea acceso a cajeros"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                    <ToggleButton fx:id="tglMantenimiento"
                                                  style="-fx-background-color: #CCBBAA; -fx-background-radius: 12;
                                                         -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" text=""/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- PANEL: POS / CAJA -->
                    <VBox fx:id="panelPOS" spacing="16" visible="false" managed="false">
                        <HBox spacing="16">

                            <!-- Operacion de caja -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-cash-register" iconSize="16" iconColor="#6B4226"/>
                                    <VBox>
                                        <Label text="Operacion de Caja"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 13px;"/>
                                        <Label text="Comportamiento del punto de venta"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <Label text="METODO DE PAGO PREDETERMINADO" styleClass="cfg-label"/>
                                <ComboBox fx:id="cmbMetodoPago" maxWidth="Infinity" styleClass="cfg-combo"/>
                                <Label text="MONEDA DE REDONDEO" styleClass="cfg-label"/>
                                <ComboBox fx:id="cmbRedondeo" maxWidth="Infinity" styleClass="cfg-combo"/>
                                <HBox alignment="CENTER_LEFT" spacing="12"
                                      style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                                        <Label text="Requerir apertura de caja"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;"/>
                                        <Label text="Cajero debe registrar fondo inicial"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                    <ToggleButton fx:id="tglAperturaCaja" selected="true"
                                                  style="-fx-background-color: #D4A843; -fx-background-radius: 12;
                                                         -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" text=""/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12"
                                      style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                                        <Label text="Confirmar antes de cobrar"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;"/>
                                        <Label text="Pantalla de resumen previa al cobro"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                    <ToggleButton fx:id="tglConfirmarCobro" selected="true"
                                                  style="-fx-background-color: #D4A843; -fx-background-radius: 12;
                                                         -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" text=""/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12"
                                      style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                                        <Label text="Imprimir ticket automaticamente"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;"/>
                                        <Label text="No pregunta, imprime al cerrar venta"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                    <ToggleButton fx:id="tglAutoImprimir"
                                                  style="-fx-background-color: #CCBBAA; -fx-background-radius: 12;
                                                         -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" text=""/>
                                </HBox>
                            </VBox>

                            <!-- Productos y Busqueda -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
                                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;
                                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),8,0,0,2);">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-barcode" iconSize="16" iconColor="#6B4226"/>
                                    <VBox>
                                        <Label text="Productos y Busqueda"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 13px;"/>
                                        <Label text="Como se muestran y buscan los articulos"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <Label text="BUSQUEDA POR" styleClass="cfg-label"/>
                                <ComboBox fx:id="cmbBusqueda" maxWidth="Infinity" styleClass="cfg-combo"/>
                                <Label text="ORDEN DE PRODUCTOS EN CAJA" styleClass="cfg-label"/>
                                <ComboBox fx:id="cmbOrdenProductos" maxWidth="Infinity" styleClass="cfg-combo"/>
                                <HBox alignment="CENTER_LEFT" spacing="12"
                                      style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                                        <Label text="Mostrar imagen de producto en caja"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;"/>
                                        <Label text="Miniatura en cada articulo del carrito"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                    <ToggleButton fx:id="tglImagenesProducto" selected="true"
                                                  style="-fx-background-color: #D4A843; -fx-background-radius: 12;
                                                         -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" text=""/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12"
                                      style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                                        <Label text="Alertar stock bajo en caja"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;"/>
                                        <Label text="Aviso al agregar producto con poco inventario"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                    <ToggleButton fx:id="tglAlertaStock" selected="true"
                                                  style="-fx-background-color: #D4A843; -fx-background-radius: 12;
                                                         -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" text=""/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12"
                                      style="-fx-background-color: #FDF8F2; -fx-padding: 12; -fx-background-radius: 8;">
                                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                                        <Label text="Vender producto sin stock"
                                               style="-fx-font-weight: bold; -fx-text-fill: #3D1F0D; -fx-font-size: 12px;"/>
                                        <Label text="Permite vender aunque el inventario sea 0"
                                               style="-fx-text-fill: #7A5535; -fx-font-size: 10px;"/>
                                    </VBox>
                                    <ToggleButton fx:id="tglVentaSinStock"
                                                  style="-fx-background-color: #CCBBAA; -fx-background-radius: 12;
                                                         -fx-min-width: 44; -fx-min-height: 24; -fx-cursor: hand;" text=""/>
                                </HBox>
                            </VBox>

                            <!-- Ventas y Clientes -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS"
