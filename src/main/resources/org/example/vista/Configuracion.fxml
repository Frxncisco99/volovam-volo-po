<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.example.modelo.SwitchToggle?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@configuracion.css"
            fx:controller="org.example.controlador.ConfiguracionController">

    <left>
        <VBox prefWidth="232" styleClass="app-sidebar">
            <VBox spacing="4" styleClass="brand-block">
                <Label text="Volovan Volo" styleClass="sidebar-brand"/>
                <Label text="SISTEMA DE PUNTO DE VENTA" styleClass="sidebar-subtitle"/>
            </VBox>
            <Separator styleClass="sidebar-separator"/>
            <HBox spacing="10" styleClass="sidebar-user-box">
                <Label fx:id="lblAvatarIniciales" text="US" styleClass="sidebar-avatar"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" text="Usuario" styleClass="sidebar-user"/>
                    <Label fx:id="lblRolUsuario" text="Rol" styleClass="sidebar-role"/>
                </VBox>
            </HBox>
            <Separator styleClass="sidebar-separator"/>
            <VBox spacing="4" styleClass="main-menu" VBox.vgrow="ALWAYS">
                <Label text="PRINCIPAL" styleClass="sidebar-section"/>
                <Button text="Dashboard" onAction="#irADashboard" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-tachometer-alt" iconSize="15" iconColor="rgba(255,255,255,0.78)"/></graphic>
                </Button>
                <Button text="Ventas / Caja" onAction="#irAVentas" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-shopping-cart" iconSize="15" iconColor="rgba(255,255,255,0.78)"/></graphic>
                </Button>
                <Button text="Inventario" onAction="#irAInventario" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-box" iconSize="15" iconColor="rgba(255,255,255,0.78)"/></graphic>
                </Button>
                <Label text="GESTION" styleClass="sidebar-section"/>
                <Button text="Empleados" onAction="#irAEmpleados" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-users" iconSize="15" iconColor="rgba(255,255,255,0.78)"/></graphic>
                </Button>
                <Button text="Clientes" onAction="#irAClientes" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="15" iconColor="rgba(255,255,255,0.78)"/></graphic>
                </Button>
                <Button text="Reportes" onAction="#irAReportes" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-chart-bar" iconSize="15" iconColor="rgba(255,255,255,0.78)"/></graphic>
                </Button>
                <Button text="Corte de Caja" onAction="#irACorteCaja" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-cash-register" iconSize="15" iconColor="rgba(255,255,255,0.78)"/></graphic>
                </Button>
                <Button text="Auditoria" onAction="#irAAuditoria" graphicTextGap="12" styleClass="sidebar-button">
                    <graphic><FontIcon iconLiteral="fas-shield-alt" iconSize="15" iconColor="rgba(255,255,255,0.78)"/></graphic>
                </Button>
                <Button text="Configuracion" graphicTextGap="12" styleClass="sidebar-button-active">
                    <graphic><FontIcon iconLiteral="fas-cog" iconSize="15" iconColor="#0b1f3a"/></graphic>
                </Button>
            </VBox>
            <Separator styleClass="sidebar-separator"/>
            <Button text="Cerrar sesion" onAction="#btnCerrar" graphicTextGap="10" styleClass="sidebar-logout">
                <graphic><FontIcon iconLiteral="fas-sign-out-alt" iconSize="15" iconColor="#fecaca"/></graphic>
            </Button>
        </VBox>
    </left>

    <center>
        <VBox styleClass="config-root">
            <HBox alignment="CENTER_LEFT" styleClass="topbar">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Configuracion" styleClass="view-title"/>
                    <Label text="Ajustes principales del punto de venta" styleClass="view-subtitle"/>
                </VBox>
                <Label fx:id="lblFeedbackGuardado" text="" styleClass="save-feedback"/>
                <Button fx:id="btnGuardarCambios" text="Guardar cambios" onAction="#guardarConfiguracion" styleClass="primary-button"/>
            </HBox>

            <HBox VBox.vgrow="ALWAYS" styleClass="workspace">
                <VBox prefWidth="238" spacing="8" styleClass="config-tabs">
                    <Label text="SECCIONES" styleClass="nav-heading"/>
                    <Button fx:id="btnTabNegocio" text="Negocio" onAction="#tabNegocio" styleClass="cfg-tab-button"/>
                    <Button fx:id="btnTabTicket" text="Ticket" onAction="#tabTicket" styleClass="cfg-tab-button"/>
                    <Button fx:id="btnTabCajon" text="Cajon de dinero" onAction="#tabCajon" styleClass="cfg-tab-button"/>
                    <Button fx:id="btnTabEmail" text="Correo / Email" onAction="#tabEmail" styleClass="cfg-tab-button"/>
                    <Button fx:id="btnTabUsuarios" text="Usuarios" onAction="#tabUsuarios" styleClass="cfg-tab-button"/>
                    <Button fx:id="btnTabBaseDatos" text="Base de datos" onAction="#tabBaseDatos" styleClass="cfg-tab-button"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <VBox spacing="5" styleClass="nav-note">
                        <Label text="Cambios locales" styleClass="nav-note-title"/>
                        <Label text="Se guardan en BD y Preferences." wrapText="true" styleClass="nav-note-text"/>
                    </VBox>
                </VBox>

                <ScrollPane fitToWidth="true" styleClass="config-scroll" HBox.hgrow="ALWAYS">
                    <VBox spacing="16" styleClass="content-shell">

                        <VBox fx:id="panelNegocio" spacing="16">
                            <HBox spacing="16">
                                <VBox spacing="12" styleClass="settings-card" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <FontIcon iconLiteral="fas-store" iconSize="18" iconColor="#2563eb"/>
                                        <VBox>
                                            <Label text="Identidad del negocio" styleClass="card-title"/>
                                            <Label text="Datos visibles en reportes y referencias internas." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <GridPane hgap="14" vgap="10">
                                        <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
                                        <Label text="Nombre del negocio" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtNombreNegocio" promptText="Volovan Volo" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Slogan" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtSlogan" promptText="El sabor de casa" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        <Label text="Telefono" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTelefono" promptText="8781234567" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <Label text="Correo" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtCorreo" promptText="contacto@negocio.mx" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                        <Label text="Sitio web" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtSitioWeb" promptText="www.negocio.mx" styleClass="cfg-field" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                        <Label text="RFC" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtRFC" promptText="XAXX010101000" styleClass="cfg-field" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                                    </GridPane>
                                </VBox>
                                <VBox spacing="12" styleClass="settings-card" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <FontIcon iconLiteral="fas-map-marker-alt" iconSize="18" iconColor="#2563eb"/>
                                        <VBox>
                                            <Label text="Ubicacion" styleClass="card-title"/>
                                            <Label text="Direccion fiscal o de atencion." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <Label text="Direccion" styleClass="field-label"/>
                                    <TextField fx:id="txtDireccion" promptText="Calle, numero, colonia" styleClass="cfg-field"/>
                                    <GridPane hgap="14" vgap="10">
                                        <columnConstraints><ColumnConstraints percentWidth="65"/><ColumnConstraints percentWidth="35"/></columnConstraints>
                                        <Label text="Ciudad" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtCiudad" promptText="Piedras Negras" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Codigo postal" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtCP" promptText="26000" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                    </GridPane>
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox fx:id="panelTicket" spacing="16" visible="false" managed="false">
                            <HBox spacing="16">
                                <VBox spacing="12" styleClass="settings-card" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <FontIcon iconLiteral="fas-receipt" iconSize="18" iconColor="#2563eb"/>
                                        <VBox>
                                            <Label text="Encabezado del ticket" styleClass="card-title"/>
                                            <Label text="Mismas claves usadas por TicketService." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <GridPane hgap="14" vgap="10">
                                        <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
                                        <Label text="Nombre" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTicketNombre" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Giro" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtTicketGiro" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        <Label text="Direccion" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTicketDireccion" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <Label text="Ciudad" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtTicketCiudad" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                        <Label text="Telefono" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtTicketTelefono" styleClass="cfg-field" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                                    </GridPane>
                                    <Label text="Encabezado" styleClass="field-label"/>
                                    <TextArea fx:id="txtMensajeEncabezado" prefRowCount="2" styleClass="cfg-area"/>
                                </VBox>
                                <VBox spacing="12" styleClass="settings-card" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <FontIcon iconLiteral="fas-print" iconSize="18" iconColor="#2563eb"/>
                                        <VBox>
                                            <Label text="Impresion" styleClass="card-title"/>
                                            <Label text="Vista previa y opciones del layout." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <Label text="Pie" styleClass="field-label"/>
                                    <TextArea fx:id="txtMensajePie" prefRowCount="3" styleClass="cfg-area"/>
                                    <Label text="Aviso" styleClass="field-label"/>
                                    <TextArea fx:id="txtAvisoFiscal" prefRowCount="2" styleClass="cfg-area"/>
                                    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="switch-row">
                                        <VBox spacing="5"><Label text="Logo" styleClass="field-label"/><SwitchToggle fx:id="tglLogoTicket"/></VBox>
                                        <VBox spacing="5"><Label text="Folio" styleClass="field-label"/><SwitchToggle fx:id="tglFolioTicket"/></VBox>
                                        <VBox spacing="5"><Label text="Desglose" styleClass="field-label"/><SwitchToggle fx:id="tglDesglose"/></VBox>
                                        <VBox spacing="5"><Label text="QR" styleClass="field-label"/><SwitchToggle fx:id="tglQR"/></VBox>
                                    </HBox>
                                    <GridPane hgap="14" vgap="10">
                                        <columnConstraints><ColumnConstraints percentWidth="60"/><ColumnConstraints percentWidth="40"/></columnConstraints>
                                        <Label text="Impresora" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <ComboBox fx:id="cmbImpresora" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Ancho" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <ComboBox fx:id="cmbAnchoPapel" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                    </GridPane>
                                    <Button text="Vista previa" onAction="#abrirVistaPrevia" styleClass="secondary-button"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox fx:id="panelCajon" spacing="16" visible="false" managed="false">
                            <VBox spacing="14" styleClass="settings-card">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-cash-register" iconSize="18" iconColor="#2563eb"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label text="Cajon de dinero" styleClass="card-title"/>
                                        <Label text="Apertura automatica al completar una venta." styleClass="card-subtitle"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglCajonActivo"/>
                                </HBox>
                                <GridPane hgap="14" vgap="10">
                                    <columnConstraints><ColumnConstraints percentWidth="55"/><ColumnConstraints percentWidth="45"/></columnConstraints>
                                    <Label text="Puerto del cajon" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                    <ComboBox fx:id="cmbCajonPuerto" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                    <Label text="Pulso" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                    <ComboBox fx:id="cmbCajonPulso" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                </GridPane>
                                <Label text="Para impresoras termicas el cajon se abre enviando el comando ESC/POS a la misma impresora" styleClass="info-note"/>
                            </VBox>
                        </VBox>

                        <VBox fx:id="panelEmail" spacing="16" visible="false" managed="false">
                            <VBox spacing="14" styleClass="settings-card">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-envelope" iconSize="18" iconColor="#2563eb"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label text="Ticket por email" styleClass="card-title"/>
                                        <Label text="Configuracion SMTP para pruebas y envio de tickets." styleClass="card-subtitle"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglEmailActivo"/>
                                </HBox>
                                <GridPane hgap="14" vgap="10">
                                    <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
                                    <Label text="Proveedor SMTP" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                    <ComboBox fx:id="cmbEmailSmtp" maxWidth="Infinity" styleClass="cfg-combo" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                    <Label text="Remitente" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                    <TextField fx:id="txtEmailRemitente" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                    <Label text="Password / App Password" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                    <PasswordField fx:id="txtEmailPassword" styleClass="cfg-field" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                </GridPane>
                                <VBox fx:id="boxSmtpPersonalizado" spacing="10">
                                    <GridPane hgap="14" vgap="10">
                                        <columnConstraints><ColumnConstraints percentWidth="70"/><ColumnConstraints percentWidth="30"/></columnConstraints>
                                        <Label text="Servidor SMTP" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <TextField fx:id="txtEmailHost" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label text="Puerto" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <TextField fx:id="txtEmailPuerto" styleClass="cfg-field" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                    </GridPane>
                                </VBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="inline-option">
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label text="Reporte diario por correo" styleClass="option-title"/>
                                        <Label text="Guarda la preferencia para reportes diarios." styleClass="card-subtitle"/>
                                    </VBox>
                                    <SwitchToggle fx:id="tglEmailReporteDiario"/>
                                </HBox>
                                <Button text="Probar conexion" onAction="#probarCorreo" styleClass="secondary-button"/>
                            </VBox>
                        </VBox>

                        <VBox fx:id="panelUsuarios" spacing="16" visible="false" managed="false">
                            <VBox spacing="14" styleClass="settings-card">
                                <HBox alignment="CENTER_LEFT" spacing="12">
                                    <FontIcon iconLiteral="fas-user-shield" iconSize="18" iconColor="#2563eb"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label text="Usuarios" styleClass="card-title"/>
                                        <Label text="Gestion de accesos del punto de venta." styleClass="card-subtitle"/>
                                    </VBox>
                                    <Button text="Nuevo usuario" onAction="#agregarUsuario" styleClass="primary-button"/>
                                </HBox>
                                <TextField fx:id="txtBuscarUsuario" promptText="Buscar usuario, nombre o rol..." styleClass="cfg-field"/>
                                <TableView fx:id="tablaUsuarios" prefHeight="430">
                                    <columns>
                                        <TableColumn fx:id="colUsuarioNombre" text="Nombre" prefWidth="260"/>
                                        <TableColumn fx:id="colUsuarioRol" text="Rol" prefWidth="140"/>
                                        <TableColumn fx:id="colUsuarioEstado" text="Estado" prefWidth="120"/>
                                        <TableColumn fx:id="colUsuarioAcciones" text="Acciones" prefWidth="290"/>
                                    </columns>
                                </TableView>
                            </VBox>
                        </VBox>

                        <VBox fx:id="panelBaseDatos" spacing="16" visible="false" managed="false">
                            <HBox spacing="16">
                                <VBox spacing="14" styleClass="settings-card" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <FontIcon iconLiteral="fas-database" iconSize="18" iconColor="#2563eb"/>
                                        <VBox>
                                            <Label text="Estado de conexion" styleClass="card-title"/>
                                            <Label text="Solo lectura de la conexion actual." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <GridPane hgap="14" vgap="12">
                                        <columnConstraints><ColumnConstraints percentWidth="35"/><ColumnConstraints percentWidth="65"/></columnConstraints>
                                        <Label text="Estado" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                        <Label fx:id="lblEstadoDB" text="Sin conexion" styleClass="cfg-status" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                        <Label text="Host actual" styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                        <Label fx:id="lblDBHost" text="localhost:3306" styleClass="value-label" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                        <Label text="Base de datos" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                        <Label fx:id="lblDBNombre" text="pospanaderia" styleClass="value-label" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                        <Label text="Version" styleClass="field-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                                        <Label fx:id="lblDBVersion" text="No disponible" styleClass="value-label" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                                    </GridPane>
                                    <Button text="Probar conexion" onAction="#probarConexionDB" styleClass="secondary-button"/>
                                </VBox>
                                <VBox spacing="14" styleClass="settings-card" HBox.hgrow="ALWAYS">
                                    <HBox alignment="CENTER_LEFT" spacing="12">
                                        <FontIcon iconLiteral="fas-file-export" iconSize="18" iconColor="#2563eb"/>
                                        <VBox>
                                            <Label text="Respaldo SQL" styleClass="card-title"/>
                                            <Label text="Exporta un dump con mysqldump." styleClass="card-subtitle"/>
                                        </VBox>
                                    </HBox>
                                    <Label text="Carpeta destino" styleClass="field-label"/>
                                    <HBox spacing="8">
                                        <TextField fx:id="txtRutaRespaldo" promptText="C:/Respaldos/POS" styleClass="cfg-field" HBox.hgrow="ALWAYS"/>
                                        <Button text="..." onAction="#seleccionarCarpetaRespaldo" styleClass="ghost-button"/>
                                    </HBox>
                                    <Button text="Exportar respaldo SQL" onAction="#exportarRespaldo" styleClass="primary-button"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </HBox>
        </VBox>
    </center>
</BorderPane>
