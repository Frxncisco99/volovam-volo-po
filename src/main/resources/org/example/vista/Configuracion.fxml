                                    </VBox>
                                    <SwitchToggle fx:id="tglEmailActivo"/>
                                </HBox>
                                <GridPane hgap="14" vgap="12">
                                    <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
