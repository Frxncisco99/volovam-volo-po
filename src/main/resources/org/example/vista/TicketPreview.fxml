<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<!--
    Ventana modal de vista previa. El papel y txtTicketRender conservan
    medidas, fuente y formato para no alterar el ticket renderizado.
-->
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controlador.TicketPreviewController"
      stylesheets="@menuPrincipal.css"
      styleClass="ticket-preview-root"
      prefWidth="360"
      prefHeight="820"
      minWidth="360"
      maxWidth="360"
      spacing="0">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="ticket-preview-header">

        <StackPane minWidth="36" minHeight="36" maxWidth="36" maxHeight="36"
                   styleClass="ticket-preview-icon-shell">
            <FontIcon iconLiteral="fas-receipt" iconSize="15" iconColor="#1a6fa8"/>
        </StackPane>

        <VBox HBox.hgrow="ALWAYS" spacing="3">
            <Label styleClass="ticket-preview-title" text="Vista previa del ticket"/>
            <Label styleClass="ticket-preview-subtitle" text="Ticket de prueba"/>
        </VBox>

        <Label styleClass="ticket-preview-badge" text="EJEMPLO"/>
    </HBox>

    <!-- ZONA DE SCROLL: el ticket se mantiene al centro dentro de un card externo -->
    <ScrollPane fitToWidth="true"
                fitToHeight="true"
                pannable="true"
                VBox.vgrow="ALWAYS"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                styleClass="ticket-preview-scroll">

        <StackPane styleClass="ticket-preview-canvas">

            <VBox alignment="TOP_CENTER" styleClass="ticket-preview-card">

                <!-- Soporte visual externo: no altera el ticket renderizado -->
                <Region prefHeight="4" prefWidth="226" styleClass="ticket-preview-cap-top"/>

                <HBox minWidth="220" maxWidth="220" alignment="CENTER"
                      styleClass="ticket-preview-perforation">
                    <Label maxWidth="Infinity" HBox.hgrow="ALWAYS"
                           styleClass="ticket-preview-perforation-label"
                           text="^v^v^v^v^v^v^v^v^v^v^v^v^v^v^v^v^"/>
                </HBox>

                <!-- PAPEL: medidas y formato conservados -->
                <VBox minWidth="220" maxWidth="220" prefWidth="220"
                      styleClass="ticket-preview-paper">

                    <TextArea fx:id="txtTicketRender"
                              editable="false"
                              wrapText="false"
                              prefWidth="220"
                              prefHeight="620"
                              styleClass="ticket-render-text"/>
                </VBox>

                <HBox minWidth="220" maxWidth="220" alignment="CENTER"
                      styleClass="ticket-preview-perforation">
                    <Label maxWidth="Infinity" HBox.hgrow="ALWAYS"
                           styleClass="ticket-preview-perforation-label"
                           text="^v^v^v^v^v^v^v^v^v^v^v^v^v^v^v^v^"/>
                </HBox>

                <Region prefHeight="6" prefWidth="200" styleClass="ticket-preview-cap-bottom"/>
            </VBox>
        </StackPane>
    </ScrollPane>

    <!-- FOOTER -->
    <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="ticket-preview-footer">

        <Button prefHeight="38"
                HBox.hgrow="ALWAYS"
                maxWidth="Infinity"
                onAction="#handleImprimir"
                graphicTextGap="8"
                styleClass="ticket-preview-print-button"
                text="Imprimir ticket">
            <graphic>
                <FontIcon iconLiteral="fas-print" iconSize="14" iconColor="white"/>
            </graphic>
        </Button>

        <Button prefHeight="38"
                prefWidth="96"
                onAction="#handleCerrar"
                styleClass="ticket-preview-close-button"
                text="Cerrar"/>
    </HBox>
</VBox>
