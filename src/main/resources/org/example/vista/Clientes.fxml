<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@menuPrincipal.css"
            styleClass="clientes-root"
            fx:controller="org.example.controlador.ClientesController">
    <left>
        <VBox prefWidth="230" styleClass="clientes-sidebar">
            <VBox spacing="3" styleClass="clientes-brand-block">
                <Label styleClass="clientes-brand-title" text="Volovan Volo"/>
                <Label styleClass="clientes-brand-subtitle" text="SISTEMA DE PUNTO DE VENTA"/>
            </VBox>
            <Separator styleClass="clientes-divider"/>
            <HBox spacing="10" styleClass="clientes-profile-row">
                <Label fx:id="lblAvatarIniciales" styleClass="clientes-sidebar-avatar" text="US"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" styleClass="clientes-profile-name" text="Usuario"/>
                    <Label fx:id="lblRolUsuario" styleClass="clientes-profile-role" text="Rol"/>
                </VBox>
            </HBox>
            <Separator styleClass="clientes-divider"/>
            <VBox spacing="3" styleClass="clientes-nav-container" VBox.vgrow="ALWAYS">
                <Label styleClass="clientes-nav-heading" text="PRINCIPAL"/>
                <Button prefHeight="40" prefWidth="210" onAction="#irADashboard" text="Dashboard" graphicTextGap="12"
                        styleClass="clientes-nav-button">
                    <graphic><FontIcon iconLiteral="fas-tachometer-alt" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAVentas" text="Ventas / Caja" graphicTextGap="12"
                        styleClass="clientes-nav-button">
                    <graphic><FontIcon iconLiteral="fas-shopping-cart" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAInventario" text="Inventario" graphicTextGap="12"
                        styleClass="clientes-nav-button">
                    <graphic><FontIcon iconLiteral="fas-box" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Label styleClass="clientes-nav-heading" text="GESTION"/>
                <Button prefHeight="40" prefWidth="210" onAction="#irAEmpleados" text="Empleados" graphicTextGap="12"
                        styleClass="clientes-nav-button">
                    <graphic><FontIcon iconLiteral="fas-users" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" text="Clientes" graphicTextGap="12"
                        styleClass="clientes-nav-button-active">
                    <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="16" iconColor="#1a6fa8"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAReportes" text="Reportes" graphicTextGap="12"
                        styleClass="clientes-nav-button">
                    <graphic><FontIcon iconLiteral="fas-chart-bar" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irACorteCaja" text="Corte de Caja" graphicTextGap="12"
                        styleClass="clientes-nav-button">
                    <graphic><FontIcon iconLiteral="fas-cash-register" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAAuditoria" text="Auditoria" graphicTextGap="12"
                        styleClass="clientes-nav-button">
                    <graphic><FontIcon iconLiteral="fas-shield-alt" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAConfiguracion" text="Configuracion" graphicTextGap="12"
                        styleClass="clientes-nav-button">
                    <graphic><FontIcon iconLiteral="fas-cog" iconSize="16" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>
            </VBox>
            <Separator styleClass="clientes-divider"/>
            <Button onAction="#btnCerrar" prefHeight="44" prefWidth="230" text="Cambiar sesion" graphicTextGap="10"
                    styleClass="clientes-session-button">
                <graphic><FontIcon iconLiteral="fas-exchange-alt" iconSize="16" iconColor="#f87171"/></graphic>
            </Button>
        </VBox>
    </left>

    <center>
        <VBox styleClass="clientes-page">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="clientes-topbar">
                <VBox spacing="2">
                    <Label styleClass="clientes-title" text="Clientes"/>
                    <Label fx:id="lblConteoActivos" styleClass="clientes-subtitle" text="0 clientes activos"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtBuscar" promptText="Buscar por nombre o telefono..." prefWidth="300"
                           styleClass="clientes-search-field"/>
                <Button onAction="#handleNuevoCliente" text="Nuevo cliente" graphicTextGap="8"
                        styleClass="clientes-primary-button">
                    <graphic><FontIcon iconLiteral="fas-plus" iconSize="14" iconColor="white"/></graphic>
                </Button>
            </HBox>

            <VBox spacing="16" styleClass="clientes-content" VBox.vgrow="ALWAYS">
                <HBox spacing="14">
                    <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                          styleClass="clientes-stat-card">
                        <Label styleClass="clientes-stat-icon-blue">
                            <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="16" iconColor="#1a6fa8"/></graphic>
                        </Label>
                        <VBox>
                            <Label styleClass="clientes-stat-label" text="TOTAL CLIENTES"/>
                            <Label fx:id="lblStatTotal" styleClass="clientes-stat-value-main" text="0"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                          styleClass="clientes-stat-card">
                        <Label styleClass="clientes-stat-icon-red">
                            <graphic><FontIcon iconLiteral="fas-dollar-sign" iconSize="16" iconColor="#c0392b"/></graphic>
                        </Label>
                        <VBox>
                            <Label styleClass="clientes-stat-label" text="TOTAL ADEUDO"/>
                            <Label fx:id="lblStatAdeudo" styleClass="clientes-stat-value-red" text="\$0.00"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="12" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS"
                          styleClass="clientes-stat-card">
                        <Label styleClass="clientes-stat-icon-orange">
                            <graphic><FontIcon iconLiteral="fas-exclamation-circle" iconSize="16" iconColor="#d97706"/></graphic>
                        </Label>
                        <VBox>
                            <Label styleClass="clientes-stat-label" text="CON SALDO"/>
                            <Label fx:id="lblStatConSaldo" styleClass="clientes-stat-value-orange" text="0"/>
                        </VBox>
                    </HBox>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            styleClass="clientes-scroll">
                    <FlowPane fx:id="flowClientes" hgap="16" vgap="16"
                              styleClass="clientes-flow"/>
                </ScrollPane>
            </VBox>
        </VBox>
    </center>
</BorderPane>
