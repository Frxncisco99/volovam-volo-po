<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@menuPrincipal.css"
            fx:controller="org.example.controlador.ClientesController">

    <left>
        <VBox prefWidth="230" style="-fx-background-color: #091e4e;">
            <VBox spacing="3" style="-fx-padding: 24 18 16 18;">
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Volovan Volo"/>
                <Label style="-fx-text-fill: rgba(255,255,255,0.55); -fx-font-size: 9px;" text="SISTEMA DE PUNTO DE VENTA"/>
            </VBox>
            <Separator style="-fx-opacity: 0.15;"/>
            <HBox spacing="10" style="-fx-padding: 14 18;">
                <Label fx:id="lblAvatarIniciales" style="-fx-background-color: rgba(255,255,255,0.22);                               -fx-text-fill: white;                               -fx-font-weight: bold;                               -fx-font-size: 13px;                               -fx-min-width: 36; -fx-min-height: 36;                               -fx-background-radius: 18;                               -fx-alignment: center;" text="AD" />
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Usuario" />
                    <Label fx:id="lblRolUsuario" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 10px;" text="Rol" />
                </VBox>
            </HBox>
            <Separator style="-fx-opacity: 0.15;"/>
            <VBox spacing="3" style="-fx-padding: 10 10;" VBox.vgrow="ALWAYS">
                <Label style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 8 8 3 8;" text="PRINCIPAL"/>
                <Button prefHeight="40" prefWidth="210" onAction="#irADashboard" text="Dashboard" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.82); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;">
                    <graphic><FontIcon iconLiteral="fas-tachometer-alt" iconSize="16" iconColor="rgba(255,255,255,0.82)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAVentas" text="Ventas / Caja" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.82); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;">
                    <graphic><FontIcon iconLiteral="fas-shopping-cart" iconSize="16" iconColor="rgba(255,255,255,0.82)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAInventario" text="Inventario" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.82); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;">
                    <graphic><FontIcon iconLiteral="fas-box" iconSize="16" iconColor="rgba(255,255,255,0.82)"/></graphic>
                </Button>
                <Label style="-fx-text-fill: rgba(255,255,255,0.38); -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 12 8 3 8;" text="GESTION"/>
                <Button prefHeight="40" prefWidth="210" onAction="#irAEmpleados" text="Empleados" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.82); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;">
                    <graphic><FontIcon iconLiteral="fas-users" iconSize="16" iconColor="rgba(255,255,255,0.82)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" text="Clientes" graphicTextGap="12"
                        style="-fx-background-color: white; -fx-text-fill: #2563eb; -fx-font-weight: bold; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14;">
                    <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="16" iconColor="#2563eb"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAReportes" text="Reportes" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.82); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;">
                    <graphic><FontIcon iconLiteral="fas-chart-bar" iconSize="16" iconColor="rgba(255,255,255,0.82)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irACorteCaja" text="Corte de Caja" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.82); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;">
                    <graphic><FontIcon iconLiteral="fas-cash-register" iconSize="16" iconColor="rgba(255,255,255,0.82)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAAuditoria" text="Auditoria" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.82); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;">
                    <graphic><FontIcon iconLiteral="fas-shield-alt" iconSize="16" iconColor="rgba(255,255,255,0.82)"/></graphic>
                </Button>
                <Button prefHeight="40" prefWidth="210" onAction="#irAConfiguracion" text="Configuracion" graphicTextGap="12"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.82); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;">
                    <graphic><FontIcon iconLiteral="fas-cog" iconSize="16" iconColor="rgba(255,255,255,0.82)"/></graphic>
                </Button>
            </VBox>
            <Separator style="-fx-opacity: 0.15;"/>
            <Button onAction="#btnCerrar" prefHeight="44" prefWidth="230" text="Cambiar sesion" graphicTextGap="10"
                    style="-fx-background-color: transparent; -fx-text-fill: #fecaca; -fx-cursor: hand;">
                <graphic><FontIcon iconLiteral="fas-exchange-alt" iconSize="16" iconColor="#f87171"/></graphic>
            </Button>
        </VBox>
    </left>

    <center>
        <VBox style="-fx-background-color: #eef4fb;">
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 16 24; -fx-effect: dropshadow(gaussian, #0f172a18, 10, 0, 0, 2);">
                <VBox spacing="2">
                    <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="Clientes"/>
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #64748b;" text="Credito, abonos, historial y estado de cuenta"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button onAction="#handleNuevoCliente" text="Nuevo cliente" graphicTextGap="8"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 9 16; -fx-cursor: hand; -fx-font-weight: bold;">
                    <graphic><FontIcon iconLiteral="fas-plus" iconSize="14" iconColor="white"/></graphic>
                </Button>
            </HBox>

            <VBox spacing="14" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="txtBuscar" promptText="Buscar por nombre o telefono..." HBox.hgrow="ALWAYS"
                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1; -fx-border-width: 1; -fx-padding: 10 14; -fx-font-size: 13px; -fx-background-color: white;"/>
                    <Label style="-fx-background-color: #e0f2fe; -fx-text-fill: #075985; -fx-background-radius: 12; -fx-padding: 7 12; -fx-font-size: 11px; -fx-font-weight: bold;" text="ABONOS ENTRAN A CAJA"/>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="listaClientes" spacing="10" style="-fx-padding: 2;"/>
                </ScrollPane>
            </VBox>
        </VBox>
    </center>
</BorderPane>
