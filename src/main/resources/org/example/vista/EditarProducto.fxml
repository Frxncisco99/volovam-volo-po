<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" alignment="CENTER"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controlador.EditarProductoController"
      style="-fx-background-color: #F5F0E8;"
      prefHeight="520" prefWidth="360">

   
    <VBox style="-fx-background-color: #3D1C02; -fx-padding: 20 24 18 24;" spacing="3">
        <Label text="Editar Producto"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FDF0D5;" />
        <Label text="Modificar datos del inventario · Volovan Volo"
               style="-fx-font-size: 11px; -fx-text-fill: #A07848;" />
    </VBox>


    <VBox spacing="12" style="-fx-padding: 22 24 18 24; -fx-background-color: #FDF8F0;"
          VBox.vgrow="ALWAYS">

        <Label text="INFORMACIÓN GENERAL"
               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #A07848;
                      -fx-padding: 0 0 4 0; -fx-border-color: #E8D8C4; -fx-border-width: 0 0 1 0;" />

        <TextField fx:id="txtNombre" promptText="Nombre del producto"
                   style="-fx-background-color: white; -fx-border-color: #D4B896;
                          -fx-border-radius: 7; -fx-background-radius: 7;
                          -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #3A1F06;
                          -fx-prompt-text-fill: #BBA07A;" maxWidth="Infinity" />

        <HBox spacing="10">
            <TextField fx:id="txtPrecio" promptText="Precio  ($)"
                       style="-fx-background-color: white; -fx-border-color: #D4B896;
                              -fx-border-radius: 7; -fx-background-radius: 7;
                              -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #3A1F06;
                              -fx-prompt-text-fill: #BBA07A;"
                       HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtCosto" promptText="Costo  ($)"
                       style="-fx-background-color: white; -fx-border-color: #D4B896;
                              -fx-border-radius: 7; -fx-background-radius: 7;
                              -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #3A1F06;
                              -fx-prompt-text-fill: #BBA07A;"
                       HBox.hgrow="ALWAYS" />
        </HBox>

        <HBox spacing="10">
            <TextField fx:id="txtStock" promptText="Cantidad en stock"
                       style="-fx-background-color: white; -fx-border-color: #D4B896;
                              -fx-border-radius: 7; -fx-background-radius: 7;
                              -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #3A1F06;
                              -fx-prompt-text-fill: #BBA07A;"
                       HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtStockMinimo" promptText="Stock mínimo"
                       style="-fx-background-color: white; -fx-border-color: #D4B896;
                              -fx-border-radius: 7; -fx-background-radius: 7;
                              -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #3A1F06;
                              -fx-prompt-text-fill: #BBA07A;"
                       HBox.hgrow="ALWAYS" />
        </HBox>

        <ComboBox fx:id="cbCategoria" promptText="Categoría"
                  style="-fx-background-color: white; -fx-border-color: #D4B896;
                         -fx-border-radius: 7; -fx-background-radius: 7;
                         -fx-font-size: 13px; -fx-text-fill: #3A1F06;
                         -fx-padding: 2 4;"
                  maxWidth="Infinity" />

        <!--CODIGO DE BARRAS-->
        <Label text="CÓDIGO DE BARRAS"
               style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #A07848;
                      -fx-padding: 4 0 4 0; -fx-border-color: #E8D8C4; -fx-border-width: 0 0 1 0;" />

        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="¿Lleva código de barras?"
                   style="-fx-font-size: 12px; -fx-text-fill: #5A3A1A;" />
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnToggleCodigo" text="No lleva" onAction="#toggleCodigo"
                    style="-fx-background-color: #D4B896; -fx-text-fill: #5A3A1A;
                           -fx-background-radius: 20; -fx-padding: 5 16;
                           -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;" />
        </HBox>

        <HBox fx:id="hboxCodigo" spacing="8" alignment="CENTER_LEFT" visible="false" managed="false">
            <TextField fx:id="txtCodigoBarras" promptText="Escanea o escribe el código"
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-border-color: #D4A843;
                              -fx-border-radius: 7; -fx-background-radius: 7;
                              -fx-padding: 9 12; -fx-font-size: 13px; -fx-text-fill: #3A1F06;
                              -fx-prompt-text-fill: #BBA07A;" />
            <Button text="✕" onAction="#limpiarCodigo"
                    style="-fx-background-color: transparent; -fx-text-fill: #C0392B;
                           -fx-font-size: 14px; -fx-cursor: hand; -fx-font-weight: bold;" />
        </HBox>

    </VBox>


    <HBox spacing="10" style="-fx-padding: 14 24 20 24; -fx-background-color: #FAF4EA;
                               -fx-border-color: #E8D8C4; -fx-border-width: 1 0 0 0;"
          alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#cancelar"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: #C4A070;
                       -fx-border-radius: 7; -fx-background-radius: 7;
                       -fx-text-fill: #7A4E28; -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 8 0; -fx-cursor: hand;" />
        <Button text="Guardar cambios" onAction="#guardarCambios"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                style="-fx-background-color: #3D8040; -fx-text-fill: white;
                       -fx-background-radius: 7; -fx-border-radius: 7;
                       -fx-font-size: 13px; -fx-font-weight: bold;
                       -fx-padding: 8 0; -fx-cursor: hand;" />
    </HBox>

</VBox>
