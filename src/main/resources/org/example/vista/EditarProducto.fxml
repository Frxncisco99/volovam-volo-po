<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" alignment="CENTER"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controlador.EditarProductoController"
      style="-fx-padding: 24; -fx-background-color: white;"
      prefHeight="380" prefWidth="320">

    <Label text="Editar Producto"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #6B4226;" />

    <TextField fx:id="txtNombre"   promptText="Nombre" />
    <TextField fx:id="txtPrecio"   promptText="Precio" />
    <TextField fx:id="txtCosto"    promptText="Costo" />
    <TextField fx:id="txtStock"    promptText="Stock" />
    <ComboBox  fx:id="cbCategoria" promptText="Categoría" maxWidth="Infinity" />

    <Button text="Guardar cambios" onAction="#guardarCambios"
            maxWidth="Infinity"
            style="-fx-background-color: #6B4226; -fx-text-fill: white;
                   -fx-background-radius: 8; -fx-padding: 8 0; -fx-font-weight: bold;" />

    <Button text="Cancelar" onAction="#cancelar"
            maxWidth="Infinity"
            style="-fx-background-radius: 8; -fx-padding: 8 0;" />

</VBox>