<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controlador.CorteCajaController">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="198" style="-fx-background-color: #091e4e;">

            <VBox spacing="3" style="-fx-padding: 24 18 16 18;">
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Volovan Volo"/>
                <Label style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 9px;" text="SISTEMA DE PUNTO DE VENTA"/>
            </VBox>

            <Separator style="-fx-opacity: 0.15;"/>

            <HBox spacing="10" style="-fx-padding: 14 18;">
                <Label fx:id="lblAvatarIniciales"
                       style="-fx-background-color: rgba(255,255,255,0.22); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-min-width: 36; -fx-min-height: 36; -fx-background-radius: 18; -fx-alignment: center;"
                       text="AD"/>
                <VBox spacing="2">
                    <Label fx:id="lblNombreUsuario" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="Usuario"/>
                    <Label fx:id="lblRolUsuario" style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 10px;" text="Rol"/>
                </VBox>
            </HBox>

            <Separator style="-fx-opacity: 0.15;"/>

            <VBox spacing="3" style="-fx-padding: 10 10;" VBox.vgrow="ALWAYS">

                <Label style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 8 8 3 8;" text="PRINCIPAL"/>

                <Button prefHeight="40" prefWidth="210" onAction="#irADashboard"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Dashboard" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-tachometer-alt" iconSize="15" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button prefHeight="40" prefWidth="210" onAction="#irAVentas"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Ventas / Caja" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-shopping-cart" iconSize="15" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button graphicTextGap="12" onAction="#irAInventario" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Inventario">
                    <graphic><FontIcon iconLiteral="fas-box" iconSize="15" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Label style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 12 8 3 8;" text="GESTION"/>

                <Button prefHeight="40" prefWidth="210" onAction="#irAEmpleados"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Empleados" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-users" iconSize="15" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button prefHeight="40" prefWidth="210" onAction="#irAClientes"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Clientes" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-user-friends" iconSize="15" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

                <Button onAction="#irAReportes" graphicTextGap="12" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Reportes">
                    <graphic><FontIcon iconColor="rgba(255,255,255,0.8)" iconLiteral="fas-chart-bar" iconSize="15"/></graphic>
                </Button>

                <!-- Activo -->
                <Button prefHeight="40" prefWidth="210"
                        style="-fx-background-color: white; -fx-text-fill: #1a6fa8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Corte de Caja" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-cash-register" iconSize="15" iconColor="#1a6fa8"/></graphic>
                </Button>

                <Button onAction="#irAConfiguracion" prefHeight="40" prefWidth="210"
                        style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.8); -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 14; -fx-cursor: hand;"
                        text="Configuracion" graphicTextGap="12">
                    <graphic><FontIcon iconLiteral="fas-cog" iconSize="15" iconColor="rgba(255,255,255,0.8)"/></graphic>
                </Button>

            </VBox>

            <Separator style="-fx-opacity: 0.15;"/>

            <Button onAction="#btnCerrar" prefHeight="44" prefWidth="230"
                    style="-fx-background-color: transparent; -fx-text-fill: rgba(255,180,180,0.9); -fx-cursor: hand;"
                    text="Cerrar sesion" graphicTextGap="10">
                <graphic><FontIcon iconLiteral="fas-sign-out-alt" iconSize="15" iconColor="#ff0000e5"/></graphic>
            </Button>

        </VBox>
    </left>

    <!-- CENTRO -->
    <center>
        <VBox style="-fx-background-color: #f0f7ff;">

            <!-- TOPBAR -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color: white; -fx-padding: 14 24; -fx-effect: dropshadow(gaussian, #1a6fa815, 8, 0, 0, 2);">
                <VBox spacing="2">
                    <Label style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Corte de Caja"/>
                    <Label fx:id="lblFechaHoy" style="-fx-font-size: 11px; -fx-text-fill: #6a96b8;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblIdCaja" style="-fx-text-fill: #6a96b8; -fx-font-size: 12px; -fx-padding: 0 16 0 0;" text="Caja #0"/>
                <Label style="-fx-background-color: #e0f5e9; -fx-text-fill: #1e7d3e; -fx-background-radius: 10; -fx-padding: 4 12; -fx-font-size: 11px;" text="Caja abierta"/>
            </HBox>

            <!-- RESUMEN CARDS -->
            <HBox spacing="12" style="-fx-padding: 16 20 0 20;">
                <VBox spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="CAJERO"/>
                    <Label fx:id="lblCajero" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="---"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="APERTURA"/>
                    <Label fx:id="lblHoraApertura" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="---"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="FONDO INICIAL"/>
                    <Label fx:id="lblFondoInicial" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="\$0.00"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 10px;" text="NO. TICKETS"/>
                    <Label fx:id="lblNumTickets" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="0"/>
                </VBox>
            </HBox>

            <!-- TABS -->
            <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"
                     style="-fx-padding: 12 20 0 20; -fx-background-color: transparent; -fx-tab-min-height: 36px;">

                <!-- TAB corte actual -->
                <Tab text="Corte Actual">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <VBox spacing="14" style="-fx-padding: 16 4 20 4;">

                            <!-- Resumen ventas -->
                            <VBox spacing="10"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Resumen de ventas"/>
                                <Separator/>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 13px;" text="Total ventas (todos los métodos):"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblTotalEfectivo" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="\$0.00"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 13px;" text="Entradas a caja:"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblTotalEntradas" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3B6D11;" text="\$0.00"/>
                                </HBox>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 13px;" text="Salidas de caja:"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblTotalSalidas" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #C0392B;" text="\$0.00"/>
                                </HBox>
                                <Separator/>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Dinero esperado en caja:"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblDineroEsperado" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="\$0.00"/>
                                </HBox>
                            </VBox>

                            <!-- Conteo -->
                            <VBox spacing="10"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Conteo fisico de efectivo"/>
                                <Separator/>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 13px;" text="Dinero contado:"/>
                                    <TextField fx:id="txtDineroContado" promptText="0.00" prefWidth="200"
                                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 1.2; -fx-padding: 8; -fx-font-size: 14px;"/>
                                </HBox>
                                <Separator/>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-font-size: 13px; -fx-text-fill: #6a96b8;" text="Diferencia:"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblDiferencia" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="\$0.00"/>
                                </HBox>
                                <Label fx:id="lblEstadoDiferencia" style="-fx-font-size: 12px; -fx-font-weight: bold;" text=""/>
                            </VBox>

                            <!-- Observaciones -->
                            <VBox spacing="8"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Observaciones"/>
                                <Label fx:id="lblObsRequerida" style="-fx-text-fill: #C0392B; -fx-font-size: 11px;" text="* Requerido si hay diferencia"/>
                                <TextArea fx:id="txtObservaciones" promptText="Escribe una observacion si hay diferencia..." prefHeight="80"
                                          style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #1a6fa8; -fx-border-width: 1.2; -fx-font-size: 13px;"/>
                            </VBox>

                            <!-- Botones -->
                            <HBox spacing="12">
                                <Button onAction="#irADashboard" prefHeight="44" prefWidth="200"
                                        style="-fx-background-color: transparent; -fx-border-color: #1a6fa8; -fx-border-radius: 10; -fx-border-width: 1.2; -fx-text-fill: #1a6fa8; -fx-font-size: 13px; -fx-cursor: hand; -fx-background-radius: 10;"
                                        text="Cancelar"/>
                                <Button onAction="#exportarCortePDF" prefHeight="44" prefWidth="200"
                                        style="-fx-background-color: transparent; -fx-text-fill: #1a6fa8; -fx-border-color: #1a6fa8; -fx-border-width: 1.2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;"
                                        text="Exportar PDF"/>
                                <Button fx:id="btnCerrarCaja" onAction="#handleCerrarCaja" prefHeight="44" HBox.hgrow="ALWAYS"
                                        style="-fx-background-color: #C0392B; -fx-background-radius: 10; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;"
                                        text="Cerrar Caja"/>
                            </HBox>

                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- TAB ventas por cajero -->
                <Tab text="Ventas por Cajero">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <VBox spacing="14" style="-fx-padding: 16 4 20 4;">

                            <VBox spacing="10"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                                <HBox alignment="CENTER_LEFT">
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Desglose de ventas por cajero"/>
                                        <Label style="-fx-font-size: 11px; -fx-text-fill: #6a96b8;" text="Cuánto vendió cada usuario en esta sesión de caja"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <TableView fx:id="tablaCajeros" prefHeight="260" style="-fx-background-radius: 8;">
                                    <columns>
                                        <TableColumn fx:id="colCajeroNombre" text="Cajero" prefWidth="180"/>
                                        <TableColumn fx:id="colCajeroTickets" text="Tickets" prefWidth="80"/>
                                        <TableColumn fx:id="colCajeroTotal" text="Total vendido" prefWidth="140"/>
                                        <TableColumn fx:id="colCajeroPromedio" text="Ticket promedio" prefWidth="140"/>
                                    </columns>
                                    <placeholder>
                                        <Label text="No hay datos de ventas para esta caja" style="-fx-text-fill: #6a96b8;"/>
                                    </placeholder>
                                </TableView>
                            </VBox>

                            <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;" spacing="8">
                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Total global de la caja"/>
                                <Separator/>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 13px;" text="Total combinado de todos los cajeros:"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblTotalCombinado" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="\$0.00"/>
                                </HBox>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- TAB metodos de pago -->
                <Tab text="Métodos de Pago">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <VBox spacing="14" style="-fx-padding: 16 4 20 4;">

                            <VBox spacing="10"
                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                                <HBox alignment="CENTER_LEFT">
                                    <VBox spacing="2">
                                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="Ventas por método de pago"/>
                                        <Label style="-fx-font-size: 11px; -fx-text-fill: #6a96b8;" text="Solo se muestran los métodos utilizados en esta caja"/>
                                    </VBox>
                                </HBox>
                                <Separator/>
                                <VBox fx:id="vboxMetodosPago" spacing="8"/>
                                <Label fx:id="lblSinMetodos" style="-fx-text-fill: #6a96b8; -fx-font-size: 12px;" text="No se registraron ventas en esta caja." visible="false" managed="false"/>
                            </VBox>

                            <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;" spacing="8">
                                <Separator/>
                                <HBox alignment="CENTER_LEFT">
                                    <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 13px;" text="Total general de ventas:"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblTotalMetodos" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0d3d5e;" text="\$0.00"/>
                                </HBox>
                            </VBox>

                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- TAB historial de cortes -->
                <Tab text="Historial de Cortes">
                    <VBox spacing="12" style="-fx-padding: 16 4 20 4;">

                        <HBox spacing="12" alignment="CENTER_LEFT"
                              style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, #1a6fa820, 12, 0, 0, 2); -fx-padding: 18;">
                            <Label style="-fx-text-fill: #6a96b8; -fx-font-size: 13px;" text="Mostrar últimos:"/>
                            <Button onAction="#cargarHistorial10" prefHeight="32" prefWidth="70"
                                    style="-fx-background-color: #1a6fa8; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 12px;"
                                    text="10"/>
                            <Button onAction="#cargarHistorial30" prefHeight="32" prefWidth="70"
                                    style="-fx-background-color: transparent; -fx-border-color: #1a6fa8; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #1a6fa8; -fx-cursor: hand; -fx-font-size: 12px;"
                                    text="30"/>
                            <Button onAction="#cargarHistorialTodos" prefHeight="32" prefWidth="70"
                                    style="-fx-background-color: transparent; -fx-border-color: #1a6fa8; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #1a6fa8; -fx-cursor: hand; -fx-font-size: 12px;"
                                    text="Todos"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblTotalCortes" style="-fx-text-fill: #6a96b8; -fx-font-size: 11px;" text=""/>
                        </HBox>

                        <TableView fx:id="tablaHistorial" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8;">
                            <columns>
                                <TableColumn fx:id="colHisId" text="#" prefWidth="45"/>
                                <TableColumn fx:id="colHisCajero" text="Cajero" prefWidth="130"/>
                                <TableColumn fx:id="colHisCaja" text="Caja" prefWidth="65"/>
                                <TableColumn fx:id="colHisApertura" text="Apertura" prefWidth="130"/>
                                <TableColumn fx:id="colHisCierre" text="Cierre" prefWidth="130"/>
                                <TableColumn fx:id="colHisVentas" text="Ventas" prefWidth="100"/>
                                <TableColumn fx:id="colHisEsperado" text="Esperado" prefWidth="100"/>
                                <TableColumn fx:id="colHisReal" text="Contado" prefWidth="100"/>
                                <TableColumn fx:id="colHisDiferencia" text="Diferencia" prefWidth="100"/>
                            </columns>
                            <placeholder>
                                <Label text="No hay cortes registrados" style="-fx-text-fill: #6a96b8;"/>
                            </placeholder>
                        </TableView>

                    </VBox>
                </Tab>

            </TabPane>

        </VBox>
    </center>

</BorderPane>
